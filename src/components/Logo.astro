---
// We importeren de Tesla afbeelding als het miniatuur-logo
import logoImg from '~/assets/images/tesla_nad_services.webp';
---

<span class="self-center ml-2 rtl:ml-0 rtl:mr-2 flex items-center gap-3">
  <!-- Het auto-icoon -->
  <img 
    src={logoImg.src} 
    alt="InTaxi Amsterdam Logo" 
    class="h-10 md:h-12 w-auto object-contain"
    loading="eager"
  />
  
  <!-- De tekst: InTaxi Amsterdam -->
  <span class="text-xl md:text-2xl font-black text-[#003399] whitespace-nowrap dark:text-white tracking-tighter">
    InTaxi <span class="text-blue-500 font-extrabold">Amsterdam</span>
  </span>
</span>
