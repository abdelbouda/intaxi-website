---
/* PriceCalculator.astro - Clean Version voor Compiler */
import { Image } from 'astro:assets';
import teslaLogo from '../../assets/images/tesla_nad_services.webp';
import vitoLogo from '../../assets/images/busje_nad_services.webp';
---

<section id="prijs-calculator" class="bg-slate-50 dark:bg-slate-900 py-4 scroll-mt-20">
  <div class="max-w-4xl mx-auto px-4">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl border border-gray-100 dark:border-slate-700 overflow-hidden">
      <div class="bg-[#003399] h-1.5 w-full"></div>

      <div class="p-4 md:p-6">
        <div class="grid lg:grid-cols-2 gap-6 items-start">
          
          <!-- STAP 1: REIS -->
          <div class="space-y-3">
            <div class="flex items-center gap-2 mb-1">
              <span class="bg-[#003399] text-white w-5 h-5 flex items-center justify-center rounded-full text-[10px] font-bold">1</span>
              <h2 class="text-sm font-black text-[#003399] uppercase tracking-wider">Reisgegevens</h2>
            </div>

            <div class="grid gap-2">
              <div class="grid grid-cols-4 gap-2">
                <div class="col-span-3 relative">
                  <div class="flex items-center bg-gray-50 dark:bg-slate-700 rounded-lg px-3 py-2 border border-gray-200 dark:border-slate-600 focus-within:border-[#003399]">
                    <span class="text-xs mr-2">📍</span>
                    <input type="text" id="pickup-input" placeholder="Ophaaladres..." class="w-full bg-transparent outline-none text-xs font-semibold" />
                  </div>
                  <div id="pickup-results" class="absolute z-50 w-full bg-white shadow-xl hidden max-h-32 overflow-y-auto border rounded-b-lg text-[11px]"></div>
                </div>
                <input type="text" id="pickup-house" placeholder="Nr" class="bg-gray-50 dark:bg-slate-700 rounded-lg px-3 py-2 border border-gray-200 dark:border-slate-600 text-xs font-semibold outline-none focus:border-[#003399]" />
              </div>

              <div class="grid grid-cols-4 gap-2">
                <div class="col-span-3 relative">
                  <div class="flex items-center bg-gray-50 dark:bg-slate-700 rounded-lg px-3 py-2 border border-gray-200 dark:border-slate-600 focus-within:border-[#003399]">
                    <span class="text-xs mr-2">🏁</span>
                    <input type="text" id="dest-input" placeholder="Bestemming..." class="w-full bg-transparent outline-none text-xs font-semibold" />
                  </div>
                  <div id="dest-results" class="absolute z-50 w-full bg-white shadow-xl hidden max-h-40 overflow-y-auto border rounded-b-lg text-[11px]"></div>
                </div>
                <input type="text" id="dest-house" placeholder="Nr" class="bg-gray-50 dark:bg-slate-700 rounded-lg px-3 py-2 border border-gray-200 dark:border-slate-600 text-xs font-semibold outline-none focus:border-[#003399]" />
              </div>

              <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg px-3 py-2 border border-blue-100 flex justify-between items-center">
                 <span class="text-[9px] uppercase font-bold text-blue-400">Ritdetails:</span>
                 <p class="text-xs font-black text-[#003399] dark:text-blue-300">
                    <span id="est-time">--</span> min / <span id="est-km">--</span> km
                 </p>
              </div>

              <div class="grid grid-cols-2 gap-2">
                <input type="date" id="pickup-date" class="bg-gray-50 dark:bg-slate-700 rounded-lg px-3 py-2 border border-gray-200 dark:border-slate-600 text-[11px] font-bold outline-none" />
                <input type="time" id="pickup-time" class="bg-gray-50 dark:bg-slate-700 rounded-lg px-3 py-2 border border-gray-200 dark:border-slate-600 text-[11px] font-bold outline-none" />
              </div>
            </div>

            <!-- VOERTUIGEN -->
            <div class="grid grid-cols-2 gap-2 pt-1">
              <button type="button" id="v-auto" onclick="setVehicle('auto')" class="bg-white dark:bg-slate-700 border-b-4 border-gray-200 p-2 rounded-xl transition-all">
                <div class="flex flex-col items-center">
                  <Image src={teslaLogo} alt="Tesla" width={60} height={30} class="w-12 h-auto mb-1" />
                  <span class="text-[10px] font-bold">Tesla</span>
                  <span id="price-auto" class="text-xs font-black text-[#003399]">€ --</span>
                </div>
              </button>
              <button type="button" id="v-bus" onclick="setVehicle('bus')" class="bg-white dark:bg-slate-700 border-b-4 border-gray-200 p-2 rounded-xl transition-all">
                <div class="flex flex-col items-center">
                  <Image src={vitoLogo} alt="Busje" width={60} height={30} class="w-12 h-auto mb-1" />
                  <span class="text-[10px] font-bold">Busje</span>
                  <span id="price-bus" class="text-xs font-black text-[#003399]">€ --</span>
                </div>
              </button>
            </div>
          </div>

          <!-- STAP 2: CONTACT -->
          <div class="space-y-3 lg:border-l border-gray-100 lg:pl-6">
            <div class="flex items-center gap-2 mb-1">
              <span class="bg-[#003399] text-white w-5 h-5 flex items-center justify-center rounded-full text-[10px] font-bold">2</span>
              <h2 class="text-sm font-black text-[#003399] uppercase tracking-wider">Contactgegevens</h2>
            </div>
            <div class="grid grid-cols-2 gap-2">
              <input type="text" id="cust-first-name" placeholder="Voornaam *" class="p-2.5 text-xs bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-lg outline-none" />
              <input type="text" id="cust-last-name" placeholder="Achternaam" class="p-2.5 text-xs bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-lg outline-none" />
            </div>
            <input type="tel" id="cust-phone" placeholder="Telefoonnummer *" class="w-full p-2.5 text-xs bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-lg outline-none" />
            <textarea id="cust-notes" placeholder="Vluchtnummer of opmerkingen..." class="w-full p-2.5 text-xs bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-lg h-20 outline-none resize-none"></textarea>
            
            <button id="final-reserve-btn" class="w-full bg-[#003399] text-white font-black py-3 rounded-xl shadow-lg active:translate-y-1 transition-all text-xs uppercase tracking-widest">
              Nu Boeken via WhatsApp
            </button>
            <p id="error-msg" class="text-[10px] text-red-500 font-bold text-center opacity-0">
              Vul a.u.b. alle verplichte velden (*) in.
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  var selectedVehicle = 'auto';
  var pickupCoords = null;
  var destCoords = null;
  var destInNL = false;

  const airports = [
    { name: "Schiphol (AMS)", coords: [4.7683, 52.3105], fixed: false },
    { name: "Eindhoven Airport (EIN)", coords: [5.3912, 51.4584], fixed: false },
    { name: "Rotterdam (RTM)", coords: [4.4372, 51.9225], fixed: false }
  ];

  window.addEventListener('DOMContentLoaded', function() {
    document.getElementById('pickup-date').value = new Date().toISOString().split('T')[0];
    document.getElementById('pickup-time').value = "12:00";
    setVehicle('auto');
    setupAutocomplete('pickup-input', 'pickup-results', function(c) { pickupCoords = c; calculatePrice(); });
    setupAutocomplete('dest-input', 'dest-results', function(c) { destCoords = c; calculatePrice(); });
  });

  window.setVehicle = function(type) {
    selectedVehicle = type;
    document.getElementById('v-auto').classList.toggle('active-vehicle', type === 'auto');
    document.getElementById('v-bus').classList.toggle('active-vehicle', type === 'bus');
  };

  async function calculatePrice() {
    if (!pickupCoords || !destCoords) return;
    const pVal = document.getElementById('pickup-input').value.toLowerCase();
    const dVal = document.getElementById('dest-input').value.toLowerCase();

    try {
      const res = await fetch('https://router.project-osrm.org/route/v1/driving/' + pickupCoords[0] + ',' + pickupCoords[1] + ';' + destCoords[0] + ',' + destCoords[1]);
      const data = await res.json();
      const r = data.routes[0];
      const km = r.distance / 1000;
      const min = r.duration / 60;
      
      document.getElementById('est-time').innerText = Math.round(min);
      document.getElementById('est-km').innerText = Math.round(km);
      
      let tAuto = (4.31 + (km * 3.17) + (min * 0.52)) * 0.90;
      let tBus = (8.75 + (km * 3.63) + (min * 0.60)) * 0.90;

      if ((pVal.includes('amsterdam') && dVal.includes('amsterdam')) || dVal.includes('schiphol')) {
          if (tAuto > 55) tAuto = 55;
          if (tBus > 70) tBus = 70;
      }
      if (destInNL) {
        if (tAuto > 250) tAuto = 250;
        if (tBus > 300) tBus = 300;
      }
      document.getElementById('price-auto').innerText = '€ ' + Math.floor(tAuto) + ',-';
      document.getElementById('price-bus').innerText = '€ ' + Math.floor(tBus) + ',-';
    } catch (e) {}
  }

  function setupAutocomplete(id, resId, cb) {
    const inp = document.getElementById(id);
    const res = document.getElementById(resId);
    inp.addEventListener('input', async function(e) {
      const v = e.target.value;
      res.innerHTML = '';
      if (v.length < 2) { res.classList.add('hidden'); return; }
      
      const r = await fetch('https://photon.komoot.io/api/?q=' + encodeURIComponent(v) + '&limit=5');
      const d = await r.json();
      d.features.forEach(function(f) {
        const div = document.createElement('div');
        div.className = 'p-2 hover:bg-blue-50 cursor-pointer border-b text-[10px]';
        const n = (f.properties.name || '') + ' ' + (f.properties.city || '') + ', ' + (f.properties.country || '');
        div.innerText = n;
        div.onclick = function() {
          inp.value = n;
          res.classList.add('hidden');
          destInNL = f.properties.country === 'Netherlands' || f.properties.countrycode === 'NL';
          cb(f.geometry.coordinates);
        };
        res.appendChild(div);
      });
      res.classList.remove('hidden');
    });
  }

  document.getElementById('final-reserve-btn').onclick = function() {
    const fn = document.getElementById('cust-first-name').value;
    const ph = document.getElementById('cust-phone').value;
    const pi = document.getElementById('pickup-input').value;
    const pr = selectedVehicle === 'auto' ? document.getElementById('price-auto').innerText : document.getElementById('price-bus').innerText;
    if (!fn || !ph || !pi || pr.includes('--')) { 
        const e = document.getElementById('error-msg');
        e.style.opacity = 1;
        setTimeout(() => e.style.opacity = 0, 3000);
        return; 
    }
    const msg = encodeURIComponent("🚕 INTAXI BOEKING\n\nKlant: "+fn+"\nTel: "+ph+"\nVan: "+pi+"\nNaar: "+document.getElementById('dest-input').value+"\nPrijs: "+pr);
    window.open("https://wa.me/31642277607?text=" + msg, "_blank");
  };
</script>

<style>
  .active-vehicle { border-color: #003399 !important; background-color: #f0f7ff !important; border-bottom-width: 0px !important; transform: translateY(2px); }
</style>
