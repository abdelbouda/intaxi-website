---
/* PriceCalculator.astro */
---

<section id="prijs-calculator" class="bg-blue-50 dark:bg-slate-900 py-12">
  <div class="max-w-4xl mx-auto px-4">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl p-8 border border-blue-100 dark:border-slate-700">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold mb-2">Bereken uw voordeel</h2>
        <p class="text-gray-600 dark:text-gray-400">
          Vergelijk ons vaste tarief met de wettelijke maximumtarieven van 2026.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        <!-- Input Velden -->
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium mb-1">Vertreklocatie</label>
            <input 
              type="text" 
              id="pickup-location" 
              placeholder="Adres in NL of vliegveld in BE/DE" 
              class="w-full p-3 rounded-lg border border-gray-300 dark:bg-slate-700 dark:border-slate-600 focus:ring-2 focus:ring-blue-500 outline-none"
            />
          </div>
          <div>
            <label class="block text-sm font-medium mb-1">Bestemming</label>
            <input 
              type="text" 
              id="dropoff-location" 
              value="Luchthaven Schiphol" 
              readonly
              class="w-full p-3 rounded-lg border border-gray-200 bg-gray-50 dark:bg-slate-700 dark:border-slate-600"
            />
          </div>
          <button id="calc-btn" class="w-full bg-[#003399] text-white font-bold py-3 rounded-lg hover:bg-blue-700 transition duration-300">
            Bereken prijs
          </button>
        </div>

        <!-- Resultaten -->
        <div id="results" class="bg-blue-50 dark:bg-slate-700/50 rounded-xl p-6 flex flex-col justify-center border-2 border-dashed border-blue-200 dark:border-slate-600">
          <div id="calc-placeholder" class="text-center text-gray-500">
            Voer uw adres in voor een prijsvergelijking.
          </div>
          <div id="calc-output" class="hidden space-y-4">
            <div class="flex justify-between items-center border-b pb-2">
              <span class="text-sm">Wettelijk Max. Tarief (2026)</span>
              <span id="max-price" class="font-semibold text-red-600 line-through"></span>
            </div>
            <div class="flex justify-between items-center">
              <span class="text-lg font-bold text-[#003399]">InTaxi Vast Tarief</span>
              <span class="text-2xl font-black text-[#003399]">€75,00</span>
            </div>
            <div id="saving-box" class="bg-green-100 text-green-800 p-3 rounded-lg text-center font-bold">
              U bespaart circa <span id="saving-amount"></span>!
            </div>
          </div>
        </div>
      </div>
      
      <p class="text-[10px] text-gray-400 mt-6 italic">
        * De berekening is gebaseerd op het starttarief (€4,31), kilometertarief (€3,17) en tijdtarief (€0,52) conform Rijksoverheid 2026.
      </p>
    </div>
  </div>
</section>

<script>
  // Tariefdata 2026
  const TARIEVEN = {
    start: 4.31, //
    km: 3.17,    //
    min: 0.52    //
  };

  // Deze functie simuleert de berekening. 
  // In een productie-omgeving zou je hier de Google Distance Matrix API aanroepen.
  document.getElementById('calc-btn').addEventListener('click', () => {
    const pickup = (document.getElementById('pickup-location') as HTMLInputElement).value;
    
    if (!pickup) return alert("Voer aub een locatie in.");

    // Demo logica: we simuleren een afstand van 25km en 30 minuten voor Amsterdam
    const afstand = 25; 
    const tijd = 30;

    const maxPrijs = TARIEVEN.start + (afstand * TARIEVEN.km) + (tijd * TARIEVEN.min); //
    const vastTarief = 75.00; //
    const besparing = maxPrijs - vastTarief;

    document.getElementById('calc-placeholder').classList.add('hidden');
    const output = document.getElementById('calc-output');
    output.classList.remove('hidden');

    document.getElementById('max-price').innerText = `€${maxPrijs.toFixed(2)}`;
    document.getElementById('saving-amount').innerText = `€${besparing.toFixed(2)}`;
  });

  // Notitie voor implementatie: 
  // Gebruik de Google Autocomplete API met 'componentRestrictions' voor NL, BE, DE.
  // Filter BE/DE resultaten op type 'airport'.
</script>
