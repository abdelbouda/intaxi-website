---
/* PriceCalculator.astro - Ruimere versie met Prijs-Cap & Validatie */
import { Image } from 'astro:assets';
import teslaLogo from '../../assets/images/tesla_nad_services.webp';
import vitoLogo from '../../assets/images/busje_nad_services.webp';
---

<section id="prijs-calculator" class="bg-slate-50 dark:bg-slate-900 py-6 scroll-mt-10">
  <div class="max-w-5xl mx-auto px-4">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl border border-gray-100 dark:border-slate-700 overflow-hidden">
      <div class="bg-[#003399] h-2 w-full"></div>

      <div class="p-6 md:p-8">
        <div class="grid lg:grid-cols-2 gap-10 items-start">
          
          <div class="space-y-4">
            <div class="flex items-center gap-3">
              <span class="bg-[#003399] text-white w-6 h-6 flex items-center justify-center rounded-full text-xs font-bold">1</span>
              <h2 class="text-sm font-black text-[#003399] uppercase tracking-wider">Reisdetails</h2>
            </div>

            <div class="grid gap-3">
              <div class="grid grid-cols-4 gap-2">
                <div class="col-span-3 relative">
                  <div class="flex items-center bg-gray-50 dark:bg-slate-700 rounded-lg px-3 py-3 border border-gray-200 dark:border-slate-600 focus-within:border-[#003399]">
                    <span class="mr-2">📍</span>
                    <input type="text" id="pickup-input" placeholder="Ophaaladres..." class="w-full bg-transparent outline-none text-sm font-semibold" />
                  </div>
                  <div id="pickup-results" class="absolute z-50 w-full bg-white shadow-2xl hidden max-h-48 overflow-y-auto border rounded-b-lg text-sm"></div>
                </div>
                <input type="text" id="pickup-house" placeholder="Nr" class="bg-gray-50 dark:bg-slate-700 rounded-lg px-3 py-3 border border-gray-200 text-sm font-bold outline-none focus:border-[#003399]" />
              </div>

              <div class="grid grid-cols-4 gap-2">
                <div class="col-span-3 relative">
                  <div class="flex items-center bg-gray-50 dark:bg-slate-700 rounded-lg px-3 py-3 border border-gray-200 dark:border-slate-600 focus-within:border-[#003399]">
                    <span class="mr-2">🏁</span>
                    <input type="text" id="dest-input" placeholder="Bestemming (Vliegveld of Stad)..." class="w-full bg-transparent outline-none text-sm font-semibold" />
                  </div>
                  <div id="dest-results" class="absolute z-50 w-full bg-white shadow-2xl hidden max-h-48 overflow-y-auto border rounded-b-lg text-sm"></div>
                </div>
                <input type="text" id="dest-house" placeholder="Nr" class="bg-gray-50 dark:bg-slate-700 rounded-lg px-3 py-3 border border-gray-200 text-sm font-bold outline-none focus:border-[#003399]" />
              </div>

              <div class="grid grid-cols-2 gap-3">
                <input type="date" id="pickup-date" class="bg-gray-50 dark:bg-slate-700 rounded-lg px-3 py-3 border border-gray-200 text-sm font-bold outline-none focus:border-[#003399]" />
                <input type="time" id="pickup-time" value="12:00" class="bg-gray-50 dark:bg-slate-700 rounded-lg px-3 py-3 border border-gray-200 text-sm font-bold outline-none focus:border-[#003399]" />
              </div>

              <div class="bg-blue-50 dark:bg-blue-900/20 rounded-lg px-4 py-3 border border-blue-100 flex justify-between items-center">
                <span class="text-xs uppercase font-bold text-blue-500">Geschatte rit:</span>
                <span class="text-sm font-black text-[#003399]"><span id="est-time">--</span> min / <span id="est-km">--</span> km</span>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-4 pt-2">
              <div id="v-auto" onclick="setVehicle('auto')" class="active-vehicle group relative bg-white dark:bg-slate-700 border-2 border-gray-100 p-4 rounded-xl cursor-pointer transition-all hover:border-[#003399] flex flex-col items-center">
                <Image src={teslaLogo} alt="Tesla" width={80} height={40} class="w-16 h-auto mb-2 object-contain" />
                <span class="text-[10px] font-bold text-gray-400 uppercase">Tesla</span>
                <span class="text-lg font-black text-[#003399]" id="price-auto">€ --</span>
              </div>
              <div id="v-bus" onclick="setVehicle('bus')" class="group relative bg-white dark:bg-slate-800 border-2 border-gray-100 p-4 rounded-xl cursor-pointer transition-all hover:border-[#003399] flex flex-col items-center">
                <Image src={vitoLogo} alt="Vito" width={80} height={40} class="w-16 h-auto mb-2 object-contain" />
                <span class="text-[10px] font-bold text-gray-400 uppercase">Busje</span>
                <span class="text-lg font-black text-[#003399]" id="price-bus">€ --</span>
              </div>
            </div>
          </div>

          <div class="space-y-4 lg:border-l lg:border-gray-100 lg:pl-10">
            <div class="flex items-center gap-3">
              <span class="bg-[#003399] text-white w-6 h-6 flex items-center justify-center rounded-full text-xs font-bold">2</span>
              <h2 class="text-sm font-black text-[#003399] uppercase tracking-wider">Contact & Boeken</h2>
            </div>
            
            <div class="grid grid-cols-2 gap-3">
              <input type="text" id="cust-first-name" placeholder="Voornaam *" class="w-full p-3.5 text-sm bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-lg outline-none focus:border-[#003399]" />
              <input type="text" id="cust-last-name" placeholder="Achternaam" class="w-full p-3.5 text-sm bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-lg outline-none focus:border-[#003399]" />
            </div>
            <input type="tel" id="cust-phone" placeholder="Telefoonnummer *" class="w-full p-3.5 text-sm bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-lg outline-none focus:border-[#003399]" />
            <textarea id="cust-notes" placeholder="Vluchtnummer of andere opmerkingen..." class="w-full p-3.5 text-sm bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-lg h-24 outline-none focus:border-[#003399] resize-none"></textarea>
            
            <button id="final-reserve-btn" class="w-full bg-[#25D366] hover:bg-[#128C7E] text-white font-black py-5 rounded-xl shadow-lg transition-all flex items-center justify-center gap-3 text-sm uppercase tracking-widest mt-2">
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.417-.003 6.557-5.338 11.892-11.893 11.892-1.997-.001-3.951-.5-5.688-1.448l-6.305 1.652zm6.599-3.835c1.406.836 2.492 1.24 4.39 1.24 5.33 0 9.675-4.346 9.678-9.677.001-2.583-1.003-5.01-2.827-6.834-1.825-1.825-4.253-2.83-6.837-2.831-5.33 0-9.673 4.346-9.676 9.677-.001 1.83.479 3.125 1.385 4.69l-.934 3.413 3.421-.899zm10.155-5.592c-.286-.143-1.688-.833-1.949-.928-.261-.095-.451-.143-.641.143-.19.286-.737.928-.903 1.118-.166.19-.333.214-.618.071-.285-.143-1.206-.444-2.298-1.417-.85-.758-1.423-1.694-1.59-1.979-.166-.286-.018-.44.125-.581.128-.128.286-.333.428-.5.143-.166.19-.286.286-.476.095-.19.048-.357-.024-.5-.071-.143-.641-1.545-.879-2.117-.231-.557-.466-.481-.641-.49-.166-.008-.356-.01-.546-.01s-.5.071-.76.357c-.26.286-.998.976-.998 2.38s1.022 2.761 1.164 2.951c.143.19 2.012 3.073 4.874 4.31.681.294 1.212.47 1.626.601.684.218 1.307.187 1.8.113.549-.082 1.688-.69 1.926-1.356.238-.666.238-1.237.166-1.356-.072-.119-.261-.19-.547-.333z"/></svg>
              Nu Boeken
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  document.getElementById('pickup-date').valueAsDate = new Date();

  let selectedVehicle = 'auto';
  let pickupCoords = null;
  let destCoords = null;
  let isNetherlands = false;

  window.setVehicle = function(type) {
    selectedVehicle = type;
    document.getElementById('v-auto').classList.toggle('active-vehicle', type === 'auto');
    document.getElementById('v-bus').classList.toggle('active-vehicle', type === 'bus');
  };

  async function searchAddress(query, resultsId, setCoords, checkCountry = false) {
    if (query.length < 3) return;
    const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=5&addressdetails=1`);
    const data = await res.json();
    const list = document.getElementById(resultsId);
    list.innerHTML = '';
    list.classList.remove('hidden');

    data.forEach(item => {
      const div = document.createElement('div');
      div.className = 'p-3 hover:bg-blue-50 cursor-pointer border-b border-gray-50 last:border-0 font-medium transition-colors';
      div.innerText = item.display_name;
      div.onclick = () => {
        document.getElementById(resultsId.replace('-results', '-input')).value = item.display_name;
        list.classList.add('hidden');
        setCoords([parseFloat(item.lon), parseFloat(item.lat)]);
        if (checkCountry) {
          isNetherlands = item.address && item.address.country_code === 'nl';
        }
        calculatePrice();
      };
      list.appendChild(div);
    });
  }

  document.getElementById('pickup-input').oninput = (e) => searchAddress(e.target.value, 'pickup-results', (c) => pickupCoords = c);
  document.getElementById('dest-input').oninput = (e) => searchAddress(e.target.value, 'dest-results', (c) => destCoords = c, true);

  async function calculatePrice() {
    if (!pickupCoords || !destCoords) return;
    try {
      const res = await fetch(`https://router.project-osrm.org/route/v1/driving/${pickupCoords[0]},${pickupCoords[1]};${destCoords[0]},${destCoords[1]}`);
      const data = await res.json();
      const r = data.routes[0];
      const km = r.distance / 1000;
      const min = r.duration / 60;

      document.getElementById('est-time').innerText = Math.round(min);
      document.getElementById('est-km').innerText = Math.round(km);

      let pA = Math.floor((4.31 + (km * 3.17) + (min * 0.52)) * 0.9);
      let pB = Math.floor((8.75 + (km * 3.63) + (min * 0.60)) * 0.9);

      // Prijs-Cap logica: Indien NL en boven limiet -> Cap toepassen
      if (isNetherlands) {
        if (pA > 250) pA = 250;
        if (pB > 300) pB = 300;
      }

      document.getElementById('price-auto').innerText = `€ ${pA},-`;
      document.getElementById('price-bus').innerText = `€ ${pB},-`;
    } catch (e) { console.error("Fout bij berekening", e); }
  }

  document.getElementById('final-reserve-btn').onclick = function() {
    const fields = {
      'Ophaaladres': 'pickup-input',
      'Bestemming': 'dest-input',
      'Voornaam': 'cust-first-name',
      'Telefoonnummer': 'cust-phone'
    };

    let missing = [];
    for (const [name, id] of Object.entries(fields)) {
      if (!document.getElementById(id).value.trim()) missing.push(name);
    }

    if (missing.length > 0) {
      alert("Vul a.u.b. de volgende verplichte velden in: " + missing.join(', '));
      return;
    }

    // WhatsApp Logica hier...
    alert("Bedankt! We openen WhatsApp voor uw reservering.");
  };
</script>

<style>
  .active-vehicle { 
    border-color: #003399 !important; 
    background-color: #f8fafc !important; 
    box-shadow: 0 10px 15px -3px rgb(0 51 153 / 0.1);
    transform: translateY(-2px);
  }
</style>
