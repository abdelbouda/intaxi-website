---
/* PriceCalculator.astro - 2-Staps Workflow gebaseerd op image_9e069c.png */
---

<section id="prijs-calculator" class="bg-slate-50 dark:bg-slate-900 py-8 scroll-mt-20">
  <div class="max-w-4xl mx-auto px-4">
    <div class="bg-[#2c2e33] rounded-3xl shadow-2xl border-4 border-red-600 overflow-hidden text-white">
      
      <!-- Top Bar: Taal (Optioneel) -->
      <div class="flex justify-end p-4">
        <select class="bg-white text-gray-800 text-sm rounded-md px-3 py-1 outline-none">
          <option>NL Dutch</option>
          <option>EN English</option>
        </select>
      </div>

      <div class="p-6 md:p-10">
        <!-- STAP 1: REIS (Gecombineerd Route + Voertuig) -->
        <div id="step-1" class="step-content space-y-4">
          
          <!-- Ophaalpunt -->
          <div class="relative bg-white rounded-xl p-4 flex items-center gap-3">
            <span class="text-gray-400">🔍</span>
            <input type="text" id="pickup-input" placeholder="Ophaalpunt (required)" class="w-full text-gray-800 outline-none font-medium" required />
            <div id="autocomplete-results" class="absolute z-50 left-0 top-full w-full bg-white shadow-2xl hidden max-h-48 overflow-y-auto border-t text-gray-800"></div>
          </div>

          <!-- Bestemming Info Box (Statisch visueel element) -->
          <div class="bg-white rounded-xl p-4 flex justify-between items-center text-gray-800">
             <div class="flex items-center gap-3">
               <span class="text-xl">✈️</span>
               <div>
                 <p class="text-[10px] uppercase font-bold text-gray-400">Selecteer uw bestemming</p>
                 <select id="destination-select" class="font-bold outline-none bg-transparent">
                    <option value="4.7683,52.3105">Schiphol Airport (AMS)</option>
                    <option value="4.4844,50.9010">Brussels Airport (BRU)</option>
                    <option value="4.4372,51.9225">Rotterdam Airport (RTM)</option>
                 </select>
               </div>
             </div>
             <div class="bg-gray-700 text-white p-2 rounded-lg text-center min-w-[80px]">
                <p class="text-[8px] uppercase">Journey Time</p>
                <p class="font-bold"><span id="est-time">--</span> Mins</p>
             </div>
          </div>

          <!-- Datum & Tijd Rij -->
          <div class="grid grid-cols-2 gap-4">
            <div class="bg-white rounded-xl p-4 text-gray-800">
               <p class="text-[10px] uppercase font-bold text-gray-400">Datum (Required)</p>
               <input type="date" id="pickup-date" class="w-full font-bold outline-none" required />
            </div>
            <div class="bg-white rounded-xl p-4 text-gray-800">
               <p class="text-[10px] uppercase font-bold text-gray-400">Time</p>
               <input type="time" id="pickup-time" class="w-full font-bold outline-none" required />
            </div>
          </div>

          <p class="text-center font-bold text-lg py-2">Selecteer uw reis</p>

          <!-- Voertuig Selectie -->
          <div class="space-y-3">
            <div onclick="selectVehicle('auto')" class="vehicle-card bg-white rounded-xl p-4 flex justify-between items-center text-gray-800 cursor-pointer hover:ring-4 hover:ring-blue-500 transition">
               <div class="flex items-center gap-4">
                 <span class="text-4xl">🚗</span>
                 <span class="font-bold text-xl">Sedan (Tesla)</span>
               </div>
               <span id="price-auto" class="font-black text-xl text-blue-600">€ --</span>
            </div>
            <div onclick="selectVehicle('bus')" class="vehicle-card bg-white rounded-xl p-4 flex justify-between items-center text-gray-800 cursor-pointer hover:ring-4 hover:ring-blue-500 transition">
               <div class="flex items-center gap-4">
                 <span class="text-4xl">🚐</span>
                 <span class="font-bold text-xl">Bus</span>
               </div>
               <span id="price-bus" class="font-black text-xl text-blue-600">€ --</span>
            </div>
          </div>
        </div>

        <!-- STAP 2: PERSOONLIJKE INFORMATIE -->
        <div id="step-2" class="step-content hidden space-y-6">
          <div class="bg-gray-800/50 p-6 rounded-2xl border border-gray-700">
            <h3 class="text-center font-bold text-xl mb-6">Persoonlijke Informatie</h3>
            <div class="grid md:grid-cols-2 gap-4 text-gray-800">
              <input type="text" id="cust-first-name" placeholder="Voornaam *" class="p-4 rounded-xl outline-none" required />
              <input type="text" id="cust-last-name" placeholder="Achternaam *" class="p-4 rounded-xl outline-none" required />
              <input type="email" id="cust-email" placeholder="E-mailadres *" class="p-4 rounded-xl outline-none" required />
              <input type="tel" id="cust-phone" placeholder="Telefoonnummer *" class="p-4 rounded-xl outline-none" required />
            </div>
            <textarea id="cust-notes" placeholder="Vluchtnummer of extra info..." class="w-full mt-4 p-4 rounded-xl text-gray-800 h-24 outline-none"></textarea>
          </div>

          <div class="flex gap-4">
             <button onclick="toggleSteps(1)" class="w-1/3 bg-gray-600 py-4 rounded-xl font-bold uppercase">Terug</button>
             <button id="final-reserve-btn" class="w-2/3 bg-green-600 py-4 rounded-xl font-bold uppercase shadow-lg hover:bg-green-700 transition">Bevestig via WhatsApp</button>
          </div>
        </div>

        <!-- Bottom Navigation Tabs (Visual only as in image) -->
        <div class="mt-8 flex justify-center items-center gap-8 border-t border-gray-700 pt-6">
          <div class="text-center opacity-100" id="nav-step-1">
            <span class="bg-red-600 text-white w-6 h-6 inline-flex items-center justify-center rounded-full text-xs font-bold mb-1">1</span>
            <p class="text-[10px] uppercase font-bold">Reis</p>
          </div>
          <div class="h-px w-12 bg-gray-600"></div>
          <div class="text-center opacity-40" id="nav-step-2">
            <span class="bg-red-600 text-white w-6 h-6 inline-flex items-center justify-center rounded-full text-xs font-bold mb-1">2</span>
            <p class="text-[10px] uppercase font-bold">Persoonlijke informatie</p>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script is:inline>
  let tripData = { pickup: '', destination: '', destName: '', date: '', time: '', vehicle: '', price: 0 };
  const TARIEVEN = { auto: { start: 4.31, km: 3.17, min: 0.52 }, bus: { start: 8.75, km: 3.63, min: 0.60 } };

  function toggleSteps(step) {
    document.querySelectorAll('.step-content').forEach(el => el.classList.add('hidden'));
    document.getElementById('step-' + step).classList.remove('hidden');
    document.getElementById('nav-step-1').style.opacity = step === 1 ? '1' : '0.4';
    document.getElementById('nav-step-2').style.opacity = step === 2 ? '1' : '0.4';
  }

  // Live prijs berekening zodra ophaalpunt bekend is
  async function updatePrices() {
    const pickup = document.getElementById('pickup-input').value;
    if (pickup.length < 5) return;

    try {
      const res = await fetch(`https://photon.komoot.io/api/?q=${encodeURIComponent(pickup)}&limit=1`);
      const data = await res.json();
      const coords = data.features[0].geometry.coordinates;
      const destCoords = document.getElementById('destination-select').value;
      
      const routeRes = await fetch(`https://router.project-osrm.org/route/v1/driving/${coords[0]},${coords[1]};${destCoords}?overview=false`);
      const routeData = await routeRes.json();
      const r = routeData.routes[0];
      
      const km = r.distance / 1000;
      const min = r.duration / 60;
      document.getElementById('est-time').innerText = Math.round(min);

      ['auto', 'bus'].forEach(type => {
        const t = TARIEVEN[type];
        const prijs = Math.floor((t.start + (km * t.km) + (min * t.min)) * 0.90);
        document.getElementById('price-' + type).innerText = `€ ${prijs},-`;
      });
    } catch (e) { console.error("Route error"); }
  }

  function selectVehicle(type) {
    const priceText = document.getElementById('price-' + type).innerText;
    if (priceText === '€ --') {
      alert("Voer eerst een geldig ophaalpunt in."); return;
    }
    tripData.vehicle = type;
    tripData.price = priceText;
    tripData.pickup = document.getElementById('pickup-input').value;
    tripData.date = document.getElementById('pickup-date').value;
    tripData.time = document.getElementById('pickup-time').value;
    tripData.destName = document.getElementById('destination-select').options[document.getElementById('destination-select').selectedIndex].text;
    toggleSteps(2);
  }

  // WhatsApp Verwerking
  document.getElementById('final-reserve-btn').onclick = () => {
    const fName = document.getElementById('cust-first-name').value;
    const phone = document.getElementById('cust-phone').value;
    if (!fName || !phone) { alert("Vul uw gegevens in."); return; }

    const msg = encodeURIComponent(`🚕 NIEUWE BOEKING\n\nKlant: ${fName}\nTel: ${phone}\nRit: ${tripData.pickup} -> ${tripData.destName}\nDatum/Tijd: ${tripData.date} om ${tripData.time}\nVoertuig: ${tripData.vehicle}\nPrijs: ${tripData.price}`);
    window.open(`https://wa.me/31642277607?text=${msg}`, '_blank');
  };

  // Autocomplete & Trigger
  document.getElementById('pickup-input').onchange = updatePrices;
  document.getElementById('destination-select').onchange = updatePrices;
</script>
