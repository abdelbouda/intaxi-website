---
/* PriceCalculator.astro - Volledige Functionaliteit in Compact Kader */
import { Image } from 'astro:assets';
import teslaLogo from '../../assets/images/tesla_nad_services.webp';
import vitoLogo from '../../assets/images/busje_nad_services.webp';
---

<section id="prijs-calculator" class="bg-slate-50 dark:bg-slate-900 py-2 scroll-mt-10">
  <div class="max-w-4xl mx-auto px-2">
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-gray-100 dark:border-slate-700 overflow-hidden">
      <div class="bg-[#003399] h-1 w-full"></div>

      <div class="p-3 md:p-4">
        <div class="grid lg:grid-cols-2 gap-4 items-start">
          
          <div class="space-y-2">
            <div class="flex items-center gap-2">
              <span class="bg-[#003399] text-white w-4 h-4 flex items-center justify-center rounded-full text-[9px] font-bold">1</span>
              <h2 class="text-[11px] font-black text-[#003399] uppercase tracking-tight">Reisdetails</h2>
            </div>

            <div class="grid gap-1.5">
              <div class="grid grid-cols-4 gap-1.5">
                <div class="col-span-3 relative">
                  <div class="flex items-center bg-gray-50 dark:bg-slate-700 rounded-md px-2 py-1.5 border border-gray-200 dark:border-slate-600 focus-within:border-[#003399]">
                    <span class="text-[10px] mr-1">📍</span>
                    <input type="text" id="pickup-input" placeholder="Van..." class="w-full bg-transparent outline-none text-[11px] font-semibold" />
                  </div>
                  <div id="pickup-results" class="absolute z-50 w-full bg-white shadow-xl hidden max-h-32 overflow-y-auto border text-[10px] rounded-b-md"></div>
                </div>
                <input type="text" id="pickup-house" placeholder="Nr" class="bg-gray-50 dark:bg-slate-700 rounded-md px-2 py-1.5 border border-gray-200 text-[11px] font-semibold outline-none" />
              </div>

              <div class="grid grid-cols-4 gap-1.5">
                <div class="col-span-3 relative">
                  <div class="flex items-center bg-gray-50 dark:bg-slate-700 rounded-md px-2 py-1.5 border border-gray-200 dark:border-slate-600 focus-within:border-[#003399]">
                    <span class="text-[10px] mr-1">🏁</span>
                    <input type="text" id="dest-input" placeholder="Naar (vliegveld of stad)..." class="w-full bg-transparent outline-none text-[11px] font-semibold" />
                  </div>
                  <div id="dest-results" class="absolute z-50 w-full bg-white shadow-xl hidden max-h-32 overflow-y-auto border text-[10px] rounded-b-md"></div>
                </div>
                <input type="text" id="dest-house" placeholder="Nr" class="bg-gray-50 dark:bg-slate-700 rounded-md px-2 py-1.5 border border-gray-200 text-[11px] font-semibold outline-none" />
              </div>

              <div class="grid grid-cols-2 gap-1.5">
                <input type="date" id="pickup-date" class="bg-gray-50 dark:bg-slate-700 rounded-md px-2 py-1.5 border border-gray-200 text-[11px] font-bold outline-none" />
                <input type="time" id="pickup-time" value="12:00" class="bg-gray-50 dark:bg-slate-700 rounded-md px-2 py-1.5 border border-gray-200 text-[11px] font-bold outline-none" />
              </div>

              <div class="bg-blue-50 dark:bg-blue-900/20 rounded-md px-2 py-1 border border-blue-100 flex justify-between items-center">
                 <span class="text-[9px] uppercase font-bold text-blue-400">Rit: <span id="est-time" class="text-[#003399]">--</span> min / <span id="est-km" class="text-[#003399]">--</span> km</span>
              </div>
            </div>

            <div class="grid grid-cols-2 gap-2 pt-1">
              <div id="v-auto" onclick="setVehicle('auto')" class="active-vehicle group relative bg-white dark:bg-slate-700 border border-gray-200 p-1.5 rounded-lg cursor-pointer transition-all active:scale-95 flex flex-col items-center">
                <Image src={teslaLogo} alt="Tesla" width={40} height={20} class="w-10 h-auto mb-0.5 object-contain" />
                <span class="text-[9px] font-black text-[#003399]" id="price-auto">€ --</span>
              </div>
              <div id="v-bus" onclick="setVehicle('bus')" class="group relative bg-white dark:bg-slate-700 border border-gray-200 p-1.5 rounded-lg cursor-pointer transition-all active:scale-95 flex flex-col items-center">
                <Image src={vitoLogo} alt="Vito" width={40} height={20} class="w-10 h-auto mb-0.5 object-contain" />
                <span class="text-[9px] font-black text-[#003399]" id="price-bus">€ --</span>
              </div>
            </div>
          </div>

          <div class="space-y-2 lg:border-l border-gray-100 lg:pl-4">
            <div class="flex items-center gap-2">
              <span class="bg-[#003399] text-white w-4 h-4 flex items-center justify-center rounded-full text-[9px] font-bold">2</span>
              <h2 class="text-[11px] font-black text-[#003399] uppercase tracking-tight">Contact</h2>
            </div>
            <div class="grid grid-cols-2 gap-1.5">
              <input type="text" id="cust-first-name" placeholder="Voornaam *" class="p-2 text-[11px] bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-md outline-none" />
              <input type="text" id="cust-last-name" placeholder="Achternaam" class="p-2 text-[11px] bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-md outline-none" />
            </div>
            <input type="tel" id="cust-phone" placeholder="Telefoonnummer *" class="w-full p-2 text-[11px] bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-md outline-none" />
            <textarea id="cust-notes" placeholder="Vluchtnummer / opmerkingen..." class="w-full p-2 text-[11px] bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-md h-12 outline-none resize-none"></textarea>
            
            <button id="final-reserve-btn" class="w-full bg-[#003399] text-white font-black py-2.5 rounded-lg shadow-md hover:bg-blue-700 transition-all flex items-center justify-center gap-2 text-[10px] uppercase tracking-widest mt-1">
              Nu Boeken
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  // Stel datum in op vandaag
  document.getElementById('pickup-date').valueAsDate = new Date();

  let selectedVehicle = 'auto';
  let pickupCoords = null;
  let destCoords = null;

  const airports = [
    { name: "Schiphol (AMS)", coords: [4.7683, 52.3105], fixed: false },
    { name: "Eindhoven Airport (EIN)", coords: [5.3912, 51.4584], fixed: false },
    { name: "Rotterdam (RTM)", coords: [4.4372, 51.9225], fixed: false },
    { name: "Brussels Airport (BRU)", fixed: true },
    { name: "Charleroi (CRL)", fixed: true },
    { name: "Weeze Airport (NRN)", fixed: true },
    { name: "Düsseldorf (DUS)", fixed: true }
  ];

  window.setVehicle = function(type) {
    selectedVehicle = type;
    document.getElementById('v-auto').classList.toggle('active-vehicle', type === 'auto');
    document.getElementById('v-bus').classList.toggle('active-vehicle', type === 'bus');
  };

  async function searchAddress(query, resultsId, setCoords) {
    if (query.length < 3) return;
    const res = await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&limit=5&countrycodes=nl,be,de`);
    const data = await res.json();
    const list = document.getElementById(resultsId);
    list.innerHTML = '';
    list.classList.remove('hidden');

    // Vliegvelden toevoegen aan lijst
    airports.filter(a => a.name.toLowerCase().includes(query.toLowerCase())).forEach(a => {
      const div = document.createElement('div');
      div.className = 'p-2 hover:bg-gray-100 cursor-pointer font-bold text-[#003399]';
      div.innerText = "✈️ " + a.name;
      div.onclick = () => {
        document.getElementById(resultsId.replace('-results', '-input')).value = a.name;
        list.classList.add('hidden');
        if (a.coords) setCoords(a.coords);
        calculatePrice();
      };
      list.appendChild(div);
    });

    data.forEach(item => {
      const div = document.createElement('div');
      div.className = 'p-2 hover:bg-gray-100 cursor-pointer border-b last:border-0';
      div.innerText = item.display_name;
      div.onclick = () => {
        document.getElementById(resultsId.replace('-results', '-input')).value = item.display_name;
        list.classList.add('hidden');
        setCoords([parseFloat(item.lon), parseFloat(item.lat)]);
        calculatePrice();
      };
      list.appendChild(div);
    });
  }

  document.getElementById('pickup-input').oninput = (e) => searchAddress(e.target.value, 'pickup-results', (c) => pickupCoords = c);
  document.getElementById('dest-input').oninput = (e) => searchAddress(e.target.value, 'dest-results', (c) => destCoords = c);

  async function calculatePrice() {
    if (!pickupCoords || !destCoords) return;
    const destVal = document.getElementById('dest-input').value;
    const fixed = airports.find(a => a.name === destVal && a.fixed);
    
    if (fixed) {
      document.getElementById('price-auto').innerText = "€ 250,-";
      document.getElementById('price-bus').innerText = "€ 300,-";
      return;
    }

    try {
      const res = await fetch(`https://router.project-osrm.org/route/v1/driving/${pickupCoords[0]},${pickupCoords[1]};${destCoords[0]},${destCoords[1]}`);
      const data = await res.json();
      const r = data.routes[0];
      const km = r.distance / 1000;
      const min = r.duration / 60;

      document.getElementById('est-time').innerText = Math.round(min);
      document.getElementById('est-km').innerText = Math.round(km);

      let pA = (4.31 + (km * 3.17) + (min * 0.52)) * 0.9;
      let pB = (8.75 + (km * 3.63) + (min * 0.60)) * 0.9;

      document.getElementById('price-auto').innerText = `€ ${Math.floor(pA)},-`;
      document.getElementById('price-bus').innerText = `€ ${Math.floor(pB)},-`;
    } catch (e) {}
  }
</script>

<style>
  .active-vehicle { 
    border-color: #003399 !important; 
    background-color: #f0f7ff !important;
    border-width: 2px !important;
  }
</style>
