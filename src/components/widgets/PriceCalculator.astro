---
/* PriceCalculator.astro - Ultra Compact Version */
import { Image } from 'astro:assets';
import teslaLogo from '../../assets/images/tesla_nad_services.webp';
import vitoLogo from '../../assets/images/busje_nad_services.webp';
---

<section id="prijs-calculator" class="bg-slate-50 dark:bg-slate-900 py-2 scroll-mt-10">
  <div class="max-w-4xl mx-auto px-2">
    <div class="bg-white dark:bg-slate-800 rounded-xl shadow-lg border border-gray-100 dark:border-slate-700 overflow-hidden">
      <div class="bg-[#003399] h-1 w-full"></div>

      <div class="p-3 md:p-4">
        <div class="grid lg:grid-cols-2 gap-4 items-start">
          
          <!-- LINKERKANT: REIS -->
          <div class="space-y-2">
            <div class="flex items-center gap-2">
              <span class="bg-[#003399] text-white w-4 h-4 flex items-center justify-center rounded-full text-[9px] font-bold">1</span>
              <h2 class="text-[11px] font-black text-[#003399] uppercase tracking-tight">Reisdetails</h2>
            </div>

            <div class="grid gap-1.5">
              <div class="grid grid-cols-4 gap-1.5">
                <div class="col-span-3 relative">
                  <div class="flex items-center bg-gray-50 dark:bg-slate-700 rounded-md px-2 py-1.5 border border-gray-200 dark:border-slate-600 focus-within:border-[#003399]">
                    <span class="text-[10px] mr-1">📍</span>
                    <input type="text" id="pickup-input" placeholder="Ophaaladres..." class="w-full bg-transparent outline-none text-[11px] font-semibold" />
                  </div>
                  <div id="pickup-results" class="absolute z-50 w-full bg-white shadow-xl hidden max-h-32 overflow-y-auto border text-[10px]"></div>
                </div>
                <input type="text" id="pickup-house" placeholder="Nr" class="bg-gray-50 dark:bg-slate-700 rounded-md px-2 py-1.5 border border-gray-200 text-[11px] font-semibold outline-none" />
              </div>

              <div class="grid grid-cols-4 gap-1.5">
                <div class="col-span-3 relative">
                  <div class="flex items-center bg-gray-50 dark:bg-slate-700 rounded-md px-2 py-1.5 border border-gray-200 dark:border-slate-600 focus-within:border-[#003399]">
                    <span class="text-[10px] mr-1">🏁</span>
                    <input type="text" id="dest-input" placeholder="Bestemming..." class="w-full bg-transparent outline-none text-[11px] font-semibold" />
                  </div>
                  <div id="dest-results" class="absolute z-50 w-full bg-white shadow-xl hidden max-h-32 overflow-y-auto border text-[10px]"></div>
                </div>
                <input type="text" id="dest-house" placeholder="Nr" class="bg-gray-50 dark:bg-slate-700 rounded-md px-2 py-1.5 border border-gray-200 text-[11px] font-semibold outline-none" />
              </div>

              <div class="grid grid-cols-2 gap-1.5">
                <div class="bg-blue-50 dark:bg-blue-900/20 rounded-md px-2 py-1 border border-blue-100 flex justify-between items-center col-span-2">
                   <span class="text-[8px] uppercase font-bold text-blue-400">Rit: <span id="est-time" class="text-[#003399]">--</span> min / <span id="est-km" class="text-[#003399]">--</span> km</span>
                </div>
                <input type="date" id="pickup-date" class="bg-gray-50 dark:bg-slate-700 rounded-md px-2 py-1.5 border border-gray-200 text-[11px] font-bold outline-none" />
                <input type="time" id="pickup-time" class="bg-gray-50 dark:bg-slate-700 rounded-md px-2 py-1.5 border border-gray-200 text-[11px] font-bold outline-none" />
              </div>
            </div>

            <!-- VOERTUIGEN COMPACT -->
            <div class="grid grid-cols-2 gap-2 pt-1">
              <div id="v-auto" onclick="setVehicle('auto')" class="group relative bg-white dark:bg-slate-700 border-b-2 border-gray-200 p-1.5 rounded-lg cursor-pointer transition-all active:scale-95">
                <div class="flex flex-col items-center">
                  <Image src={teslaLogo} alt="Tesla" width={40} height={20} class="w-10 h-auto mb-0.5 object-contain" />
                  <span class="text-[9px] font-black text-[#003399]" id="price-auto">€ --</span>
                </div>
              </div>
              <div id="v-bus" onclick="setVehicle('bus')" class="group relative bg-white dark:bg-slate-700 border-b-2 border-gray-200 p-1.5 rounded-lg cursor-pointer transition-all active:scale-95">
                <div class="flex flex-col items-center">
                  <Image src={vitoLogo} alt="Vito" width={40} height={20} class="w-10 h-auto mb-0.5 object-contain" />
                  <span class="text-[9px] font-black text-[#003399]" id="price-bus">€ --</span>
                </div>
              </div>
            </div>
          </div>

          <!-- RECHTERKANT: CONTACT -->
          <div class="space-y-2 lg:border-l border-gray-100 lg:pl-4">
            <div class="flex items-center gap-2">
              <span class="bg-[#003399] text-white w-4 h-4 flex items-center justify-center rounded-full text-[9px] font-bold">2</span>
              <h2 class="text-[11px] font-black text-[#003399] uppercase tracking-tight">Contact</h2>
            </div>
            <div class="grid grid-cols-2 gap-1.5">
              <input type="text" id="cust-first-name" placeholder="Voornaam *" class="p-2 text-[11px] bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-md outline-none" />
              <input type="text" id="cust-last-name" placeholder="Achternaam" class="p-2 text-[11px] bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-md outline-none" />
            </div>
            <input type="tel" id="cust-phone" placeholder="Telefoonnummer *" class="w-full p-2 text-[11px] bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-md outline-none" />
            <textarea id="cust-notes" placeholder="Vluchtnummer / opmerkingen..." class="w-full p-2 text-[11px] bg-gray-50 dark:bg-slate-700 border border-gray-200 rounded-md h-12 outline-none resize-none"></textarea>
            
            <button id="final-reserve-btn" class="w-full bg-[#003399] text-white font-black py-2.5 rounded-lg shadow-md hover:translate-y-[1px] active:translate-y-[2px] transition-all flex items-center justify-center gap-2 text-[10px] uppercase tracking-widest">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.417-.003 6.557-5.338 11.892-11.893 11.892-1.997-.001-3.951-.5-5.688-1.448l-6.305 1.652zm6.599-3.835c1.406.836 2.492 1.24 4.39 1.24 5.33 0 9.675-4.346 9.678-9.677.001-2.583-1.003-5.01-2.827-6.834-1.825-1.825-4.253-2.83-6.837-2.831-5.33 0-9.673 4.346-9.676 9.677-.001 1.83.479 3.125 1.385 4.69l-.934 3.413 3.421-.899zm10.155-5.592c-.286-.143-1.688-.833-1.949-.928-.261-.095-.451-.143-.641.143-.19.286-.737.928-.903 1.118-.166.19-.333.214-.618.071-.285-.143-1.206-.444-2.298-1.417-.85-.758-1.423-1.694-1.59-1.979-.166-.286-.018-.44.125-.581.128-.128.286-.333.428-.5.143-.166.19-.286.286-.476.095-.19.048-.357-.024-.5-.071-.143-.641-1.545-.879-2.117-.231-.557-.466-.481-.641-.49-.166-.008-.356-.01-.546-.01s-.5.071-.76.357c-.26.286-.998.976-.998 2.38s1.022 2.761 1.164 2.951c.143.19 2.012 3.073 4.874 4.31.681.294 1.212.47 1.626.601.684.218 1.307.187 1.8.113.549-.082 1.688-.69 1.926-1.356.238-.666.238-1.237.166-1.356-.072-.119-.261-.19-.547-.333z"/></svg>
              Nu Boeken
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Script blijft hetzelfde als voorheen voor de logica -->

<style>
  .active-vehicle { 
    border-color: #003399 !important; 
    background-color: #f0f7ff !important; 
    border-bottom-width: 0px !important;
    transform: translateY(2px);
  }
</style>
