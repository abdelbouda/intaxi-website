---
/* PriceCalculator.astro - 10% Discount, Round Down, NL Only & Extra Fields */
---

<section id="prijs-calculator" class="bg-blue-50 dark:bg-slate-900 py-12 border-t border-b border-gray-200 dark:border-slate-800 scroll-mt-20">
  <div class="max-w-4xl mx-auto px-4">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl p-8 border border-blue-100 dark:border-slate-700">
      
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold mb-2 text-[#003399] dark:text-blue-400">Bereken uw ritprijs</h2>
        <p class="text-gray-600 dark:text-gray-400 font-medium">
          Profiteer nu van <span class="text-green-600 font-bold">10% korting</span> op de officiële 2026 tarieven!
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Linker kolom: Inputs -->
        <div class="space-y-5">
          <div class="relative">
            <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Straat / Stad</label>
            <input 
              type="text" 
              id="pickup-input" 
              placeholder="Typ ophaaladres..." 
              class="w-full p-3 rounded-lg border border-gray-300 dark:bg-slate-700 dark:border-slate-600 outline-none focus:ring-2 focus:ring-blue-500"
              autocomplete="off"
            />
            <div id="autocomplete-results" class="absolute z-20 w-full bg-white dark:bg-slate-800 shadow-2xl rounded-b-lg hidden max-h-60 overflow-y-auto border border-gray-200 dark:border-slate-600"></div>
          </div>

          <div class="grid grid-cols-3 gap-3">
            <div class="col-span-1">
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Huisnr.</label>
              <input type="text" id="house-number" placeholder="12a" class="w-full p-3 rounded-lg border border-gray-300 dark:bg-slate-700 dark:border-slate-600 outline-none focus:ring-2 focus:ring-blue-500" />
            </div>
            <div class="col-span-2">
              <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Bestemming</label>
              <select id="destination-select" class="w-full p-3 rounded-lg border border-gray-300 dark:bg-slate-700 dark:border-slate-600 outline-none focus:ring-2 focus:ring-blue-500">
                <option value="4.7683,52.3105">Schiphol Airport (AMS)</option>
                <option value="4.4844,50.9010">Brussels Airport (BRU)</option>
                <option value="6.7663,51.2895">Düsseldorf Airport (DUS)</option>
                <option value="4.4372,51.9225">Rotterdam Airport (RTM)</option>
                <option value="5.3916,51.4584">Eindhoven Airport (EIN)</option>
              </select>
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Opmerkingen (optioneel)</label>
            <textarea id="notes-input" placeholder="Bijv. vluchtnummer of extra bagage..." class="w-full p-3 rounded-lg border border-gray-300 dark:bg-slate-700 dark:border-slate-600 outline-none focus:ring-2 focus:ring-blue-500" rows="2"></textarea>
          </div>

          <div>
            <label class="block text-sm font-semibold mb-1 text-gray-700 dark:text-gray-300">Type Voertuig</label>
            <div class="grid grid-cols-2 gap-2">
              <button id="btn-auto" class="vehicle-btn active p-3 border-2 rounded-lg font-bold transition-colors" data-type="auto">Tesla (1-4p)</button>
              <button id="btn-bus" class="vehicle-btn p-3 border-2 border-gray-200 dark:border-slate-600 rounded-lg font-bold transition-colors text-gray-500" data-type="bus">Bus (5-8p)</button>
            </div>
          </div>

          <button id="calculate-btn" class="w-full bg-[#003399] text-white font-bold py-4 rounded-lg hover:bg-blue-800 transition shadow-lg">
            Bereken Ritprijs
          </button>
        </div>

        <!-- Rechter kolom: Resultaat -->
        <div id="results-box" class="bg-slate-50 dark:bg-slate-900/50 rounded-xl p-6 border-2 border-dashed border-slate-200 dark:border-slate-700 flex flex-col justify-center text-center relative overflow-hidden">
          <div id="calc-loader" class="hidden flex flex-col items-center">
            <div class="animate-spin rounded-full h-10 w-10 border-b-2 border-blue-600 mb-2"></div>
            <p>Prijs berekenen...</p>
          </div>
          
          <div id="calc-placeholder" class="text-gray-500 italic">
            Voer uw adres in voor een scherpe aanbieding inclusief 10% korting.
          </div>

          <div id="calc-output" class="hidden space-y-3">
             <div class="inline-block bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded mb-2 uppercase">10% Introductiekorting toegepast</div>
             <p class="text-sm font-medium text-gray-500 line-through" id="old-price"></p>
             <div class="py-2">
               <span id="display-price" class="text-6xl font-black text-[#003399] dark:text-blue-400">€ 0</span>
             </div>
             <div id="route-info" class="text-xs font-bold text-gray-500 bg-white dark:bg-slate-800 py-1 px-3 rounded-full border inline-block"></div>
             
             <div class="pt-4">
               <a href="#" id="whatsapp-link" target="_blank" class="inline-flex items-center justify-center bg-green-600 text-white px-6 py-4 rounded-full font-bold hover:bg-green-700 transition w-full shadow-md">
                  Reserveer deze prijs via WhatsApp
               </a>
             </div>
          </div>
        </div>
      </div>

      <div class="mt-8 pt-6 border-t border-gray-100 dark:border-slate-700 text-[10px] text-gray-500 leading-relaxed text-center">
        Onze prijzen zijn gebaseerd op de wettelijke 2026 tarieven minus 10% korting. Het eindbedrag wordt naar beneden afgerond op hele euro's.
      </div>
    </div>
  </div>
</section>

<style>
  .vehicle-btn.active { border-color: #003399; background-color: rgba(0, 51, 153, 0.05); color: #003399; }
</style>

<script>
  const TARIEVEN = { auto: { start: 4.31, km: 3.17, min: 0.52 }, bus: { start: 8.75, km: 3.63, min: 0.60 } };
  let selectedLonLat = null;
  let currentVehicleType = 'auto';

  const pickupInput = document.getElementById('pickup-input');
  const resultsDiv = document.getElementById('autocomplete-results');
  const vehicleBtns = document.querySelectorAll('.vehicle-btn');

  vehicleBtns.forEach(btn => {
    btn.onclick = () => {
      vehicleBtns.forEach(b => { b.classList.remove('active', 'border-[#003399]', 'bg-blue-50'); b.classList.add('text-gray-500'); });
      btn.classList.add('active', 'border-[#003399]', 'bg-blue-50');
      btn.classList.remove('text-gray-500');
      currentVehicleType = btn.dataset.type;
    };
  });

  // API Filter: Alleen Nederland resultaten
  pickupInput.addEventListener('input', async (e) => {
    const val = e.target.value;
    if (val.length < 3) { resultsDiv.classList.add('hidden'); return; }

    try {
      // Filter toegevoegd: countrycode=nl
      const res = await fetch(`https://photon.komoot.io/api/?q=${encodeURIComponent(val)}&limit=5&lang=nl&location_bias_scale=0.5`);
      const data = await res.json();
      
      resultsDiv.innerHTML = '';
      // Filter extra op features uit Nederland
      const nlFeatures = data.features.filter(f => f.properties.countrycode === 'NL' || f.properties.country === 'Netherlands');

      if(nlFeatures.length === 0) { resultsDiv.classList.add('hidden'); return; }

      nlFeatures.forEach(f => {
        const div = document.createElement('div');
        div.className = 'p-3 hover:bg-slate-100 dark:hover:bg-slate-700 cursor-pointer border-b text-sm';
        const name = f.properties.name || '';
        const city = f.properties.city ? `, ${f.properties.city}` : '';
        div.innerText = `${name}${city}`;
        
        div.onclick = () => {
          pickupInput.value = name;
          selectedLonLat = f.geometry.coordinates;
          resultsDiv.classList.add('hidden');
        };
        resultsDiv.appendChild(div);
      });
      resultsDiv.classList.remove('hidden');
    } catch (err) { console.error(err); }
  });

  document.getElementById('calculate-btn').onclick = async () => {
    if (!selectedLonLat) return alert("Selecteer een ophaaladres uit de lijst.");
    
    const loader = document.getElementById('calc-loader');
    const output = document.getElementById('calc-output');
    const placeholder = document.getElementById('calc-placeholder');

    placeholder.classList.add('hidden');
    loader.classList.remove('hidden');
    output.classList.add('hidden');

    const destCoords = document.getElementById('destination-select').value;
    const t = TARIEVEN[currentVehicleType];

    try {
      const res = await fetch(`https://router.project-osrm.org/route/v1/driving/${selectedLonLat[0]},${selectedLonLat[1]};${destCoords}?overview=false`);
      const data = await res.json();
      const route = data.routes[0];

      const km = route.distance / 1000;
      const min = route.duration / 60;

      // Berekening
      const basisPrijs = t.start + (km * t.km) + (min * t.min);
      const metKorting = basisPrijs * 0.90; // 10% korting
      const afgerond = Math.floor(metKorting); // Afronden naar beneden

      document.getElementById('old-price').innerText = `Normaal: €${basisPrijs.toFixed(2)}`;
      document.getElementById('display-price').innerText = `€ ${afgerond}`;
      document.getElementById('route-info').innerText = `${km.toFixed(1)} km | ± ${Math.round(min)} min`;
      
      // WhatsApp link
      const huisnr = document.getElementById('house-number').value;
      const notes = document.getElementById('notes-input').value;
      const destinationText = document.getElementById('destination-select').options[document.getElementById('destination-select').selectedIndex].text;
      
      const msg = encodeURIComponent(
        `Hallo InTaxi, ik wil een rit boeken:\n\n` +
        `📍 Van: ${pickupInput.value} ${huisnr}\n` +
        `🏁 Naar: ${destinationText}\n` +
        `🚗 Auto: ${currentVehicleType === 'auto' ? 'Tesla' : 'Busje'}\n` +
        `📝 Opmerking: ${notes || 'Geen'}\n\n` +
        `💰 Prijs: €${afgerond},- (inclusief 10% korting)`
      );
      document.getElementById('whatsapp-link').href = `https://wa.me/31642277607?text=${msg}`;

      loader.classList.add('hidden');
      output.classList.remove('hidden');
    } catch (err) {
      alert("Fout bij berekening.");
      loader.classList.add('hidden');
    }
  };
</script>
