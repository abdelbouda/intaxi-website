---
/* PriceCalculator.astro - All-in-One Layout (Reis & Contact naast elkaar) */
---

<section id="prijs-calculator" class="bg-slate-50 dark:bg-slate-900 py-8 scroll-mt-20">
  <div class="max-w-5xl mx-auto px-4">
    <!-- Hoofdcontainer met NAD Blauwe rand en 3D schaduw -->
    <div class="bg-white dark:bg-slate-800 rounded-3xl shadow-[0_20px_50px_rgba(0,51,153,0.12)] border-2 border-[#003399] overflow-hidden">
      
      <div class="p-6 md:p-10">
        <div class="grid lg:grid-cols-2 gap-10">
          
          <!-- LINKERKANT: REISGEGEVENS -->
          <div class="space-y-5">
            <div class="flex items-center gap-3 mb-2">
              <span class="bg-[#003399] text-white w-6 h-6 flex items-center justify-center rounded-full text-xs font-bold">1</span>
              <h2 class="text-xl font-black text-[#003399] uppercase tracking-tight">Reisdetails</h2>
            </div>

            <div class="space-y-3">
              <!-- Ophaalpunt -->
              <div class="relative">
                <label class="block text-[10px] font-bold uppercase text-gray-400 mb-1 ml-1">Ophaalpunt *</label>
                <div class="flex items-center bg-gray-50 dark:bg-slate-700 rounded-xl p-3 border border-gray-100 dark:border-slate-600">
                  <span class="mr-2">📍</span>
                  <input type="text" id="pickup-input" placeholder="Straat en stad..." class="w-full bg-transparent outline-none text-sm font-medium" />
                </div>
                <div id="autocomplete-results" class="absolute z-50 w-full bg-white shadow-2xl hidden max-h-40 overflow-y-auto border rounded-b-xl mt-1 text-sm text-gray-800"></div>
              </div>

              <!-- Bestemming & Reistijd -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <div class="bg-gray-50 dark:bg-slate-700 rounded-xl p-3 border border-gray-100 dark:border-slate-600">
                  <label class="block text-[10px] font-bold uppercase text-gray-400 mb-1">Bestemming</label>
                  <select id="destination-select" class="w-full bg-transparent font-bold text-xs outline-none">
                    <option value="4.7683,52.3105">Schiphol Airport (AMS)</option>
                    <option value="4.4844,50.9010">Brussels Airport (BRU)</option>
                    <option value="4.4372,51.9225">Rotterdam Airport (RTM)</option>
                  </select>
                </div>
                <div class="bg-[#003399]/5 dark:bg-blue-900/20 rounded-xl p-3 border border-[#003399]/10 flex flex-col justify-center items-center">
                   <p class="text-[8px] uppercase font-bold text-gray-400">Geschatte Reistijd</p>
                   <p class="text-lg font-black text-[#003399] dark:text-blue-400"><span id="est-time">--</span> <span class="text-xs uppercase">min</span></p>
                </div>
              </div>

              <!-- Datum & Tijd -->
              <div class="grid grid-cols-2 gap-3">
                <div class="bg-gray-50 dark:bg-slate-700 rounded-xl p-3 border border-gray-100 dark:border-slate-600">
                  <label class="block text-[10px] font-bold uppercase text-gray-400 mb-1">Datum</label>
                  <input type="date" id="pickup-date" class="w-full bg-transparent font-bold text-xs outline-none" />
                </div>
                <div class="bg-gray-50 dark:bg-slate-700 rounded-xl p-3 border border-gray-100 dark:border-slate-600">
                  <label class="block text-[10px] font-bold uppercase text-gray-400 mb-1">Tijd</label>
                  <input type="time" id="pickup-time" class="w-full bg-transparent font-bold text-xs outline-none" />
                </div>
              </div>
            </div>

            <!-- Voertuig Keuze -->
            <div class="pt-4 space-y-2">
              <p class="text-[10px] font-bold uppercase text-gray-400 ml-1">Kies uw voertuig</p>
              <div id="v-auto" onclick="setVehicle('auto')" class="vehicle-card border-2 border-transparent bg-gray-50 dark:bg-slate-700 p-3 rounded-2xl cursor-pointer flex justify-between items-center transition-all hover:bg-blue-50">
                <div class="flex items-center gap-3">
                  <span class="text-2xl">🚗</span>
                  <span class="font-bold text-sm">Sedan (Tesla)</span>
                </div>
                <span id="price-auto" class="font-black text-[#003399]">€ --</span>
              </div>
              <div id="v-bus" onclick="setVehicle('bus')" class="vehicle-card border-2 border-transparent bg-gray-50 dark:bg-slate-700 p-3 rounded-2xl cursor-pointer flex justify-between items-center transition-all hover:bg-blue-50">
                <div class="flex items-center gap-3">
                  <span class="text-2xl">🚐</span>
                  <span class="font-bold text-sm">Personenbus</span>
                </div>
                <span id="price-bus" class="font-black text-[#003399]">€ --</span>
              </div>
            </div>
          </div>

          <!-- RECHTERKANT: CONTACTGEGEVENS -->
          <div class="space-y-5 border-t lg:border-t-0 lg:border-l border-gray-100 dark:border-slate-700 lg:pl-10 pt-8 lg:pt-0">
            <div class="flex items-center gap-3 mb-2">
              <span class="bg-[#003399] text-white w-6 h-6 flex items-center justify-center rounded-full text-xs font-bold">2</span>
              <h2 class="text-xl font-black text-[#003399] uppercase tracking-tight">Persoonsgegevens</h2>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <input type="text" id="cust-first-name" placeholder="Voornaam *" class="p-3.5 text-sm bg-gray-50 dark:bg-slate-700 border border-gray-100 dark:border-slate-600 rounded-xl outline-none focus:ring-2 focus:ring-[#003399]" />
              <input type="text" id="cust-last-name" placeholder="Achternaam *" class="p-3.5 text-sm bg-gray-50 dark:bg-slate-700 border border-gray-100 dark:border-slate-600 rounded-xl outline-none focus:ring-2 focus:ring-[#003399]" />
              <input type="email" id="cust-email" placeholder="E-mail *" class="p-3.5 text-sm bg-gray-50 dark:bg-slate-700 border border-gray-100 dark:border-slate-600 rounded-xl outline-none focus:ring-2 focus:ring-[#003399]" />
              <input type="tel" id="cust-phone" placeholder="Telefoon *" class="p-3.5 text-sm bg-gray-50 dark:bg-slate-700 border border-gray-100 dark:border-slate-600 rounded-xl outline-none focus:ring-2 focus:ring-[#003399]" />
            </div>
            
            <textarea id="cust-notes" placeholder="Vluchtnummer of extra wensen..." class="w-full p-4 text-sm bg-gray-50 dark:bg-slate-700 border border-gray-100 dark:border-slate-600 rounded-xl h-24 outline-none focus:ring-2 focus:ring-[#003399]"></textarea>

            <!-- Actieknop -->
            <div class="pt-4">
              <button id="final-reserve-btn" class="w-full bg-[#25D366] hover:bg-[#20ba5a] text-white font-black py-4 rounded-2xl shadow-[0_10px_20px_rgba(37,211,102,0.3)] flex items-center justify-center gap-3 transition-all transform hover:-translate-y-1 active:scale-95 uppercase tracking-wider">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946.003-6.556 5.338-11.891 11.893-11.891 3.181.001 6.167 1.24 8.413 3.488 2.245 2.248 3.481 5.236 3.48 8.417-.003 6.557-5.338 11.892-11.893 11.892-1.997-.001-3.951-.5-5.688-1.448l-6.305 1.652zm6.599-3.835c1.406.836 2.492 1.24 4.39 1.24 5.33 0 9.675-4.346 9.678-9.677.001-2.583-1.003-5.01-2.827-6.834-1.825-1.825-4.253-2.83-6.837-2.831-5.33 0-9.673 4.346-9.676 9.677-.001 1.83.479 3.125 1.385 4.69l-.934 3.413 3.421-.899zm10.155-5.592c-.286-.143-1.688-.833-1.949-.928-.261-.095-.451-.143-.641.143-.19.286-.737.928-.903 1.118-.166.19-.333.214-.618.071-.285-.143-1.206-.444-2.298-1.417-.85-.758-1.423-1.694-1.59-1.979-.166-.286-.018-.44.125-.581.128-.128.286-.333.428-.5.143-.166.19-.286.286-.476.095-.19.048-.357-.024-.5-.071-.143-.641-1.545-.879-2.117-.231-.557-.466-.481-.641-.49-.166-.008-.356-.01-.546-.01s-.5.071-.76.357c-.26.286-.998.976-.998 2.38s1.022 2.761 1.164 2.951c.143.19 2.012 3.073 4.874 4.31.681.294 1.212.47 1.626.601.684.218 1.307.187 1.8.113.549-.082 1.688-.69 1.926-1.356.238-.666.238-1.237.166-1.356-.072-.119-.261-.19-.547-.333z"/></svg>
                Reservering Versturen
              </button>
            </div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  let selectedVehicle = 'auto';
  let tripData = { price: 0, km: 0, time: 0 };

  // Set Default Date/Time
  window.addEventListener('DOMContentLoaded', () => {
    document.getElementById('pickup-date').value = new Date().toISOString().split('T')[0];
    document.getElementById('pickup-time').value = "12:00";
    setVehicle('auto');
  });

  function setVehicle(type) {
    selectedVehicle = type;
    document.getElementById('v-auto').classList.toggle('border-[#003399]', type === 'auto');
    document.getElementById('v-auto').classList.toggle('bg-blue-50', type === 'auto');
    document.getElementById('v-bus').classList.toggle('border-[#003399]', type === 'bus');
    document.getElementById('v-bus').classList.toggle('bg-blue-50', type === 'bus');
  }

  async function updatePrices() {
    const pickup = document.getElementById('pickup-input').value;
    if (pickup.length < 5) return;

    try {
      const res = await fetch(`https://photon.komoot.io/api/?q=${encodeURIComponent(pickup)}&limit=1`);
      const data = await res.json();
      const coords = data.features[0].geometry.coordinates;
      const destCoords = document.getElementById('destination-select').value;
      
      const routeRes = await fetch(`https://router.project-osrm.org/route/v1/driving/${coords[0]},${coords[1]};${destCoords}?overview=false`);
      const routeData = await routeRes.json();
      const r = routeData.routes[0];
      
      const km = r.distance / 1000;
      const min = r.duration / 60;
      document.getElementById('est-time').innerText = Math.round(min);

      const tAuto = { start: 4.31, km: 3.17, min: 0.52 };
      const tBus = { start: 8.75, km: 3.63, min: 0.60 };

      document.getElementById('price-auto').innerText = `€ ${Math.floor((tAuto.start + (km * tAuto.km) + (min * tAuto.min)) * 0.90)},-`;
      document.getElementById('price-bus').innerText = `€ ${Math.floor((tBus.start + (km * tBus.km) + (min * tBus.min)) * 0.90)},-`;
    } catch (e) { console.error("Error updating price"); }
  }

  document.getElementById('final-reserve-btn').onclick = () => {
    const fName = document.getElementById('cust-first-name').value;
    const phone = document.getElementById('cust-phone').value;
    const price = selectedVehicle === 'auto' ? document.getElementById('price-auto').innerText : document.getElementById('price-bus').innerText;
    
    if (!fName || !phone || price === '€ --') {
      alert("Vul a.u.b. alle velden in en kies een geldig ophaaladres."); return;
    }

    const msg = encodeURIComponent(
      `🚕 NIEUWE BOEKING (InTaxi.nl)\n\n` +
      `👤 Klant: ${fName} ${document.getElementById('cust-last-name').value}\n` +
      `📞 Tel: ${phone}\n` +
      `📍 Van: ${document.getElementById('pickup-input').value}\n` +
      `🏁 Naar: ${document.getElementById('destination-select').options[document.getElementById('destination-select').selectedIndex].text}\n` +
      `📅 Datum: ${document.getElementById('pickup-date').value}\n` +
      `🕒 Tijd: ${document.getElementById('pickup-time').value}\n` +
      `🚗 Auto: ${selectedVehicle === 'auto' ? 'Sedan (Tesla)' : 'Personenbus'}\n` +
      `💰 Prijs: ${price}\n` +
      `📝 Info: ${document.getElementById('cust-notes').value || 'Geen'}`
    );
    window.open(`https://wa.me/31642277607?text=${msg}`, '_blank');
  };

  document.getElementById('pickup-input').onchange = updatePrices;
  document.getElementById('destination-select').onchange = updatePrices;

  // Autocomplete
  const pickupInput = document.getElementById('pickup-input');
  const resultsDiv = document.getElementById('autocomplete-results');
  pickupInput.addEventListener('input', async (e) => {
    const val = e.target.value;
    if (val.length < 3) { resultsDiv.classList.add('hidden'); return; }
    const res = await fetch(`https://photon.komoot.io/api/?q=${encodeURIComponent(val)}&limit=5`);
    const data = await res.json();
    resultsDiv.innerHTML = '';
    data.features.forEach(f => {
      const div = document.createElement('div');
      div.className = 'p-3 hover:bg-blue-50 cursor-pointer border-b last:border-0 dark:hover:bg-slate-700';
      div.innerText = `${f.properties.name || ''}, ${f.properties.city || ''}`;
      div.onclick = () => { pickupInput.value = div.innerText; resultsDiv.classList.add('hidden'); updatePrices(); };
      resultsDiv.appendChild(div);
    });
    resultsDiv.classList.remove('hidden');
  });
</script>
