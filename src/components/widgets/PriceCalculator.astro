---
/* PriceCalculator.astro - Volledige Multi-step Workflow met Checkout */
---

<section id="prijs-calculator" class="bg-blue-50 dark:bg-slate-900 py-12 border-t border-b border-gray-200 dark:border-slate-800 scroll-mt-20">
  <div class="max-w-4xl mx-auto px-4">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-xl border border-blue-100 dark:border-slate-700 overflow-hidden">
      
      <div class="flex bg-slate-100 dark:bg-slate-700">
        <div id="step-1-tab" class="step-tab flex-1 py-3 text-center text-xs font-bold uppercase border-b-4 border-blue-600 text-blue-600">1. Route</div>
        <div id="step-2-tab" class="step-tab flex-1 py-3 text-center text-xs font-bold uppercase border-b-4 border-transparent text-gray-400">2. Bagage</div>
        <div id="step-3-tab" class="step-tab flex-1 py-3 text-center text-xs font-bold uppercase border-b-4 border-transparent text-gray-400">3. Voertuig</div>
        <div id="step-4-tab" class="step-tab flex-1 py-3 text-center text-xs font-bold uppercase border-b-4 border-transparent text-gray-400">4. Checkout</div>
      </div>

      <div class="p-8">
        <div id="step-1" class="step-content space-y-6">
          <div class="text-center mb-6">
            <h2 class="text-2xl font-bold text-[#003399] dark:text-blue-400">Waar wil je heen?</h2>
          </div>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="space-y-4">
              <div class="relative">
                <label class="block text-sm font-semibold mb-1">Van (Ophaaladres) *</label>
                <input type="text" id="pickup-input" placeholder="Straatnaam en stad..." class="w-full p-3 rounded-lg border border-gray-300 dark:bg-slate-700 dark:text-white" required />
                <div id="autocomplete-results" class="absolute z-50 w-full bg-white dark:bg-slate-800 shadow-xl hidden max-h-48 overflow-y-auto border border-gray-200"></div>
              </div>
              <div>
                <label class="block text-sm font-semibold mb-1">Huisnummer *</label>
                <input type="text" id="house-number" placeholder="Bijv. 12" class="w-full p-3 rounded-lg border border-gray-300 dark:bg-slate-700 dark:text-white" required />
              </div>
              <div>
                <label class="block text-sm font-semibold mb-1">Naar (Bestemming)</label>
                <select id="destination-select" class="w-full p-3 rounded-lg border border-gray-300 dark:bg-slate-700 dark:text-white">
                  <option value="4.7683,52.3105">Schiphol Airport (AMS)</option>
                  <option value="4.4844,50.9010">Brussels Airport (BRU)</option>
                  <option value="4.4372,51.9225">Rotterdam Airport (RTM)</option>
                </select>
              </div>
            </div>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-semibold mb-1">Ophaalmoment *</label>
                <input type="datetime-local" id="pickup-time" class="w-full p-3 rounded-lg border border-gray-300 dark:bg-slate-700 dark:text-white" required />
              </div>
              <div>
                <label class="block text-sm font-semibold mb-1">Aantal reizigers</label>
                <input type="number" id="passengers" value="1" min="1" max="8" class="w-full p-3 rounded-lg border border-gray-300 dark:bg-slate-700 dark:text-white" />
              </div>
            </div>
          </div>
          <button onclick="nextStep(2)" class="w-full bg-[#003399] text-white font-bold py-4 rounded-lg hover:bg-blue-800 transition">Bereken mijn ritprijs</button>
        </div>

        <div id="step-2" class="step-content hidden space-y-6">
          <div class="text-center mb-6">
            <h2 class="text-2xl font-bold text-[#003399] dark:text-blue-400">Bagage</h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="p-4 border rounded-xl text-center dark:border-slate-600">
              <span class="block text-3xl mb-2">🧳</span>
              <p class="font-bold text-sm">Grote koffer</p>
              <input type="number" id="luggage-large" value="0" min="0" class="w-16 mx-auto mt-2 p-1 border rounded text-center dark:bg-slate-700" />
            </div>
            <div class="p-4 border rounded-xl text-center dark:border-slate-600">
              <span class="block text-3xl mb-2">💼</span>
              <p class="font-bold text-sm">Handbagage</p>
              <input type="number" id="luggage-small" value="0" min="0" class="w-16 mx-auto mt-2 p-1 border rounded text-center dark:bg-slate-700" />
            </div>
            <div class="p-4 border rounded-xl text-center dark:border-slate-600">
              <span class="block text-3xl mb-2">👶</span>
              <p class="font-bold text-sm">Kinderzitje</p>
              <input type="number" id="child-seat" value="0" min="0" class="w-16 mx-auto mt-2 p-1 border rounded text-center dark:bg-slate-700" />
            </div>
          </div>
          <div class="flex gap-4">
            <button onclick="nextStep(1)" class="w-1/3 bg-gray-200 py-4 rounded-lg font-bold">Terug</button>
            <button onclick="calculateAndGoToStep3()" class="w-2/3 bg-[#003399] text-white py-4 rounded-lg font-bold">Bekijk Voertuigen</button>
          </div>
        </div>

        <div id="step-3" class="step-content hidden space-y-4">
          <div class="text-center mb-6">
            <h2 class="text-2xl font-bold text-[#003399] dark:text-blue-400">Selecteer uw voertuig</h2>
          </div>
          <div id="vehicle-options" class="space-y-4">
            </div>
          <button onclick="nextStep(2)" class="w-full bg-gray-200 py-3 rounded-lg font-bold">Terug naar bagage</button>
        </div>

        <div id="step-4" class="step-content hidden space-y-6">
          <div class="text-center">
            <h2 class="text-2xl font-bold text-[#003399] dark:text-blue-400">Contactgegevens</h2>
          </div>
          <div class="bg-blue-50 dark:bg-slate-900/50 p-4 rounded-lg mb-6 border border-blue-100 dark:border-slate-700">
            <p class="text-sm"><strong>Geselecteerde rit:</strong> <span id="summary-text">...</span></p>
            <p class="text-xl font-bold text-blue-600 mt-2">Totaal: <span id="summary-price">€ 0</span></p>
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            <input type="text" id="cust-first-name" placeholder="Voornaam *" class="p-3 border rounded-lg dark:bg-slate-700 dark:text-white" required />
            <input type="text" id="cust-last-name" placeholder="Achternaam *" class="p-3 border rounded-lg dark:bg-slate-700 dark:text-white" required />
            <input type="email" id="cust-email" placeholder="E-mailadres *" class="p-3 border rounded-lg dark:bg-slate-700 dark:text-white" required />
            <input type="tel" id="cust-phone" placeholder="Telefoonnummer *" class="p-3 border rounded-lg dark:bg-slate-700 dark:text-white" required />
          </div>
          <textarea id="cust-notes" placeholder="Vluchtnummer of extra opmerkingen..." class="w-full p-3 border rounded-lg dark:bg-slate-700 dark:text-white h-24"></textarea>
          
          <div class="flex gap-4">
            <button onclick="nextStep(3)" class="w-1/3 bg-gray-200 py-4 rounded-lg font-bold">Terug</button>
            <button id="final-reserve-btn" class="w-2/3 bg-green-600 text-white font-bold py-4 rounded-lg hover:bg-green-700 transition">Reserveer nu via WhatsApp</button>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script is:inline>
  let tripData = {
    pickup: '', house: '', destination: '', destName: '', time: '', passengers: 1,
    luggage: { large: 0, small: 0, seats: 0 },
    vehicle: 'auto', price: 0, km: 0
  };

  const TARIEVEN = {
    auto: { start: 4.31, km: 3.17, min: 0.52, label: 'Tesla Business Class', desc: 'Luxe Tesla uit het E-segment.' },
    bus:  { start: 8.75, km: 3.63, min: 0.60, label: 'Personenbus (5-8p)', desc: 'Ideaal voor groepen en veel bagage.' }
  };

  function nextStep(step) {
    if (step === 2) {
      if (!document.getElementById('pickup-input').value || !document.getElementById('house-number').value || !document.getElementById('pickup-time').value) {
        alert("Vul a.u.b. alle verplichte velden (*) in."); return;
      }
    }
    
    document.querySelectorAll('.step-content').forEach(el => el.classList.add('hidden'));
    document.getElementById('step-' + step).classList.remove('hidden');
    
    document.querySelectorAll('.step-tab').forEach((tab, i) => {
      tab.classList.toggle('border-blue-600', (i + 1) === step);
      tab.classList.toggle('text-blue-600', (i + 1) === step);
      tab.classList.toggle('text-gray-400', (i + 1) !== step);
      tab.classList.toggle('border-transparent', (i + 1) !== step);
    });
    window.scrollTo({ top: document.getElementById('prijs-calculator').offsetTop - 20, behavior: 'smooth' });
  }

  async function calculateAndGoToStep3() {
    const pickup = document.getElementById('pickup-input').value;
    const destSelect = document.getElementById('destination-select');
    const destCoords = destSelect.value;
    
    // Simpele geo-lookup voor demo (in praktijk gebruik je de geselecteerde coords van autocomplete)
    try {
      const res = await fetch(`https://photon.komoot.io/api/?q=${encodeURIComponent(pickup)}&limit=1`);
      const data = await res.json();
      const coords = data.features[0].geometry.coordinates;
      
      const routeRes = await fetch(`https://router.project-osrm.org/route/v1/driving/${coords[0]},${coords[1]};${destCoords}?overview=false`);
      const routeData = await routeRes.json();
      const r = routeData.routes[0];
      
      tripData.km = r.distance / 1000;
      const min = r.duration / 60;

      const container = document.getElementById('vehicle-options');
      container.innerHTML = '';

      ['auto', 'bus'].forEach(type => {
        const t = TARIEVEN[type];
        const basis = t.start + (tripData.km * t.km) + (min * t.min);
        const prijs = Math.floor(basis * 0.90);
        
        const card = document.createElement('div');
        card.className = "p-5 border-2 rounded-xl cursor-pointer hover:border-blue-500 transition flex justify-between items-center dark:border-slate-700 bg-white dark:bg-slate-800";
        card.onclick = () => selectVehicle(type, prijs);
        card.innerHTML = `
          <div>
            <h3 class="font-bold text-lg">${t.label}</h3>
            <p class="text-xs text-gray-500">${t.desc}</p>
            <p class="text-xs font-bold text-green-600 mt-1">✓ Bagage inclusief ✓ 10% korting</p>
          </div>
          <div class="text-right">
            <span class="block text-2xl font-black text-blue-600">€ ${prijs},-</span>
            <button class="bg-blue-600 text-white text-xs px-4 py-2 rounded mt-2 uppercase font-bold">Selecteer</button>
          </div>
        `;
        container.appendChild(card);
      });

      nextStep(3);
    } catch (e) { alert("Kon route niet berekenen. Controleer het adres."); }
  }

  function selectVehicle(type, prijs) {
    tripData.vehicle = type;
    tripData.price = prijs;
    tripData.pickup = document.getElementById('pickup-input').value;
    tripData.house = document.getElementById('house-number').value;
    tripData.time = document.getElementById('pickup-time').value;
    tripData.destName = document.getElementById('destination-select').options[document.getElementById('destination-select').selectedIndex].text;
    
    document.getElementById('summary-text').innerText = `${tripData.pickup} (${tripData.house}) ➔ ${tripData.destName}`;
    document.getElementById('summary-price').innerText = `€ ${prijs},-`;
    nextStep(4);
  }

  document.getElementById('final-reserve-btn').onclick = () => {
    const fName = document.getElementById('cust-first-name').value;
    const lName = document.getElementById('cust-last-name').value;
    const email = document.getElementById('cust-email').value;
    const phone = document.getElementById('cust-phone').value;
    const notes = document.getElementById('cust-notes').value;

    if (!fName || !lName || !email || !phone) {
      alert("Vul a.u.b. uw contactgegevens in."); return;
    }

    const msg = encodeURIComponent(
      `🚕 NIEUWE RESERVERING\n\n` +
      `👤 Klant: ${fName} ${lName}\n` +
      `📞 Tel: ${phone}\n` +
      `📧 E-mail: ${email}\n\n` +
      `📅 Datum: ${tripData.time}\n` +
      `📍 Van: ${tripData.pickup} ${tripData.house}\n` +
      `🏁 Naar: ${tripData.destName}\n` +
      `🚗 Type: ${TARIEVEN[tripData.vehicle].label}\n` +
      `💰 Prijs: €${tripData.price},-\n\n` +
      `📝 Opmerking: ${notes || 'Geen'}`
    );
    window.open(`https://wa.me/31642277607?text=${msg}`, '_blank');
  };

  // Autocomplete functionaliteit
  const pickupInput = document.getElementById('pickup-input');
  const resultsDiv = document.getElementById('autocomplete-results');
  pickupInput.addEventListener('input', async (e) => {
    const val = e.target.value;
    if (val.length < 3) { resultsDiv.classList.add('hidden'); return; }
    const res = await fetch(`https://photon.komoot.io/api/?q=${encodeURIComponent(val)}&limit=5`);
    const data = await res.json();
    resultsDiv.innerHTML = '';
    data.features.forEach(f => {
      const div = document.createElement('div');
      div.className = 'p-3 hover:bg-gray-100 cursor-pointer text-sm dark:text-white dark:hover:bg-slate-700';
      div.innerText = `${f.properties.name || ''} ${f.properties.city || ''}`;
      div.onclick = () => { pickupInput.value = div.innerText; resultsDiv.classList.add('hidden'); };
      resultsDiv.appendChild(div);
    });
    resultsDiv.classList.remove('hidden');
  });
</script>
