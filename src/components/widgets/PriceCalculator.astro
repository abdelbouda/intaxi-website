---
/* PriceCalculator.astro - Compacte 3D Versie met Kleurconsistentie */
---

<section id="prijs-calculator" class="bg-slate-50 dark:bg-slate-900 py-8 scroll-mt-20">
  <div class="max-w-3xl mx-auto px-4">
    <div class="bg-white dark:bg-slate-800 rounded-2xl shadow-[0_20px_50px_rgba(0,51,153,0.1)] border border-gray-100 dark:border-slate-700 overflow-hidden transition-all duration-300 hover:shadow-[0_25px_60px_rgba(0,51,153,0.15)]">
      
      <div class="flex bg-gray-50/50 dark:bg-slate-700/50 border-b border-gray-100 dark:border-slate-700">
        <div id="step-1-tab" class="step-tab flex-1 py-3 text-center text-[10px] font-bold uppercase tracking-wider border-b-2 border-[#003399] text-[#003399]">1. Route</div>
        <div id="step-2-tab" class="step-tab flex-1 py-3 text-center text-[10px] font-bold uppercase tracking-wider border-b-2 border-transparent text-gray-400">2. Bagage</div>
        <div id="step-3-tab" class="step-tab flex-1 py-3 text-center text-[10px] font-bold uppercase tracking-wider border-b-2 border-transparent text-gray-400">3. Voertuig</div>
        <div id="step-4-tab" class="step-tab flex-1 py-3 text-center text-[10px] font-bold uppercase tracking-wider border-b-2 border-transparent text-gray-400">4. Checkout</div>
      </div>

      <div class="p-6 md:p-8">
        <div id="step-1" class="step-content space-y-5">
          <div class="text-center mb-4">
            <h2 class="text-xl font-bold text-[#003399] dark:text-blue-400">Waar wil je heen?</h2>
          </div>
          <div class="grid md:grid-cols-2 gap-4">
            <div class="space-y-3">
              <div class="relative">
                <label class="block text-xs font-bold mb-1 text-gray-600 dark:text-gray-300">Van (Ophaaladres) *</label>
                <input type="text" id="pickup-input" placeholder="Straatnaam en stad..." class="w-full p-2.5 text-sm rounded-lg border border-gray-200 dark:bg-slate-700 dark:border-slate-600 dark:text-white outline-none focus:ring-2 focus:ring-[#003399] transition-all" required />
                <div id="autocomplete-results" class="absolute z-50 w-full bg-white dark:bg-slate-800 shadow-2xl hidden max-h-48 overflow-y-auto border border-gray-100 rounded-b-lg"></div>
              </div>
              <div class="grid grid-cols-3 gap-2">
                <div class="col-span-1">
                  <label class="block text-xs font-bold mb-1 text-gray-600">Huisnr. *</label>
                  <input type="text" id="house-number" placeholder="12" class="w-full p-2.5 text-sm rounded-lg border border-gray-200 dark:bg-slate-700 dark:text-white outline-none focus:ring-2 focus:ring-[#003399]" required />
                </div>
                <div class="col-span-2">
                  <label class="block text-xs font-bold mb-1 text-gray-600">Bestemming</label>
                  <select id="destination-select" class="w-full p-2.5 text-sm rounded-lg border border-gray-200 dark:bg-slate-700 dark:text-white outline-none focus:ring-2 focus:ring-[#003399]">
                    <option value="4.7683,52.3105">Schiphol Airport (AMS)</option>
                    <option value="4.4844,50.9010">Brussels Airport (BRU)</option>
                    <option value="4.4372,51.9225">Rotterdam Airport (RTM)</option>
                  </select>
                </div>
              </div>
            </div>
            <div class="space-y-3">
              <div>
                <label class="block text-xs font-bold mb-1 text-gray-600">Ophaalmoment *</label>
                <input type="datetime-local" id="pickup-time" class="w-full p-2.5 text-sm rounded-lg border border-gray-200 dark:bg-slate-700 dark:text-white outline-none focus:ring-2 focus:ring-[#003399]" required />
              </div>
              <div>
                <label class="block text-xs font-bold mb-1 text-gray-600">Aantal reizigers</label>
                <input type="number" id="passengers" value="1" min="1" max="8" class="w-full p-2.5 text-sm rounded-lg border border-gray-200 dark:bg-slate-700 dark:text-white outline-none focus:ring-2 focus:ring-[#003399]" />
              </div>
            </div>
          </div>
          <button onclick="nextStep(2)" class="w-full bg-[#003399] text-white font-bold py-3.5 rounded-xl hover:bg-blue-800 shadow-[0_4px_15px_rgba(0,51,153,0.3)] transform transition hover:-translate-y-0.5 active:scale-95">
            Volgende Stap
          </button>
        </div>

        <div id="step-2" class="step-content hidden space-y-5">
          <div class="text-center">
            <h2 class="text-xl font-bold text-[#003399] mb-4">Bagage</h2>
          </div>
          <div class="grid grid-cols-3 gap-3">
            <div class="p-3 border rounded-xl text-center dark:border-slate-600 bg-gray-50/50">
              <span class="text-2xl">🧳</span>
              <p class="font-bold text-[10px] mt-1 uppercase text-gray-500">Koffer</p>
              <input type="number" id="luggage-large" value="0" min="0" class="w-12 mx-auto mt-1 p-1 text-sm border rounded text-center dark:bg-slate-700 outline-none focus:ring-2 focus:ring-[#003399]" />
            </div>
            <div class="p-3 border rounded-xl text-center dark:border-slate-600 bg-gray-50/50">
              <span class="text-2xl">💼</span>
              <p class="font-bold text-[10px] mt-1 uppercase text-gray-500">Handtas</p>
              <input type="number" id="luggage-small" value="0" min="0" class="w-12 mx-auto mt-1 p-1 text-sm border rounded text-center dark:bg-slate-700 outline-none focus:ring-2 focus:ring-[#003399]" />
            </div>
            <div class="p-3 border rounded-xl text-center dark:border-slate-600 bg-gray-50/50">
              <span class="text-2xl">👶</span>
              <p class="font-bold text-[10px] mt-1 uppercase text-gray-500">Zitje</p>
              <input type="number" id="child-seat" value="0" min="0" class="w-12 mx-auto mt-1 p-1 text-sm border rounded text-center dark:bg-slate-700 outline-none focus:ring-2 focus:ring-[#003399]" />
            </div>
          </div>
          <div class="flex gap-3">
            <button onclick="nextStep(1)" class="w-1/3 bg-gray-100 py-3 rounded-xl font-bold text-gray-600 hover:bg-gray-200 transition">Terug</button>
            <button onclick="calculateAndGoToStep3()" class="w-2/3 bg-[#003399] text-white py-3 rounded-xl font-bold shadow-lg hover:-translate-y-0.5 transition">Bereken Vaste Prijs</button>
          </div>
        </div>

        <div id="step-3" class="step-content hidden space-y-4">
          <div class="text-center">
            <h2 class="text-xl font-bold text-[#003399] mb-4">Kies uw voertuig</h2>
          </div>
          <div id="vehicle-options" class="space-y-3"></div>
          <button onclick="nextStep(2)" class="w-full text-gray-400 text-xs font-bold uppercase hover:text-[#003399] transition">Wijzig Bagage</button>
        </div>

        <div id="step-4" class="step-content hidden space-y-5">
          <div class="bg-[#003399]/5 p-4 rounded-xl border border-[#003399]/10">
            <p class="text-[10px] font-bold text-[#003399] uppercase">Uw vaste prijsopgave:</p>
            <p id="summary-text" class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-1"></p>
            <p class="text-3xl font-black text-[#003399] mt-1"><span id="summary-price">€ 0</span></p>
          </div>
          <div class="grid md:grid-cols-2 gap-3">
            <input type="text" id="cust-first-name" placeholder="Voornaam *" class="p-2.5 text-sm border rounded-lg dark:bg-slate-700 outline-none focus:ring-2 focus:ring-[#003399]" required />
            <input type="text" id="cust-last-name" placeholder="Achternaam *" class="p-2.5 text-sm border rounded-lg dark:bg-slate-700 outline-none focus:ring-2 focus:ring-[#003399]" required />
            <input type="email" id="cust-email" placeholder="E-mailadres *" class="p-2.5 text-sm border rounded-lg dark:bg-slate-700 outline-none focus:ring-2 focus:ring-[#003399]" required />
            <input type="tel" id="cust-phone" placeholder="Telefoonnummer *" class="p-2.5 text-sm border rounded-lg dark:bg-slate-700 outline-none focus:ring-2 focus:ring-[#003399]" required />
          </div>
          <textarea id="cust-notes" placeholder="Vluchtnummer of extra info..." class="w-full p-2.5 text-sm border rounded-lg dark:bg-slate-700 h-20 outline-none focus:ring-2 focus:ring-[#003399]"></textarea>
          <div class="flex gap-3">
            <button onclick="nextStep(3)" class="w-1/3 bg-gray-100 py-3 rounded-xl font-bold text-gray-600">Terug</button>
            <button id="final-reserve-btn" class="w-2/3 bg-green-600 text-white font-bold py-3 rounded-xl hover:bg-green-700 shadow-xl flex items-center justify-center gap-2 transform hover:-translate-y-0.5 transition">
               Reserveer via WhatsApp
            </button>
          </div>
        </div>

      </div>
    </div>
  </div>
</section>

<script is:inline>
  let tripData = {
    pickup: '', house: '', destination: '', destName: '', time: '', passengers: 1,
    luggage: { large: 0, small: 0, seats: 0 },
    vehicle: 'auto', price: 0, km: 0
  };

  const TARIEVEN = {
    auto: { start: 4.31, km: 3.17, min: 0.52, label: 'Tesla Business Class', desc: '1-4p | Luxe & Elektrisch' },
    bus:  { start: 8.75, km: 3.63, min: 0.60, label: 'Personenbus', desc: '5-8p | Veel bagage' }
  };

  function nextStep(step) {
    if (step === 2) {
      if (!document.getElementById('pickup-input').value || !document.getElementById('house-number').value || !document.getElementById('pickup-time').value) {
        alert("Vul a.u.b. alle verplichte velden (*) in."); return;
      }
    }
    
    document.querySelectorAll('.step-content').forEach(el => el.classList.add('hidden'));
    document.getElementById('step-' + step).classList.remove('hidden');
    
    document.querySelectorAll('.step-tab').forEach((tab, i) => {
      const active = (i + 1) === step;
      tab.classList.toggle('border-[#003399]', active);
      tab.classList.toggle('text-[#003399]', active);
      tab.classList.toggle('text-gray-400', !active);
      tab.classList.toggle('border-transparent', !active);
    });
    window.scrollTo({ top: document.getElementById('prijs-calculator').offsetTop - 20, behavior: 'smooth' });
  }

  async function calculateAndGoToStep3() {
    const pickup = document.getElementById('pickup-input').value;
    const destSelect = document.getElementById('destination-select');
    const destCoords = destSelect.value;
    
    try {
      const res = await fetch(`https://photon.komoot.io/api/?q=${encodeURIComponent(pickup)}&limit=1`);
      const data = await res.json();
      const coords = data.features[0].geometry.coordinates;
      
      const routeRes = await fetch(`https://router.project-osrm.org/route/v1/driving/${coords[0]},${coords[1]};${destCoords}?overview=false`);
      const routeData = await routeRes.json();
      const r = routeData.routes[0];
      
      tripData.km = r.distance / 1000;
      const min = r.duration / 60;

      const container = document.getElementById('vehicle-options');
      container.innerHTML = '';

      ['auto', 'bus'].forEach(type => {
        const t = TARIEVEN[type];
        const basis = t.start + (tripData.km * t.km) + (min * t.min);
        const prijs = Math.floor(basis * 0.90);
        
        const card = document.createElement('div');
        card.className = "p-4 border border-gray-100 rounded-xl cursor-pointer hover:border-[#003399] hover:bg-blue-50/30 transition-all flex justify-between items-center bg-white shadow-sm hover:shadow-md";
        card.onclick = () => selectVehicle(type, prijs);
        card.innerHTML = `
          <div>
            <h3 class="font-bold text-sm text-gray-800">${t.label}</h3>
            <p class="text-[10px] text-gray-500">${t.desc}</p>
          </div>
          <div class="text-right">
            <span class="block text-xl font-black text-[#003399]">€ ${prijs},-</span>
            <span class="text-[9px] font-bold text-green-600 uppercase tracking-tighter">10% Korting Toegepast</span>
          </div>
        `;
        container.appendChild(card);
      });

      nextStep(3);
    } catch (e) { alert("Kon route niet berekenen. Controleer het adres."); }
  }

  function selectVehicle(type, prijs) {
    tripData.vehicle = type;
    tripData.price = prijs;
    tripData.pickup = document.getElementById('pickup-input').value;
    tripData.house = document.getElementById('house-number').value;
    tripData.time = document.getElementById('pickup-time').value;
    tripData.destName = document.getElementById('destination-select').options[document.getElementById('destination-select').selectedIndex].text;
    
    document.getElementById('summary-text').innerText = `${tripData.pickup} (${tripData.house}) ➔ ${tripData.destName}`;
    document.getElementById('summary-price').innerText = `€ ${prijs},-`;
    nextStep(4);
  }

  document.getElementById('final-reserve-btn').onclick = () => {
    const fName = document.getElementById('cust-first-name').value;
    const lName = document.getElementById('cust-last-name').value;
    const email = document.getElementById('cust-email').value;
    const phone = document.getElementById('cust-phone').value;
    const notes = document.getElementById('cust-notes').value;

    if (!fName || !lName || !email || !phone) {
      alert("Vul a.u.b. uw contactgegevens in."); return;
    }

    const msg = encodeURIComponent(
      `🚕 NIEUWE RESERVERING\n\n` +
      `👤 Klant: ${fName} ${lName}\n` +
      `📞 Tel: ${phone}\n` +
      `📅 Datum: ${tripData.time}\n` +
      `📍 Van: ${tripData.pickup} ${tripData.house}\n` +
      `🏁 Naar: ${tripData.destName}\n` +
      `🚗 Type: ${TARIEVEN[tripData.vehicle].label}\n` +
      `💰 Vaste Prijs: €${tripData.price},-\n\n` +
      `📝 Opmerking: ${notes || 'Geen'}`
    );
    window.open(`https://wa.me/31642277607?text=${msg}`, '_blank');
  };

  const pickupInput = document.getElementById('pickup-input');
  const resultsDiv = document.getElementById('autocomplete-results');
  pickupInput.addEventListener('input', async (e) => {
    const val = e.target.value;
    if (val.length < 3) { resultsDiv.classList.add('hidden'); return; }
    const res = await fetch(`https://photon.komoot.io/api/?q=${encodeURIComponent(val)}&limit=5`);
    const data = await res.json();
    resultsDiv.innerHTML = '';
    data.features.forEach(f => {
      const div = document.createElement('div');
      div.className = 'p-2.5 hover:bg-blue-50 cursor-pointer text-xs dark:text-white dark:hover:bg-slate-700';
      div.innerText = `${f.properties.name || ''} ${f.properties.city || ''}`;
      div.onclick = () => { pickupInput.value = div.innerText; resultsDiv.classList.add('hidden'); };
      resultsDiv.appendChild(div);
    });
    resultsDiv.classList.remove('hidden');
  });
</script>
