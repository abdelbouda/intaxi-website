---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import PriceCalculator from '~/components/widgets/PriceCalculator.astro';

const metadata = {
  title: 'InTaxi — Luxe Tesla Taxi naar Schiphol met vaste tarieven',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <Hero>
    <Fragment slot="title"></Fragment>
    <Fragment slot="subtitle"></Fragment>

    <Fragment slot="content">
      <!-- Container met animatie-instellingen -->
      <div class="relative -mt-10 md:-mt-16 max-w-5xl mx-auto z-10">
        
        <div class="calculator-container opacity-0 pointer-events-auto">
          <div class="bg-white/95 dark:bg-slate-900/95 backdrop-blur-md p-2 md:p-4 rounded-3xl shadow-2xl border border-white/20">
            <PriceCalculator />
          </div>
          
          <!-- Subtiele tekst direct onder de witte box -->
          <div class="text-center mt-6">
             <h2 class="text-white text-2xl md:text-3xl font-bold drop-shadow-lg">
              Luxe vervoer in een <span class="text-blue-400 font-extrabold">Tesla</span>
            </h2>
            <p class="text-white/90 mt-2 font-medium bg-black/20 inline-block px-4 py-1 rounded-full backdrop-blur-sm">
              Vaste tarieven • Schiphol Service • Amsterdam
            </p>
          </div>
        </div>

      </div>
    </Fragment>

    <Fragment slot="actions"></Fragment>
  </Hero>

  <Note title="Onze belofte:" description="Duurzaamheid, Punctualiteit en Luxe op basis van vaste, transparante tarieven." />

  <Features
    id="tarieven"
    title="Waarom reizen met InTaxi?"
    items={[
      { title: 'Vaste Ritprijs', description: 'Geen verrassingen achteraf.', icon: 'tabler:currency-euro' },
      { title: 'Tesla Vloot', description: 'Stijlvol en milieuvriendelijk.', icon: 'tabler:bolt' },
      { title: 'WhatsApp Service', description: 'Direct contact en bevestiging.', icon: 'tabler:brand-whatsapp' },
    ]}
  />

  <Steps
    title="Hoe werkt het?"
    items={[
      { title: 'Stap 1', description: "Bereken uw vaste prijs bovenaan.", icon: 'tabler:calculator' },
      { title: 'Stap 2', description: "Bevestig direct via WhatsApp.", icon: 'tabler:brand-whatsapp' },
      { title: 'Stap 3', description: "Geniet van een zorgeloze rit.", icon: 'tabler:check' },
    ]}
  />

  <CallToAction
    title="Vragen?"
    subtitle="Onze centrale is 24/7 bereikbaar via WhatsApp."
    actions={[{ variant: 'primary', text: 'Stuur een bericht', href: 'https://wa.me/31642277607', icon: 'tabler:brand-whatsapp' }]}
  />
</Layout>

<style is:global>
  /* De animatie definitie */
  @keyframes simpleFadeIn {
    from { 
      opacity: 0; 
      transform: translateY(15px); 
    }
    to { 
      opacity: 1; 
      transform: translateY(0); 
    }
  }

  /* Toepassing van de animatie op de container */
  .calculator-container {
    animation: simpleFadeIn 1.2s ease-out forwards;
    animation-delay: 2s; /* De 2 seconden wachttijd */
  }

  /* Zorg dat invoervelden altijd klikbaar zijn, zelfs tijdens/na animatie */
  .calculator-container input, 
  .calculator-container button, 
  .calculator-container select {
    pointer-events: auto !important;
  }
</style>
