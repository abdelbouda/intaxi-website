---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import PriceCalculator from '~/components/widgets/PriceCalculator.astro';

const metadata = {
  title: 'InTaxi — Luxe Tesla Taxi naar Schiphol met vaste tarieven',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <Hero>
    <!-- 1. Tekst bovenaan -->
    <Fragment slot="title">
      Luxe vervoer in een <span class="text-blue-400">Tesla</span>
    </Fragment>

    <Fragment slot="subtitle">
      <div class="mb-4">
        <span class="font-semibold text-white">InTaxi powered by (NAD Service)</span> biedt premium luchthavenvervoer vanuit Amsterdam.
      </div>
      <div class="flex justify-center gap-4">
         <span class="bg-blue-600/20 text-blue-300 px-3 py-1 rounded-full text-xs border border-blue-400/30 uppercase tracking-wider font-semibold">100% Elektrisch</span>
         <span class="bg-blue-600/20 text-blue-300 px-3 py-1 rounded-full text-xs border border-blue-400/30 uppercase tracking-wider font-semibold">Vaste Tarieven</span>
      </div>
    </Fragment>

    <!-- 2. De zwevende PriceCalculator in het midden -->
    <Fragment slot="content">
      <div class="relative mt-10 max-w-4xl mx-auto pointer-events-auto">
        <div class="bg-white/95 dark:bg-slate-900/95 backdrop-blur-md p-2 md:p-4 rounded-3xl shadow-2xl border border-white/20 transform transition-all">
          <PriceCalculator />
        </div>
        
        <p class="text-white/70 text-[11px] mt-4 text-center italic font-medium">
          Bereken direct uw voordelige vaste tarief en boek via WhatsApp.
        </p>
      </div>
    </Fragment>

    <!-- 3. Actieknop onderaan de calculator -->
    <Fragment slot="actions">
      <div class="mt-4 flex justify-center">
        <a 
          href="https://wa.me/31642277607?text=Ik%20wil%20graag%20een%20luxe%20Tesla%20taxi%20boeken" 
          target="_blank"
          class="flex items-center gap-2 bg-[#25D366] hover:bg-[#128C7E] text-white font-bold py-3 px-8 rounded-full shadow-lg transition-all hover:scale-105"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-brand-whatsapp"><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path><path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"></path></svg>
          Direct contact via WhatsApp
        </a>
      </div>
    </Fragment>
  </Hero>

  <!-- 2. Note Widget ******************* -->
  <Note title="Onze belofte:" description="Duurzaamheid, Punctualiteit en Luxe op basis van vaste, transparante tarieven." />

  <!-- 3. Features Widget *************** -->
  <Features
    id="tarieven"
    tagline="Tarieven & Service"
    title="Waarom reizen met InTaxi?"
    items={[
      {
        title: 'Vaste Ritprijs',
        description: 'Geen verrassingen achteraf. Wij bieden een vast tarief vooraf, berekend volgens de officiële tarieven.',
        icon: 'tabler:currency-euro',
      },
      {
        title: 'Premium Tesla Vloot',
        description: 'Stap in een van onze luxe, volledig elektrische Tesla’s. Stil, ruim en comfortabel.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Zakelijke Kwaliteit',
        description: 'Professionele chauffeurs die altijd stipt op tijd zijn voor uw reis.',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Direct Bevestigen',
        description: 'Bereken uw prijs en stuur de details direct door naar onze centrale via WhatsApp.',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  />

  <Steps
    title="Hoe werkt het?"
    items={[
      {
        title: 'Stap 1: <span class="font-medium text-[#003399]">Bereken uw vaste prijs</span>',
        description: "Vul uw route in de calculator bovenaan de pagina in.",
        icon: 'tabler:calculator',
      },
      {
        title: 'Stap 2: <span class="font-medium text-[#003399]">Bevestig via WhatsApp</span>',
        description: "Stuur de ritdetails direct door voor een snelle bevestiging.",
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: 'Stap 3: <span class="font-medium text-[#003399]">Ontspannen reizen</span>',
        description: 'Uw chauffeur staat op de afgesproken tijd klaar.',
        icon: 'tabler:check',
      },
    ]}
  />

  <FAQs
    title="Veelgestelde Vragen"
    items={[
      {
        title: 'Geldt de prijs uit de calculator altijd?',
        description: "Ja, de berekende prijs is een vast tarief. Geen extra kosten bij files of omleidingen.",
      },
      {
        title: 'Hoe reserveer ik na de berekening?',
        description: "Klik op de knop in de calculator om de gegevens via WhatsApp te versturen; wij bevestigen direct.",
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Vragen? WhatsApp ons',
        href: 'https://wa.me/31642277607',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title">Klaar om te vertrekken?</Fragment>
    <Fragment slot="subtitle">Bereken nu uw ritprijs in de calculator en boek binnen 1 minuut.</Fragment>
  </CallToAction>
</Layout>
