---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import PriceCalculator from '~/components/widgets/PriceCalculator.astro';

const metadata = {
  title: 'InTaxi — Luxe Tesla Taxi naar Schiphol met vaste tarieven',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <!-- De PriceCalculator is nu verhuisd naar de 'content' slot van de Hero -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Direct contact via WhatsApp',
        href: 'https://wa.me/31642277607?text=Ik%20wil%20graag%20een%20luxe%20Tesla%20taxi%20boeken%20voor%20een%20vaste%20prijs',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title">
      Luxe vervoer in een <span class="text-blue-400">Tesla</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold text-white">InTaxi powered by (NAD Service)</span> biedt premium luchthavenvervoer vanuit Amsterdam. 
      Reis volledig elektrisch voor een <span class="font-bold text-blue-400">vaste prijs</span>.
    </Fragment>

    <!-- Hier plaatsen we de calculator midden in de Hero over de video heen -->
    <Fragment slot="content">
      <div class="mt-8 max-w-4xl mx-auto text-left pointer-events-auto">
        <PriceCalculator />
      </div>
    </Fragment>
  </Hero>

  <!-- 2. Note Widget ******************* -->
  <Note title="Onze belofte:" description="Duurzaamheid, Punctualiteit en Luxe op basis van vaste, transparante tarieven." />

  <!-- 3. Features Widget *************** -->
  <Features
    id="tarieven"
    tagline="Tarieven & Service"
    title="Waarom reizen met InTaxi?"
    items={[
      {
        title: 'Vaste Ritprijs',
        description: 'Geen verrassingen achteraf. Wij bieden een vast tarief vooraf, berekend volgens de officiële tarieven.',
        icon: 'tabler:currency-euro',
      },
      {
        title: 'Premium Tesla Vloot',
        description: 'Stap in een van onze luxe, volledig elektrische Tesla’s. Stil, ruim en comfortabel.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Zakelijke Kwaliteit',
        description: 'Professionele chauffeurs die altijd stipt op tijd zijn voor uw reis.',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Direct Bevestigen',
        description: 'Bereken uw prijs en stuur de details direct door naar onze centrale via WhatsApp.',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  />

  <Steps
    title="Hoe werkt het?"
    items={[
      {
        title: 'Stap 1: <span class="font-medium text-[#003399]">Bereken uw vaste prijs</span>',
        description: "Vul uw route in de calculator bovenaan de pagina in.",
        icon: 'tabler:calculator',
      },
      {
        title: 'Stap 2: <span class="font-medium text-[#003399]">Bevestig via WhatsApp</span>',
        description: "Stuur de ritdetails direct door voor een snelle bevestiging.",
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: 'Stap 3: <span class="font-medium text-[#003399]">Ontspannen reizen</span>',
        description: 'Uw chauffeur staat op de afgesproken tijd klaar.',
        icon: 'tabler:check',
      },
    ]}
  />

  <FAQs
    title="Veelgestelde Vragen"
    items={[
      {
        title: 'Geldt de prijs uit de calculator altijd?',
        description: "Ja, de berekende prijs is een vast tarief. Geen extra kosten bij files of omleidingen.",
      },
      {
        title: 'Hoe reserveer ik na de berekening?',
        description: "Klik op de knop in de calculator om de gegevens via WhatsApp te versturen; wij bevestigen direct.",
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Vragen? WhatsApp ons',
        href: 'https://wa.me/31642277607',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title">Klaar om te vertrekken?</Fragment>
    <Fragment slot="subtitle">Bereken nu uw ritprijs in de calculator en boek binnen 1 minuut.</Fragment>
  </CallToAction>
</Layout>
