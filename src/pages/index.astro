---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import PriceCalculator from '~/components/widgets/PriceCalculator.astro';

// Importeer je eigen Tesla afbeelding
import teslaImg from '~/assets/images/tesla_nad_services.webp';

const metadata = {
  title: 'InTaxi — Luxe Tesla Taxi naar Schiphol met eerlijke tarieven',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Boek via WhatsApp',
        href: 'https://wa.me/31642277607?text=Ik%20wil%20graag%20een%20luxe%20Tesla%20taxi%20boeken',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      { text: 'Bereken uw eerlijke ritprijs', href: '#prijs-calculator' },
    ]}
  >
    <Fragment slot="title">
      Uw luxe rit naar Schiphol in een <span class="text-[#003399] dark:text-blue-400">Tesla</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold text-gray-900 dark:text-white">InTaxi powered by (NAD Service)</span> biedt premium luchthavenvervoer vanuit Amsterdam. 
      Reis volledig elektrisch en in stijl voor een eerlijke prijs, berekend volgens de officiële <span class="font-bold text-[#003399]">taxitarieven van 2026</span>.
    </Fragment>

    <Fragment slot="image">
      <div class="relative m-auto max-w-2xl">
        <img 
          src={teslaImg.src} 
          alt="InTaxi Tesla NAD Service" 
          class="mx-auto rounded-md w-full shadow-lg bg-gray-400 dark:bg-slate-700"
          loading="eager"
          width={672} 
          height={364}
        />
      </div>
    </Fragment>
  </Hero>

  <!-- Tariefcalculator Sectie *********** -->
  
  <PriceCalculator />

  <!-- Note Widget ******************* -->

  <Note title="Onze belofte:" description="Duurzaamheid, Punctualiteit en Luxe op basis van eerlijke, wettelijke tarieven." />

  <!-- Features Widget *************** -->

  <Features
    id="tarieven"
    tagline="Tarieven & Service"
    title="Waarom reizen met InTaxi?"
    subtitle="Wij combineren de duurzaamheid van Tesla met de betrouwbaarheid van NAD Service voor de perfecte reiservaring."
    items={[
      {
        title: 'Eerlijke Meterprijs',
        description: 'Geen schattingen achteraf. Wij hanteren de officiële tarieven van de Rijksoverheid, zodat u nooit te veel betaalt.',
        icon: 'tabler:currency-euro',
      },
      {
        title: 'Premium Tesla Vloot',
        description: 'Stap in een van onze luxe, volledig elektrische Tesla’s. Stil, ruim en voorzien van alle moderne gemakken.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Zakelijke Kwaliteit',
        description: 'Onze chauffeurs zijn professioneel, discreet en altijd stipt op tijd voor uw zakelijke of vakantiereis.',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Eenvoudig Boeken',
        description: 'Geen ingewikkelde apps. Gebruik onze calculator voor een indicatie en bevestig direct via WhatsApp.',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  />

  <!-- De rest van de widgets blijven functioneel hetzelfde maar gebruiken de teslaImg import -->

  <Content
    isReversed
    tagline="De Ervaring"
    title="Reis in de toekomst van vervoer"
    items={[
      {
        title: 'Milieuvriendelijk',
        description: 'Door volledig elektrisch te rijden dragen we samen bij aan een schoner Amsterdam zonder in te leveren op comfort.',
      },
      {
        title: 'Comfort op Maat',
        description: 'Geniet van de panoramische daken en de rustige rit die alleen een Tesla kan bieden.',
      },
    ]}
    image={{
      src: teslaImg,
      alt: 'Luxe Tesla interieur en exterieur',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Luxe als standaard</h3>
      Wij geloven dat de rit naar de luchthaven net zo ontspannen moet zijn als de vlucht zelf.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-slate-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <Steps
    title="Hoe werkt het?"
    items={[
      {
        title: 'Stap 1: <span class="font-medium text-[#003399]">Bereken uw prijs</span>',
        description: "Gebruik de calculator hierboven om een eerlijke prijsindicatie te krijgen voor uw specifieke route.",
        icon: 'tabler:calculator',
      },
      {
        title: 'Stap 2: <span class="font-medium text-[#003399]">Bevestig via WhatsApp</span>',
        description: "Stuur ons uw locatie en tijd. Wij reageren direct om uw luxe Tesla te bevestigen.",
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: 'Stap 3: <span class="font-medium text-[#003399]">Ontspannen aankomen</span>',
        description: 'Onze chauffeur helpt met uw bagage en brengt u in alle rust naar de vertrekhal.',
        icon: 'tabler:plane-departure',
      },
      {
        title: 'Goede reis!',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: teslaImg,
      alt: 'Uw rit met InTaxi',
    }}
  />

  <FAQs
    title="Veelgestelde Vragen"
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Hoe wordt de prijs bepaald?',
        description: "Wij maken gebruik van de officiële taximeter die de prijs berekent op basis van starttarief, afstand en tijd, conform de wetgeving van 2026.",
      },
      {
        title: 'Hoe kan ik betalen?',
        description: "U kunt bij de chauffeur betalen via pin, creditcard of contant. Voor zakelijke klanten is rijden op factuur mogelijk.",
      },
      {
        title: 'Rijden jullie 24/7?',
        description: "Zeker. Of u nu een vroege vlucht heeft om 05:00 uur of midden in de nacht landt, wij staan voor u klaar.",
      },
      {
        title: 'Wat als mijn vlucht vertraging heeft?',
        description: "Geen zorgen. Wij houden uw vluchtnummer in de gaten en passen de ophaaltijd automatisch aan bij aankomst op Schiphol.",
      },
    ]}
  />

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Reserveer nu via WhatsApp',
        href: 'https://wa.me/31642277607',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title">
      Klaar om te vertrekken?
    </Fragment>

    <Fragment slot="subtitle">
      Reserveer vandaag nog uw Tesla bij <strong class="text-[#003399]">InTaxi</strong> en reis zorgeloos voor een eerlijke prijs.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-[#003399]/5 dark:bg-transparent"></div>
    </Fragment>
  </CallToAction>
</Layout>
