---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import PriceCalculator from '~/components/widgets/PriceCalculator.astro';

const metadata = {
  title: 'InTaxi — Luxe Tesla Taxi naar Schiphol met vaste tarieven',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>

  <Hero>
    <!-- 1. Calculator bovenaan (Content slot eerst) -->
    <Fragment slot="content">
      <div class="relative -mt-8 md:-mt-16 mb-10 max-w-4xl mx-auto pointer-events-auto">
        <div class="bg-white/95 dark:bg-slate-900/95 backdrop-blur-md p-2 md:p-4 rounded-3xl shadow-2xl border border-white/20">
          <PriceCalculator />
        </div>
      </div>
    </Fragment>

    <!-- 2. Tekst onder de calculator -->
    <Fragment slot="title">
      <span class="text-3xl md:text-5xl">Luxe vervoer in een <span class="text-blue-400 font-bold">Tesla</span></span>
    </Fragment>

    <Fragment slot="subtitle">
      <div class="mt-4">
        <span class="font-semibold text-white/90">InTaxi powered by (NAD Service)</span> biedt premium luchthavenvervoer vanuit Amsterdam.
      </div>
      <div class="flex justify-center gap-3 mt-6">
         <span class="bg-blue-600/30 text-blue-200 px-4 py-1.5 rounded-full text-xs border border-blue-400/30 uppercase tracking-widest font-bold">100% Elektrisch</span>
         <span class="bg-blue-600/30 text-blue-200 px-4 py-1.5 rounded-full text-xs border border-blue-400/30 uppercase tracking-widest font-bold">Vaste Tarieven</span>
      </div>
    </Fragment>

    <!-- 3. De knop helemaal onderaan de hero -->
    <Fragment slot="actions">
      <div class="mt-10 flex justify-center">
        <a 
          href="https://wa.me/31642277607?text=Ik%20wil%20graag%20een%20luxe%20Tesla%20taxi%20boeken" 
          target="_blank"
          class="flex items-center gap-3 bg-[#25D366] hover:bg-[#128C7E] text-white font-black py-4 px-10 rounded-full shadow-xl transition-all hover:scale-105 uppercase text-sm tracking-widest"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path><path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"></path></svg>
          Direct Boeken via WhatsApp
        </a>
      </div>
    </Fragment>
  </Hero>

  <!-- Note, Features, Steps etc. blijven hetzelfde -->
  <Note title="Onze belofte:" description="Duurzaamheid, Punctualiteit en Luxe op basis van vaste, transparante tarieven." />

  <Features
    id="tarieven"
    tagline="Tarieven & Service"
    title="Waarom reizen met InTaxi?"
    items={[
      { title: 'Vaste Ritprijs', description: 'Geen verrassingen achteraf. Wij bieden een vast tarief vooraf.', icon: 'tabler:currency-euro' },
      { title: 'Premium Tesla Vloot', description: 'Stap in een van onze luxe, volledig elektrische Tesla’s.', icon: 'tabler:bolt' },
      { title: 'Zakelijke Kwaliteit', description: 'Professionele chauffeurs die altijd stipt op tijd zijn.', icon: 'tabler:briefcase' },
      { title: 'Direct Bevestigen', description: 'Boek direct via WhatsApp na uw prijsberekening.', icon: 'tabler:brand-whatsapp' },
    ]}
  />

  <Steps
    title="Hoe werkt het?"
    items={[
      { title: 'Stap 1: Bereken prijs', description: "Vul uw route in de calculator bovenaan in.", icon: 'tabler:calculator' },
      { title: 'Stap 2: WhatsApp', description: "Stuur de details door voor een snelle bevestiging.", icon: 'tabler:brand-whatsapp' },
      { title: 'Stap 3: Reis', description: 'Uw chauffeur staat op de afgesproken tijd klaar.', icon: 'tabler:check' },
    ]}
  />

  <FAQs
    title="Veelgestelde Vragen"
    items={[
      { title: 'Geldt de prijs uit de calculator altijd?', description: "Ja, de berekende prijs is een vast tarief." },
      { title: 'Hoe reserveer ik?', description: "Na de berekening klikt u op de WhatsApp-knop om te boeken." },
    ]}
  />

  <CallToAction
    title="Klaar om te vertrekken?"
    subtitle="Bereken uw prijs bovenaan de pagina en boek binnen 1 minuut."
    actions={[{ variant: 'primary', text: 'Vragen? WhatsApp ons', href: 'https://wa.me/31642277607', icon: 'tabler:brand-whatsapp' }]}
  />
</Layout>
