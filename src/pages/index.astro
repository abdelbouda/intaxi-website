---
import Layout from '~/layouts/PageLayout.astro';

import Hero from '~/components/widgets/Hero.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import Steps from '~/components/widgets/Steps.astro';
import Content from '~/components/widgets/Content.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'InTaxi — Luxe Tesla Taxi naar Schiphol vanaf €75',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Boek via WhatsApp',
        href: 'https://wa.me/31642277607?text=Ik%20wil%20graag%20een%20luxe%20Tesla%20taxi%20boeken',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      { text: 'Bekijk tarieven', href: '#tarieven' },
    ]}
    image={{ 
      src: 'https://images.unsplash.com/photo-1617788130012-02ba73c2f6fd?auto=format&fit=crop&w=2070&q=80', 
      alt: 'Luxe Tesla X met professionele chauffeur' 
    }}
  >
    <Fragment slot="title">
      Uw luxe rit naar Schiphol in een <span class="text-[#003399] dark:text-blue-400">Tesla</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="font-semibold text-gray-900 dark:text-white">InTaxi (NAD Service)</span> biedt premium luchthavenvervoer vanuit Amsterdam. 
      Reis volledig elektrisch, in stijl en altijd voor een vast tarief van <span class="font-bold text-[#003399]">€75,-</span>.
    </Fragment>
  </Hero>

  <!-- Note Widget ******************* -->

  <Note title="Onze belofte:" description="Duurzaamheid, Punctualiteit en Luxe zonder verrassingen." />

  <!-- Features Widget *************** -->

  <Features
    id="tarieven"
    tagline="Tarieven & Service"
    title="Waarom reizen met InTaxi?"
    subtitle="Wij combineren de duurzaamheid van Tesla met de betrouwbaarheid van NAD Service voor de perfecte reiservaring."
    items={[
      {
        title: 'Vast Tarief €75,-',
        description:
          'Geen meter-stress of onverwachte kosten. U weet vooraf precies wat de rit van Amsterdam naar Schiphol kost.',
        icon: 'tabler:currency-euro',
      },
      {
        title: 'Premium Tesla Vloot',
        description:
          'Stap in een van onze luxe, volledig elektrische Tesla’s. Stil, ruim en voorzien van alle moderne gemakken.',
        icon: 'tabler:bolt',
      },
      {
        title: 'Zakelijke Kwaliteit',
        description:
          'Onze chauffeurs zijn professioneel, discreet en altijd stipt op tijd voor uw zakelijke of vakantiereis.',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Eenvoudig Boeken',
        description:
          'Geen ingewikkelde apps of formulieren. Stuur ons simpelweg een WhatsApp-bericht en uw rit is bevestigd.',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    tagline="De Ervaring"
    title="Reis in de toekomst van vervoer"
    items={[
      {
        title: 'Milieuvriendelijk',
        description:
          'Door volledig elektrisch te rijden dragen we samen bij aan een schoner Amsterdam zonder in te leveren op comfort.',
      },
      {
        title: 'Comfort op Maat',
        description:
          'Geniet van de panoramische daken en de rustige rit die alleen een Tesla kan bieden.',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1560958089-b8a1929cea89?auto=format&fit=crop&w=2070&q=80',
      alt: 'Tesla Model S Interior',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Luxe als standaard</h3>
      Wij geloven dat de reis naar de luchthaven net zo ontspannen moet zijn als de vlucht zelf.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-slate-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Steps Widget ****************** -->

  <Steps
    title="Hoe werkt het?"
    items={[
      {
        title: 'Stap 1: <span class="font-medium text-[#003399]">Stuur een bericht</span>',
        description:
          "WhatsApp ons uw ophaallocatie, tijd en vluchtnummer. Wij reageren direct om uw rit te bevestigen.",
        icon: 'tabler:message-circle',
      },
      {
        title: 'Stap 2: <span class="font-medium text-[#003399]">Tesla arriveert</span>',
        description:
          "Onze chauffeur staat op het afgesproken tijdstip voor de deur en helpt u uiteraard met uw bagage.",
        icon: 'tabler:car',
      },
      {
        title: 'Stap 3: <span class="font-medium text-[#003399]">Ontspannen aankomen</span>',
        description:
          'Geniet van de rit. U wordt direct voor de vertrekhal op Schiphol afgezet.',
        icon: 'tabler:plane-departure',
      },
      {
        title: 'Geniet van uw vlucht!',
        icon: 'tabler:check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1541447271487-09612b3f49f7?auto=format&fit=crop&w=987&q=80',
      alt: 'Schiphol Airport Departure',
    }}
  />

  <!-- FAQs Widget ******************* -->

  <FAQs
    title="Veelgestelde Vragen"
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: 'Hoe kan ik betalen?',
        description:
          "U kunt bij de chauffeur betalen via pin, creditcard of contant. Voor zakelijke klanten is rijden op factuur mogelijk.",
      },
      {
        title: 'Is het tarief van €75,- inclusief koffers?',
        description:
          'Ja, de prijs is inclusief bagage. Onze Tesla\'s hebben voldoende ruimte voor koffers voor maximaal 4 personen.',
      },
      {
        title: 'Rijden jullie 24/7?',
        description:
          "Zeker. Of u nu een vroege vlucht heeft om 05:00 uur of midden in de nacht landt, wij staan voor u klaar.",
      },
      {
        title: 'Wat als mijn vlucht vertraging heeft?',
        description:
          "Geen zorgen. Wij houden uw vluchtnummer in de gaten en passen de ophaaltijd automatisch aan bij aankomst op Schiphol.",
      },
    ]}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Reserveer nu via WhatsApp',
        href: 'https://wa.me/31642277607',
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title">
      Klaar om te vertrekken?
    </Fragment>

    <Fragment slot="subtitle">
      Reserveer vandaag nog uw Tesla bij <strong class="text-[#003399]">InTaxi</strong> en reis zorgeloos naar Schiphol.
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-[#003399]/5 dark:bg-transparent"></div>
    </Fragment>
  </CallToAction>
</Layout>
