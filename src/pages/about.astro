---
import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Over Ons — InTaxi Amsterdam',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Over InTaxi"
    image={{
      src: 'https://images.unsplash.com/photo-1559136555-9303baea8ebd?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=2070&q=80',
      alt: 'InTaxi Amsterdam Tesla Service',
    }}
  >
    <Fragment slot="title">
      Uw partner in premium vervoer met <br />
      <span class="text-accent dark:text-white">vaste tarieven in Amsterdam</span>
    </Fragment>

    <Fragment slot="subtitle">
      Bij <strong>InTaxi Amsterdam</strong> is een rit meer dan alleen van A naar B. Met meerdere jaren ervaring bieden wij 
      hoogwaardig personenvervoer. Of u nu kiest voor onze duurzame Tesla taxi of een ruim busje, 
      wij staan garant voor comfort en punctualiteit voor elke rit naar <strong>Schiphol</strong> of binnen de regio.
    </Fragment>
  </Hero>

  <!-- Stats Widget ****************** -->

  <Stats
    title="Onze impact in cijfers"
    stats={[
      { title: 'Jaren Ervaring', amount: '8+' },
      { title: 'Tevreden Klanten', amount: '15K+' },
      { title: 'Elektrische KM', amount: '500K+' },
      { title: 'Chauffeurs', amount: '12' },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    title="Onze Specialisaties"
    subtitle="Wij bieden een breed scala aan vervoersoplossingen, van particuliere ritten tot gespecialiseerde zorgtrajecten."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Zakelijk Vervoer',
        description:
          'Representatief vervoer voor professionals waarbij discretie, comfort en tijdwinst naar de luchthaven essentieel zijn.',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Schiphol Service',
        description:
          'Specialist in vervoer naar het vliegveld. Wij monitoren uw vlucht en hanteren vaste tarieven naar de luchthaven.',
        icon: 'tabler:plane-arrival',
      },
      {
        title: 'Particulier Vervoer',
        description:
          'Luxe en betrouwbare ritten door heel Amsterdam en omstreken voor een eerlijke, vooraf afgesproken prijs.',
        icon: 'tabler:car',
      },
    ]}
  />

  <!-- Features3 Widget ************** -->

  <Features3
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'Zorgvervoer',
        description:
          'Wij bieden extra zorg en aandacht voor patiëntenvervoer van en naar medische instellingen.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'Leerlingenvervoer',
        description:
          'Veilig en vertrouwd vervoer voor scholieren, uitgevoerd door ervaren chauffeurs die rust uitstralen.',
        icon: 'tabler:school',
      },
      {
        title: 'Speciaal Vervoer',
        description:
          'Maatwerkoplossingen voor unieke vervoersvragen, evenementen of groepsvervoer in luxe busjes.',
        icon: 'tabler:star',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1740&q=80',
      alt: 'InTaxi Service beeld',
    }}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Onze Kernwaarden"
    subtitle="Waarom klanten al jarenlang kiezen voor de taxi services van InTaxi Amsterdam."
    items={[
      {
        title: 'Klantgerichte aanpak',
        description:
          'Uw wensen staan centraal. Van een flesje water in de Tesla tot hulp bij uw bagage op het vliegveld.',
      },
      {
        title: 'Vaste Tarieven',
        description:
          'Geen verrassingen of meterkosten. U weet vooraf exact wat de rit naar de luchthaven of Amsterdam kost.',
      },
      {
        title: 'Duurzaamheid',
        description:
          'Wij investeren in de toekomst met een 100% elektrische vloot voor een schoner Amsterdam.',
      },
    ]}
  />

  <!-- Steps2 Widget ****************** -->

  <Steps2
    title="Prestaties"
    subtitle="Onze jarenlange inzet voor kwaliteit heeft geleid tot een sterke reputatie in de regio Amsterdam."
    isReversed={true}
    callToAction={{
      text: 'Bereken uw ritprijs',
      href: '/',
    }}
    items={[
      {
        title: 'Regionale dekking',
        description: 'Wij bedienen de gehele metropoolregio Amsterdam en alle grote vliegvelden in Nederland en België.',
        icon: 'tabler:map-pin',
      },
      {
        title: 'Hoge klantwaardering',
        description:
          'Trots op onze positieve reviews van zowel zakelijke partners als particuliere reizigers.',
        icon: 'tabler:message-star',
      },
      {
        title: 'Gecertificeerd Vervoer',
        description:
          'Volledig gecertificeerd voor zorgvervoer en leerlingenvervoer met de juiste keurmerken.',
        icon: 'tabler:certificate',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Onze Werkgebieden"
    tagline="Locaties"
    columns={3}
    items={[
      {
        title: 'Amsterdam',
        description: 'Centrum, West, Zuid, Oost en Noord.',
      },
      {
        title: 'Schiphol',
        description: 'Vaste ophaalpunten bij de luchthaven.',
      },
      {
        title: 'Amstelveen & Omstreken',
        description: 'Snelle aanrijtijden in de gehele regio.',
      },
    ]}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Direct Contact"
    tagline="Bereikbaarheid"
    columns={2}
    items={[
      {
        title: 'WhatsApp ons',
        description:
          'De snelste manier om een rit te boeken of een prijsopgave op te vragen.',
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: 'Bel onze centrale',
        description:
          'Voor directe spoedritten of vragen over uw zakelijke boeking.',
        icon: 'tabler:phone',
      },
    ]}
  />
</Layout>
