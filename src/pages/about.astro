import Features2 from '~/components/widgets/Features2.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Hero from '~/components/widgets/Hero.astro';
import Stats from '~/components/widgets/Stats.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Over Ons | Uw Mobiliteitspartner in Amsterdam — InTaxi',
  description: 'InTaxi Amsterdam: Uw specialist in zakelijk vervoer, veilig leerlingenvervoer en luxe airport taxi services naar Schiphol. Ontdek onze 100% elektrische vloot.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget: Kleur aangepast naar wit voor betere leesbaarheid -->
  <Hero
    tagline="Uw Mobiliteitspartner"
    image={{
      src: 'https://images.unsplash.com/photo-1441333343567-9919e68e0044?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80',
      alt: 'Luxe taxi service op het vliegveld',
    }}
  >
    <Fragment slot="title">
      Professioneel taxi vervoer voor <br />
      <span class="text-white dark:text-white">zakelijk en particulier</span>
    </Fragment>

    <Fragment slot="subtitle">
      Bij <strong>InTaxi Amsterdam</strong> gaan we verder dan alleen vervoer. Als uw integrale <strong>mobiliteitspartner</strong> bieden wij maatwerkoplossingen voor de zakelijke markt, specialistische <strong>airport ritten</strong> en betrouwbaar <strong>leerlingenvervoer</strong>. Met onze 100% elektrische vloot combineren wij duurzaamheid met de hoogste standaard in comfort en punctualiteit.
    </Fragment>
  </Hero>

  <!-- Stats Widget -->
  <Stats
    title="Betrouwbaarheid in cijfers"
    stats={[
      { title: 'Jaren Ervaring', amount: '8+' },
      { title: 'Tevreden Klanten', amount: '15K+' },
      { title: 'Elektrische KM', amount: '500K+' },
      { title: 'Chauffeurs', amount: '12' },
    ]}
  />

  <!-- Features3 Widget: Focus op Kernsegmenten -->
  <Features3
    title="Onze Specialisaties"
    subtitle="Van strategisch zakelijk partnerschap tot zorgvuldig leerlingenvervoer; wij ontzorgen u op elk traject."
    columns={3}
    isBeforeContent={true}
    items={[
      {
        title: 'Zakelijk Vervoer & Partners',
        description:
          'Wij fungeren als de verlengde arm van uw organisatie. Representatieve chauffeurs, facturatie op rekening en prioritair boeken voor uw directie en gasten.',
        icon: 'tabler:briefcase',
      },
      {
        title: 'Airport Specialist',
        description:
          'Uw reis begint bij de voordeur. Wij zijn gespecialiseerd in vliegveld ritten naar Schiphol, Brussel en Düsseldorf met vaste, scherpe tarieven.',
        icon: 'tabler:plane-departure',
      },
      {
        title: 'Leerlingenvervoer',
        description:
          'Veiligheid en continuïteit voor de meest kwetsbare reizigers. Onze chauffeurs zijn gecertificeerd en getraind in sociaal-emotionele begeleiding.',
        icon: 'tabler:school',
      },
    ]}
  />

  <!-- Rest van de widgets blijft ongewijzigd -->
  <Features3
    columns={3}
    isAfterContent={true}
    items={[
      {
        title: 'Zorgvervoer',
        description:
          'Comfortabel en empathisch vervoer van en naar ziekenhuizen en zorginstellingen, waarbij we de tijd nemen voor de cliënt.',
        icon: 'tabler:heart-handshake',
      },
      {
        title: 'Particuliere Luxe',
        description:
          'Ervaar de premium service van een privéchauffeur voor de prijs van een reguliere taxi binnen de regio Amsterdam.',
        icon: 'tabler:car',
      },
      {
        title: 'Event & Groepsvervoer',
        description:
          'Logistieke planning voor congressen of groepsreizen in onze luxe taxibusjes (tot 8 personen).',
        icon: 'tabler:users',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1544620347-c4fd4a3d5957?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Professionele taxi chauffeur klaar voor vertrek',
    }}
  />

  <Steps2
    title="Waarom InTaxi de voorkeur heeft"
    subtitle="Onze belofte aan elke zakelijke en particuliere klant."
    items={[
      {
        title: 'Mobiliteitspartner van A tot Z',
        description:
          'Wij denken mee met uw logistiek. Of het nu gaat om een enkele rit naar Schiphol of de dagelijkse planning van leerlingenvervoer.',
      },
      {
        title: 'Transparante Vaste Tarieven',
        description:
          'Geen verrassingen achteraf. Wij hanteren vooraf gecommuniceerde tarieven, ook voor onze luxe Tesla vloot.',
      },
      {
        title: 'Duurzame Ambitie',
        description:
          'Met een volledig elektrische vloot dragen wij direct bij aan de leefbaarheid en luchtkwaliteit in Amsterdam.',
      },
    ]}
  />

  <Features2
    title="Operationeel in de Metropoolregio"
    tagline="Dekking"
    columns={3}
    items={[
      {
        title: 'Amsterdam & Amstelveen',
        description: 'Snelle responstijden in alle stadsdelen, inclusief Zuidas en Centrum.',
      },
      {
        title: 'Luchthaven Schiphol',
        description: '24/7 aanwezigheid met Meet & Greet service bij de aankomsthal.',
      },
      {
        title: 'Internationaal',
        description: 'Lange-afstandsritten naar o.a. Antwerpen, Brussel, Parijs en Berlijn.',
      },
    ]}
  />

  <Features2
    title="Word zakelijk partner"
    tagline="Contact"
    columns={2}
    items={[
      {
        title: 'WhatsApp Business',
        description:
          'Stuur direct een bericht voor boekingen of offertes. Snel, efficiënt en altijd bereikbaar.',
        icon: 'tabler:brand-whatsapp',
      },
      {
        title: 'Zakelijke Desk',
        description:
          'Bel ons voor het openen van een zakelijk account of spoedritten binnen Amsterdam.',
        icon: 'tabler:phone',
      },
    ]}
  />
</Layout>
