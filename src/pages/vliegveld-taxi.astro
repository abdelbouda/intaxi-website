---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';

const metadata = {
  title: 'Vliegveld Taxi Amsterdam | Boek Direct Vaste Tarieven',
  description: 'Boek uw luxe Tesla taxi van Amsterdam naar alle luchthavens voor een vaste prijs. Directe bevestiging via WhatsApp.',
};

// Logica voor datum en tijd standaardwaarden
const today = new Date().toISOString().split('T')[0];
---

<Layout metadata={metadata}>
  <section class="relative md:py-12 py-8 bg-white dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      
      <!-- TITEL BOVENAAN -->
      <div class="text-center mb-8">
        <h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter mb-4 font-heading text-[#003399]">
          Luchthavenvervoer Vaste Tarieven
        </h1>
        <p class="text-xl text-muted dark:text-slate-400 max-w-3xl mx-auto">
          Kies uw bestemming, vul uw ophaallocatie in en boek direct uw luxe rit via WhatsApp.
        </p>
      </div>

      <!-- DE NIEUWE AIRPORT CALCULATOR STIJL BOX -->
      <div class="bg-white dark:bg-slate-800 rounded-3xl shadow-2xl border border-gray-100 dark:border-slate-700 overflow-hidden">
        <div class="p-6 md:p-10">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            
            <!-- LINKERKANT: TABEL MET RADIO BUTTONS -->
            <div>
              <div class="flex items-center mb-6">
                <span class="flex items-center justify-center w-8 h-8 rounded-full bg-[#003399] text-white font-bold mr-3">1</span>
                <h2 class="text-xl font-bold text-[#003399]">Kies uw Bestemming</h2>
              </div>
              
              <div class="overflow-hidden rounded-xl border border-gray-200 dark:border-slate-700">
                <table class="w-full text-left border-collapse">
                  <thead>
                    <tr class="bg-[#003399] text-white text-sm">
                      <th class="p-3">Select</th>
                      <th class="p-3">Luchthaven</th>
                      <th class="p-3 text-right">Tesla</th>
                      <th class="p-3 text-right">Busje</th>
                    </tr>
                  </thead>
                  <tbody class="text-sm">
                    <tr class="border-b border-gray-100 dark:border-slate-700 hover:bg-blue-50 dark:hover:bg-slate-700 transition-colors cursor-pointer">
                      <td class="p-3 text-center"><input type="radio" name="airport" value="Schiphol" checked class="w-4 h-4 text-[#003399]" /></td>
                      <td class="p-3 font-semibold text-[#003399]">Schiphol Airport (AMS)</td>
                      <td class="p-3 text-right font-bold text-blue-700">€ 45,-</td>
                      <td class="p-3 text-right font-bold text-blue-700">€ 65,-</td>
                    </tr>
                    <tr class="border-b border-gray-100 dark:border-slate-700 hover:bg-blue-50 dark:hover:bg-slate-700 transition-colors cursor-pointer">
                      <td class="p-3 text-center"><input type="radio" name="airport" value="Rotterdam" class="w-4 h-4 text-[#003399]" /></td>
                      <td class="p-3 font-semibold text-[#003399]">Rotterdam The Hague</td>
                      <td class="p-3 text-right font-bold text-blue-700">€ 125,-</td>
                      <td class="p-3 text-right font-bold text-blue-700">€ 160,-</td>
                    </tr>
                    <tr class="border-b border-gray-100 dark:border-slate-700 hover:bg-blue-50 dark:hover:bg-slate-700 transition-colors cursor-pointer">
                      <td class="p-3 text-center"><input type="radio" name="airport" value="Eindhoven" class="w-4 h-4 text-[#003399]" /></td>
                      <td class="p-3 font-semibold text-[#003399]">Eindhoven Airport</td>
                      <td class="p-3 text-right font-bold text-blue-700">€ 185,-</td>
                      <td class="p-3 text-right font-bold text-blue-700">€ 230,-</td>
                    </tr>
                    <tr class="border-b border-gray-100 dark:border-slate-700 hover:bg-blue-50 dark:hover:bg-slate-700 transition-colors cursor-pointer">
                      <td class="p-3 text-center"><input type="radio" name="airport" value="Brussel" class="w-4 h-4 text-[#003399]" /></td>
                      <td class="p-3 font-semibold text-[#003399]">Brussel Zaventem</td>
                      <td class="p-3 text-right font-bold text-blue-700">€ 325,-</td>
                      <td class="p-3 text-right font-bold text-blue-700">€ 395,-</td>
                    </tr>
                    <tr class="hover:bg-blue-50 dark:hover:bg-slate-700 transition-colors cursor-pointer">
                      <td class="p-3 text-center"><input type="radio" name="airport" value="Dusseldorf" class="w-4 h-4 text-[#003399]" /></td>
                      <td class="p-3 font-semibold text-[#003399]">Düsseldorf Airport</td>
                      <td class="p-3 text-right font-bold text-blue-700">€ 345,-</td>
                      <td class="p-3 text-right font-bold text-blue-700">€ 415,-</td>
                    </tr>
                  </tbody>
                </table>
              </div>
              <p class="mt-3 text-xs text-gray-500 italic">* Regio Amsterdam (incl. Amstelveen, Hoofddorp). Andere locaties op aanvraag.</p>
            </div>

            <!-- RECHTERKANT: FORMULIER VELDEN -->
            <div class="flex flex-col justify-center">
              <div class="flex items-center mb-6">
                <span class="flex items-center justify-center w-8 h-8 rounded-full bg-[#003399] text-white font-bold mr-3">2</span>
                <h2 class="text-xl font-bold text-[#003399]">Ritgegevens & Boeken</h2>
              </div>

              <div class="space-y-4">
                <!-- Ophaallocatie -->
                <div class="relative">
                  <div class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-red-500">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M12 11m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0" /><path d="M17.657 16.657l-4.242 4.242a2 2 0 0 1 -2.827 0l-4.244 -4.243a8 8 0 1 1 11.314 0z" /></svg>
                  </div>
                  <input type="text" placeholder="Straatnaam + Huisnummer (Ophaallocatie)" class="block w-full p-4 pl-10 text-sm border border-gray-200 rounded-xl bg-gray-50 focus:ring-blue-500 focus:border-blue-500 dark:bg-slate-700 dark:border-slate-600 dark:text-white" />
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <!-- Datum -->
                  <div class="relative">
                    <input type="date" value={today} class="block w-full p-4 text-sm border border-gray-200 rounded-xl bg-gray-50 dark:bg-slate-700 dark:border-slate-600 dark:text-white" />
                  </div>
                  <!-- Tijd -->
                  <div class="relative">
                    <input type="time" value="12:00" class="block w-full p-4 text-sm border border-gray-200 rounded-xl bg-gray-50 dark:bg-slate-700 dark:border-slate-600 dark:text-white" />
                  </div>
                </div>

                <!-- Naam veld (optioneel maar handig) -->
                <input type="text" placeholder="Uw Naam" class="block w-full p-4 text-sm border border-gray-200 rounded-xl bg-gray-50 dark:bg-slate-700 dark:border-slate-600 dark:text-white" />

                <!-- CTA KNOP -->
                <button 
                  onclick="window.open('https://wa.me/31642277607?text=Ik%20wil%20graag%20een%20luxe%20vliegveld%20taxi%20boeken.%20Bestemming:%20' + document.querySelector('input[name=airport]:checked').value, '_blank')"
                  class="w-full bg-[#003399] hover:bg-blue-800 text-white font-bold py-4 px-6 rounded-xl transition-all shadow-lg flex items-center justify-center gap-2 group"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 group-hover:scale-110 transition-transform" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9" /><path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1" /></svg>
                  NU BOEKEN VIA WHATSAPP
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Rest van de SEO content van de vorige pagina hieronder -->
  <!-- (Features, Over InTaxi, etc. zoals in het vorige ontwerp) -->
</Layout>
