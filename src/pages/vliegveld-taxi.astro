---
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Vliegveld Taxi Amsterdam | Boek Direct Vaste Tarieven',
  description: 'Boek uw luxe Tesla taxi van Amsterdam naar alle luchthavens voor een vaste prijs. Directe bevestiging via WhatsApp.',
};

const today = new Date().toISOString().split('T')[0];
---

<Layout metadata={metadata}>
  <section class="relative md:py-12 py-8 bg-white dark:bg-slate-900">
    <div class="max-w-7xl mx-auto px-4 sm:px-6">
      
      <div class="text-center mb-8">
        <h1 class="text-4xl md:text-5xl font-bold leading-tighter tracking-tighter mb-4 font-heading text-[#003399]">
          Luchthavenvervoer Vaste Tarieven
        </h1>
      </div>

      <div class="bg-white dark:bg-slate-800 rounded-3xl shadow-2xl border border-gray-100 dark:border-slate-700 overflow-hidden">
        <div class="p-6 md:p-10">
          <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
            
            <!-- 1. Luchthaven Selectie -->
            <div>
              <div class="flex items-center mb-6">
                <span class="flex items-center justify-center w-8 h-8 rounded-full bg-[#003399] text-white font-bold mr-3">1</span>
                <h2 class="text-xl font-bold text-[#003399]">Kies uw Bestemming</h2>
              </div>
              
              <div class="overflow-hidden rounded-xl border border-gray-200 dark:border-slate-700">
                <table class="w-full text-left border-collapse">
                  <thead class="bg-[#003399] text-white text-sm">
                    <tr>
                      <th class="p-3 text-center">Select</th>
                      <th class="p-3">Luchthaven</th>
                      <th class="p-3 text-right">Tesla</th>
                      <th class="p-3 text-right">Busje</th>
                    </tr>
                  </thead>
                  <tbody class="text-sm text-[#003399]">
                    {[
                      { id: 'ams', name: 'Schiphol Airport (AMS)', prices: ['€ 45,-', '€ 65,-'] },
                      { id: 'rtm', name: 'Rotterdam The Hague (RTM)', prices: ['€ 125,-', '€ 160,-'] },
                      { id: 'ein', name: 'Eindhoven Airport (EIN)', prices: ['€ 185,-', '€ 230,-'] },
                      { id: 'bru', name: 'Brussel Zaventem (BRU)', prices: ['€ 325,-', '€ 395,-'] },
                      { id: 'dus', name: 'Düsseldorf / Weeze', prices: ['€ 345,-', '€ 415,-'] }
                    ].map((item, i) => (
                      <tr class="border-b border-gray-100 dark:border-slate-700 hover:bg-blue-50 cursor-pointer airport-row">
                        <td class="p-3 text-center">
                          <input type="radio" name="airport" value={item.name} checked={i === 0} class="w-4 h-4" />
                        </td>
                        <td class="p-3 font-semibold">{item.name}</td>
                        <td class="p-3 text-right font-bold">{item.prices[0]}</td>
                        <td class="p-3 text-right font-bold">{item.prices[1]}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>

            <!-- 2. Formulier -->
            <div class="flex flex-col justify-center">
              <div class="flex items-center mb-6">
                <span class="flex items-center justify-center w-8 h-8 rounded-full bg-[#003399] text-white font-bold mr-3">2</span>
                <h2 class="text-xl font-bold text-[#003399]">Uw Gegevens</h2>
              </div>

              <div class="space-y-4">
                <div class="relative" id="autocomplete-container">
                  <input id="ophaal-adres" type="text" autocomplete="off" placeholder="Vul uw ophaaladres in..." class="block w-full p-4 border border-gray-200 rounded-xl bg-gray-50 focus:ring-2 focus:ring-blue-500 outline-none dark:bg-slate-700 dark:text-white" />
                  <div id="suggestions" class="absolute z-[9999] w-full bg-white border border-gray-300 rounded-b-xl shadow-2xl hidden max-h-60 overflow-y-auto"></div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                  <input id="datum" type="date" value={today} class="p-4 border border-gray-200 rounded-xl bg-gray-50 outline-none" />
                  <input id="tijd" type="time" value="12:00" class="p-4 border border-gray-200 rounded-xl bg-gray-50 outline-none" />
                </div>

                <input id="klant-naam" type="text" placeholder="Naam" class="w-full p-4 border border-gray-200 rounded-xl bg-gray-50 outline-none" />
                <input id="klant-tel" type="tel" placeholder="Telefoonnummer" class="w-full p-4 border border-gray-200 rounded-xl bg-gray-50 outline-none" />

                <button id="whatsapp-btn" class="w-full bg-[#003399] text-white font-bold py-4 rounded-xl hover:bg-blue-800 transition-colors shadow-lg">
                  RESERVEREN VIA WHATSAPP
                </button>
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      function initBooking() {
        const input = document.getElementById('ophaal-adres');
        const suggestionsBox = document.getElementById('suggestions');
        const btn = document.getElementById('whatsapp-btn');
        let timeout;

        if (!input || !suggestionsBox) return;

        // Adres Autocomplete
        input.addEventListener('input', () => {
          clearTimeout(timeout);
          const q = input.value;
          if (q.length < 3) {
            suggestionsBox.classList.add('hidden');
            return;
          }

          timeout = setTimeout(async () => {
            try {
              const res = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q)}&format=json&addressdetails=1&limit=5&countrycodes=nl`);
              const data = await res.json();
              
              suggestionsBox.innerHTML = '';
              if (data.length > 0) {
                suggestionsBox.classList.remove('hidden');
                data.forEach(item => {
                  const div = document.createElement('div');
                  div.className = 'p-3 hover:bg-gray-100 cursor-pointer border-b text-sm text-black';
                  div.textContent = item.display_name.split(',').slice(0, 3).join(',');
                  div.onclick = () => {
                    input.value = div.textContent;
                    suggestionsBox.classList.add('hidden'); // Verberg direct
                    suggestionsBox.innerHTML = '';
                  };
                  suggestionsBox.appendChild(div);
                });
              }
            } catch (e) { console.error(e); }
          }, 300);
        });

        // Sluit lijst bij klikken buitenveld
        document.addEventListener('click', (e) => {
          if (!input.contains(e.target)) suggestionsBox.classList.add('hidden');
        });

        // WhatsApp Verzenden
        btn.onclick = () => {
          const v = (id) => document.getElementById(id).value;
          const airport = document.querySelector('input[name="airport"]:checked').value;
          const msg = `Nieuwe Boeking:%0A- Naar: ${airport}%0A- Van: ${v('ophaal-adres')}%0A- Datum: ${v('datum')} om ${v('tijd')}%0A- Naam: ${v('klant-naam')}%0A- Tel: ${v('klant-tel')}`;
          window.open(`https://wa.me/31642277607?text=${msg}`, '_blank');
        };

        // Tabel rijen selecteren
        document.querySelectorAll('.airport-row').forEach(row => {
          row.onclick = () => row.querySelector('input').checked = true;
        });
      }

      // Start direct en na Astro transities
      initBooking();
      document.addEventListener('astro:page-load', initBooking);
    })();
  </script>
</Layout>
