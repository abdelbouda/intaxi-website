---
import Layout from '~/layouts/PageLayout.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

// 1. Static Paths - Stabiel en Getest
export async function getStaticPaths() {
  const luchthavensData = [
    { slug: 'schiphol', naam: 'Schiphol Airport', code: 'AMS', tesla: '45', busje: '65' },
    { slug: 'rotterdam', naam: 'Rotterdam The Hague', code: 'RTM', tesla: '125', busje: '160' },
    { slug: 'eindhoven', naam: 'Eindhoven Airport', code: 'EIN', tesla: '185', busje: '230' },
    { slug: 'antwerpen', naam: 'Antwerpen Airport', code: 'ANR', tesla: '225', busje: '275' },
    { slug: 'brussel', naam: 'Brussel Zaventem', code: 'BRU', tesla: '325', busje: '395' },
    { slug: 'charleroi', naam: 'Charleroi Airport', code: 'CRL', tesla: '325', busje: '395' },
    { slug: 'duesseldorf', naam: 'Düsseldorf / Weeze', code: 'DUS', tesla: '345', busje: '415' },
  ];

  return luchthavensData.map((luchthaven) => ({
    params: { luchthaven: luchthaven.slug },
    props: { info: luchthaven, alleLuchthavens: luchthavensData },
  }));
}

const { info, alleLuchthavens } = Astro.props;

// 2. SEO Metadata - Dynamisch en Veilig
const metadata = {
  title: `Taxi naar ${info.naam} (${info.code}) | InTaxi Amsterdam`,
  description: `Vaste tarieven naar ${info.naam}. Reis comfortabel in een Tesla sedan vanaf € ${info.tesla},- of taxibusje vanaf € ${info.busje},-. 24/7 airport service vanuit Amsterdam.`,
};
---

<Layout metadata={metadata}>
  <!-- 3. Stabilized Pure HTML Hero Sectie (Geen widgets) -->
  <section class="relative h-[60vh] min-h-[500px] flex items-center justify-center overflow-hidden bg-black">
    <!-- De video - Controleer of het bestand exact hier staat -->
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute z-0 w-full h-full object-cover opacity-60"
    >
      <source src="/videos/video_intaxi.webm" type="video/webm" />
    </video>
    
    <!-- Donkere Blauwe Overlay -->
    <div class="absolute inset-0 bg-[#003399]/30 z-10"></div>

    <!-- Dynamische Tekst -->
    <div class="relative z-20 text-center text-white px-4 max-w-4xl">
      <h1 class="text-4xl md:text-7xl font-bold mb-6 font-heading tracking-tighter uppercase">
        Taxi {info.naam}
      </h1>
      <p class="text-xl md:text-2xl font-medium mb-10 leading-relaxed italic border-b border-white/20 pb-4">
        Luxe Airport Vervoer: Tesla Sedan € {info.tesla},- | Taxibus € {info.busje},-
      </p>
      <div class="flex justify-center">
        <a 
          href="https://wa.me/31642277607" 
          class="bg-white text-[#003399] hover:bg-gray-100 px-8 py-4 rounded-full font-bold transition-all shadow-2xl flex items-center text-lg"
        >
          Reserveer via WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- 4. Features/Tarieven Sectie (Veilig voor dynamische data) -->
  <Features2
    title="Luchthaven Tarieven Amsterdam"
    subtitle={`Vaste prijzen voor uw rit naar ${info.naam}`}
    items={[
      {
        title: 'Tesla Sedan',
        description: `Vanaf € ${info.tesla},- <br /> Max. 4 personen`,
        icon: 'tabler:car-electric',
      },
      {
        title: 'Luxe Personenbus',
        description: `Vanaf € ${info.busje},- <br /> Tot 8 personen`,
        icon: 'tabler:users',
      },
      {
        title: 'Airport Service',
        description: 'Professionele chauffeurs 24/7',
        icon: 'tabler:plane-departure',
      },
    ]}
  />

  <!-- 5. Content Sectie (Stabieler gemaakt) -->
  <Content
    isReversed
    items={[
      {
        title: 'Stipt en Betrouwbaar',
        description: `Wij zijn gespecialiseerd in lange-afstandsritten naar ${info.naam}.`,
      },
      {
        title: 'Luxe Tesla Vloot',
        description: 'Geniet van een stille, duurzame rit in de nieuwste Tesla Model Y of 3.',
      },
    ]}
    image={{ src: '~/assets/images/taxi-airport.jpg', alt: 'Airport Service' }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold mb-2 uppercase">Service naar {info.code}</h3>
      Reis in comfort van Amsterdam naar de terminal.
    </Fragment>
  </Content>

  <!-- 6. SEO Link Sectie (Dynamische Loop beveiligd) -->
  <section class="max-w-6xl mx-auto px-4 py-16 border-t border-gray-100 dark:border-slate-800">
    <h3 class="text-xl font-bold mb-8 italic text-[#003399]">Bekijk ook onze andere bestemmingen:</h3>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {
        // Filtert de huidige pagina eruit om loops te voorkomen
        alleLuchthavens
          .filter((l) => l.slug !== info.slug)
          .map((l) => (
            <a 
              href={`/taxi-${l.slug}`} 
              class="block p-4 rounded-xl border border-gray-200 dark:border-slate-800 hover:border-[#003399] hover:bg-gray-50 dark:hover:bg-slate-800 transition-all text-sm font-bold"
            >
              Taxi {l.naam} →
            </a>
          ))
      }
    </div>
  </section>

  <!-- 7. CTA Sectie -->
  <CallToAction
    title="Uw taxi naar de luchthaven reserveren?"
    subtitle="Vaste prijzen, luxe Tesla's en 24/7 service."
    actions={[{
      variant: 'primary',
      text: 'Direct Boeken via WhatsApp',
      href: 'https://wa.me/31642277607',
      icon: 'tabler:brand-whatsapp',
    }]}
  />
</Layout>
