---
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

export async function getStaticPaths() {
  const luchthavensData = [
    { slug: 'schiphol', naam: 'Schiphol Airport', code: 'AMS', tesla: '45', busje: '65' },
    { slug: 'rotterdam', naam: 'Rotterdam The Hague', code: 'RTM', tesla: '125', busje: '160' },
    { slug: 'eindhoven', naam: 'Eindhoven Airport', code: 'EIN', tesla: '185', busje: '230' },
    { slug: 'antwerpen', naam: 'Antwerpen Airport', code: 'ANR', tesla: '225', busje: '275' },
    { slug: 'brussel', naam: 'Brussel Zaventem', code: 'BRU', tesla: '325', busje: '395' },
    { slug: 'charleroi', naam: 'Charleroi Airport', code: 'CRL', tesla: '325', busje: '395' },
    { slug: 'duesseldorf', naam: 'Düsseldorf / Weeze', code: 'DUS', tesla: '345', busje: '415' },
  ];

  return luchthavensData.map((luchthaven) => ({
    params: { luchthaven: luchthaven.slug },
    props: { info: luchthaven, alleLuchthavens: luchthavensData },
  }));
}

const { info, alleLuchthavens } = Astro.props;

const metadata = {
  title: `Taxi naar ${info.naam} - InTaxi Amsterdam`,
};
---

<Layout metadata={metadata}>
  <section class="bg-[#003399] py-20 px-4 text-center">
    <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 uppercase">
      Taxi {info.naam}
    </h1>
    <p class="text-xl text-blue-100 mb-10">
      Vaste prijs: € {info.tesla},- (Tesla) of € {info.busje},- (Bus).
    </p>
    <a href="https://wa.me/31642277607" class="bg-white text-[#003399] px-8 py-4 rounded-lg font-bold">
      Boek via WhatsApp
    </a>
  </section>

  <Features2
    title="Tarieven"
    items={[
      {
        title: 'Tesla Sedan',
        description: `Vanaf € ${info.tesla},-`,
        // Icoon tijdelijk weg om build error te voorkomen
      },
      {
        title: 'Taxibus',
        description: `Vanaf € ${info.busje},-`,
      },
      {
        title: 'Service',
        description: '24/7 airport service',
      },
    ]}
  />

  <CallToAction
    title="Nu een taxi nodig?"
    actions={[{
      variant: 'primary',
      text: 'WhatsApp ons',
      href: 'https://wa.me/31642277607',
    }]}
  />
</Layout>
