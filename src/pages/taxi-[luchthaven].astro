---
import Layout from '~/layouts/PageLayout.astro';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

export async function getStaticPaths() {
  const luchthavens = [
    { slug: 'schiphol', naam: 'Schiphol Airport', code: 'AMS', tesla: '45', busje: '65' },
    { slug: 'rotterdam', naam: 'Rotterdam The Hague', code: 'RTM', tesla: '125', busje: '160' },
    { slug: 'eindhoven', naam: 'Eindhoven Airport', code: 'EIN', tesla: '185', busje: '230' },
    { slug: 'antwerpen', naam: 'Antwerpen Airport', code: 'ANR', tesla: '225', busje: '275' },
    { slug: 'brussel', naam: 'Brussel Zaventem', code: 'BRU', tesla: '325', busje: '395' },
    { slug: 'charleroi', naam: 'Charleroi Airport', code: 'CRL', tesla: '325', busje: '395' },
    { slug: 'duesseldorf', naam: 'Düsseldorf / Weeze', code: 'DUS', tesla: '345', busje: '415' },
  ];

  return luchthavens.map((l) => ({
    params: { luchthaven: l.slug },
    props: { info: l, alleLuchthavens: luchthavens },
  }));
}

const { info, alleLuchthavens } = Astro.props;

const metadata = {
  title: `Taxi naar ${info.naam} (${info.code}) | InTaxi Amsterdam`,
  description: `Vaste lage tarieven naar ${info.naam}. Reis comfortabel in een Tesla vanaf € ${info.tesla},-.`,
};
---

<Layout metadata={metadata}>
  <!-- Stabilized Video Hero -->
  <section class="relative h-[60vh] min-h-[500px] flex items-center justify-center overflow-hidden bg-black">
    <video
      autoplay
      muted
      loop
      playsinline
      poster="/images/hero-poster.jpg"
      class="absolute z-0 w-auto min-w-full min-h-full max-w-none object-cover opacity-60"
    >
      <source src="/videos/video_intaxi.webm" type="video/webm" />
      <source src="/videos/video_intaxi.mp4" type="video/mp4" />
    </video>
    
    <div class="absolute inset-0 bg-[#003399]/30 z-10"></div>

    <div class="relative z-20 text-center text-white px-4">
      <h1 class="text-4xl md:text-6xl font-bold mb-4 font-heading uppercase tracking-tighter">
        Taxi {info.naam}
      </h1>
      <p class="text-xl md:text-2xl mb-8 font-medium">
        Luxe vervoer vanaf <span class="font-bold text-white underline decoration-2 decoration-white/50">€ {info.tesla},-</span>
      </p>
      <a 
        href="https://wa.me/31642277607" 
        class="inline-flex items-center justify-center px-8 py-4 text-lg font-bold text-[#003399] transition-all bg-white rounded-full hover:bg-gray-100 shadow-xl"
      >
        Boek direct via WhatsApp
      </a>
    </div>
  </section>

  <!-- Features / Tarieven -->
  <Features2
    title="Tarieven Amsterdam Airport Service"
    subtitle={`Vaste prijzen voor uw rit naar ${info.naam}`}
    items={[
      {
        title: 'Tesla Executive',
        description: `€ ${info.tesla},- <br /> Duurzaam & Comfortabel`,
        icon: 'tabler:car-electric',
      },
      {
        title: 'Luxe Personenbus',
        description: `€ ${info.busje},- <br /> Tot 8 personen`,
        icon: 'tabler:users',
      },
      {
        title: 'Airport Service',
        description: '24/7 beschikbaarheid',
        icon: 'tabler:plane-arrival',
      },
    ]}
  />

  <Content
    isReversed
    items={[
      {
        title: 'Stiptheid gegarandeerd',
        description: `Onze chauffeurs zijn altijd 5 minuten voor de afgesproken tijd aanwezig voor uw rit naar ${info.naam}.`,
      },
      {
        title: 'Vaste Prijs',
        description: 'Inclusief bagage, BTW en parkeerkosten op de luchthaven.',
      },
    ]}
    image={{ src: '~/assets/images/default.jpg', alt: 'InTaxi Service' }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold mb-2 uppercase">Service naar {info.code}</h3>
      Reis zonder zorgen van Amsterdam naar de terminal.
    </Fragment>
  </Content>

  <!-- SEO Footer Links -->
  <section class="max-w-6xl mx-auto px-4 py-12 border-t border-gray-100">
    <h2 class="text-xl font-bold mb-6 italic text-[#003399]">Andere luchthaven ritten:</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      {alleLuchthavens.filter(l => l.slug !== info.slug).map((l) => (
        <a 
          href={`/taxi-${l.slug}`} 
          class="block p-3 rounded border border-gray-200 hover:bg-[#003399] hover:text-white transition-all text-sm font-medium"
        >
          Taxi {l.naam} →
        </a>
      ))}
    </div>
  </section>

  <CallToAction
    title="Snel een taxi nodig?"
    actions={[{
      variant: 'primary',
      text: 'Bel of WhatsApp nu',
      href: 'https://wa.me/31642277607',
      icon: 'tabler:brand-whatsapp',
    }]}
  />
</Layout>
