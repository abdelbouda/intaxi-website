---
export const prerender = true;

import Layout from '~/layouts/PageLayout.astro';

export async function getStaticPaths() {
  const steden = [
    { slug: 'schiphol', naam: 'Schiphol Airport', code: 'AMS', prijs: '45' },
    { slug: 'rotterdam', naam: 'Rotterdam The Hague', code: 'RTM', prijs: '125' },
    { slug: 'eindhoven', naam: 'Eindhoven Airport', code: 'EIN', prijs: '185' },
    { slug: 'antwerpen', naam: 'Antwerpen Airport', code: 'ANR', prijs: '225' },
    { slug: 'brussel', naam: 'Brussel Zaventem', code: 'BRU', prijs: '325' },
    { slug: 'charleroi', naam: 'Charleroi Airport', code: 'CRL', prijs: '325' },
    { slug: 'duesseldorf', naam: 'Düsseldorf / Weeze', code: 'DUS', prijs: '345' },
  ];

  return steden.map((item) => ({
    params: { luchthaven: item.slug },
    props: { naam: item.naam, code: item.code, prijs: item.prijs },
  }));
}

const { naam, code, prijs } = Astro.props;
---

<Layout metadata={{ title: `Taxi naar ${naam}` }}>
  <main style="padding: 100px 20px; text-align: center; font-family: sans-serif;">
    <h1 style="font-size: 3rem; margin-bottom: 20px; color: #003399;">Taxi naar {naam} ({code})</h1>
    <p style="font-size: 1.5rem; margin-bottom: 40px;">Vaste prijs vanaf Amsterdam: €{prijs},-</p>
    <a 
      href="https://wa.me/31642277607" 
      style="background: #25d366; color: white; padding: 15px 30px; border-radius: 5px; text-decoration: none; font-weight: bold;"
    >
      Reserveer via WhatsApp
    </a>
  </main>
</Layout>
