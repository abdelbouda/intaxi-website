---
import Layout from '~/layouts/PageLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const luchthavens = [
    { slug: 'schiphol-airport', naam: 'Schiphol Airport', code: 'AMS', prijsTesla: '45', prijsBus: '65', reistijd: '20-25 min' },
    { slug: 'rotterdam-the-hague', naam: 'Rotterdam The Hague', code: 'RTM', prijsTesla: '125', prijsBus: '160', reistijd: '50-60 min' },
    { slug: 'eindhoven-airport', naam: 'Eindhoven Airport', code: 'EIN', prijsTesla: '185', prijsBus: '230', reistijd: '75-90 min' },
    { slug: 'antwerp-airport', naam: 'Antwerp Airport', code: 'ANR', prijsTesla: '225', prijsBus: '275', reistijd: '120 min' },
    { slug: 'brussels-zaventem', naam: 'Brussels Zaventem', code: 'BRU', prijsTesla: '325', prijsBus: '395', reistijd: '2.5 hours' },
    { slug: 'charleroi-airport', naam: 'Charleroi Airport', code: 'CRL', prijsTesla: '325', prijsBus: '395', reistijd: '3 hours' },
    { slug: 'duesseldorf-weeze', naam: 'Düsseldorf / Weeze', code: 'DUS', prijsTesla: '345', prijsBus: '415', reistijd: '2 hours' },
  ];

  return luchthavens.map((l) => ({
    params: { luchthaven: l.slug }, // This fills the [luchthaven] in the URL
    props: { 
      naam: l.naam, 
      code: l.code, 
      prijsTesla: l.prijsTesla,
      prijsBus: l.prijsBus,
      reistijd: l.reistijd 
    },
  }));
}
const { naam, code, prijsTesla, prijsBus, reistijd } = Astro.props;
const today = new Date().toISOString().split('T')[0];

const metadata = {
  title: `Taxi Amsterdam to ${naam} (${code}) | Fixed Price from €${prijsTesla}`,
  description: `Luxury Tesla taxi or van from Amsterdam to ${naam}. Fixed rate from €${prijsTesla}. No hidden costs, available 24/7. Book directly via WhatsApp!`,
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Reduced padding from py-12 to pt-6 -->
  <section class="pt-6 pb-12 md:pt-10 md:pb-20 px-4 max-w-6xl mx-auto">
    
    <!-- Compact header -->
    <div class="text-center mb-6 md:mb-8">
      <h1 class="text-2xl md:text-4xl font-extrabold text-slate-900 mb-2 tracking-tight uppercase">
        Taxi Amsterdam to <span class="text-[#003399]">{naam}</span>
      </h1>
      <p class="text-sm md:text-base text-gray-600 max-w-xl mx-auto leading-tight">
        Choose a luxury Tesla or a spacious taxi van at a fixed rate to {code}.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 items-start">
      
      <!-- LEFT SIDE: INFO & RATES -->
      <div class="space-y-4">
        <div class="bg-white border border-gray-100 rounded-3xl shadow-xl overflow-hidden">
          <div class="bg-[#003399] p-3 text-white font-bold text-center uppercase tracking-widest text-[10px]">
            Rates to {code}
          </div>
          <div class="p-4 grid grid-cols-2 gap-3">
            <div class="text-center p-3 rounded-2xl bg-blue-50 border border-blue-100">
              <span class="block text-[9px] uppercase font-bold text-blue-400 mb-1">Luxury Tesla (4p)</span>
              <span class="text-xl font-black text-[#003399]">from €{prijsTesla},-</span>
            </div>
            <div class="text-center p-3 rounded-2xl bg-slate-50 border border-slate-100">
              <span class="block text-[9px] uppercase font-bold text-slate-400 mb-1">Taxi Van (8p)</span>
              <span class="text-xl font-black text-slate-700">from €{prijsBus},-</span>
            </div>
          </div>
          <div class="px-4 pb-4 text-[11px] text-gray-500 italic text-center">
             Estimated travel time: approximately {reistijd}
          </div>
        </div>

        <div class="hidden md:block bg-slate-50/50 p-4 rounded-3xl border border-slate-100">
          <ul class="list-none pl-0 space-y-1 text-xs">
            <li class="flex items-center">✅ <span class="ml-2">Fixed price in advance</span></li>
            <li class="flex items-center">✅ <span class="ml-2">Luxury Teslas & vans</span></li>
            <li class="flex items-center">✅ <span class="ml-2">24/7 WhatsApp support</span></li>
          </ul>
        </div>
      </div>

      <!-- RIGHT SIDE: BOOKING FORM (Sleek design) -->
      <div class="bg-white rounded-3xl shadow-2xl p-5 border border-gray-50">
        <div class="flex items-center mb-4">
          <span class="flex items-center justify-center w-6 h-6 rounded-full bg-[#003399] text-white font-bold mr-2 text-[10px]">2</span>
          <h2 class="text-base font-bold text-[#003399]">Trip Details & Book</h2>
        </div>

        <div class="space-y-3">
          <div class="grid grid-cols-2 gap-2">
            <button id="btn-tesla" class="vehicle-btn active p-2 rounded-xl border-2 border-[#003399] bg-[#003399] text-white font-bold text-[10px] uppercase transition-all">Luxury Tesla</button>
            <button id="btn-busje" class="vehicle-btn p-2 rounded-xl border-2 border-gray-100 bg-gray-50 text-gray-400 font-bold text-[10px] uppercase transition-all">Taxi Van</button>
          </div>

          <div class="flex gap-2">
            <div class="flex-[4] relative">
              <input id="ophaal-adres" type="text" autocomplete="off" placeholder="Pickup Address" class="block w-full p-3 border border-gray-200 rounded-xl bg-gray-50 outline-none text-xs text-black[...]
              <div id="suggestions" class="absolute z-[100] w-full bg-white border border-gray-300 rounded-b-xl shadow-2xl hidden max-h-40 overflow-y-auto mt-1"></div>
            </div>
            <input id="huisnummer" type="text" placeholder="No." class="flex-[1] p-3 border border-gray-200 rounded-xl bg-gray-50 outline-none text-xs text-black text-center" />
          </div>

          <div class="grid grid-cols-2 gap-2">
            <input id="datum" type="date" value={today} class="p-3 border border-gray-200 rounded-xl bg-gray-50 outline-none text-xs text-black" />
            <input id="tijd" type="time" value="12:00" class="p-3 border border-gray-200 rounded-xl bg-gray-50 outline-none text-xs text-black" />
          </div>

          <div class="grid grid-cols-2 gap-2">
            <input id="naam" type="text" placeholder="Name" class="p-3 border border-gray-200 rounded-xl bg-gray-50 outline-none text-xs text-black" />
            <input id="tel" type="tel" placeholder="Phone" class="p-3 border border-gray-200 rounded-xl bg-gray-50 outline-none text-xs text-black" />
          </div>

          <textarea id="notitie" placeholder="Flight number / notes..." rows="1" class="w-full p-3 border border-gray-200 rounded-xl bg-gray-50 outline-none text-xs text-black resize-none"><[...]

          <div class="bg-blue-50 p-3 rounded-2xl text-center border border-blue-100">
             <span id="current-price" class="text-xl font-black text-[#003399]">Total: € {prijsTesla},-</span>
          </div>

          <button id="whatsapp-btn" class="w-full bg-[#003399] text-white font-black py-4 rounded-2xl hover:bg-blue-800 transition-all shadow-lg uppercase tracking-widest text-[11px] flex items-c[...]
            Book Now via WhatsApp
          </button>
        </div>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ naam, prijsTesla, prijsBus }}>
    function initLocalBooking() {
      const input = document.getElementById('ophaal-adres');
      const suggestionsBox = document.getElementById('suggestions');
      const btn = document.getElementById('whatsapp-btn');
      const priceDisplay = document.getElementById('current-price');
      const teslaBtn = document.getElementById('btn-tesla');
      const busjeBtn = document.getElementById('btn-busje');
      
      let selectedVehicle = 'Tesla';
      let debounceTimer;

      function setVehicle(type) {
        selectedVehicle = type;
        if (type === 'Tesla') {
          teslaBtn.className = "vehicle-btn active p-2 rounded-xl border-2 border-[#003399] bg-[#003399] text-white font-bold text-[10px] uppercase";
          busjeBtn.className = "vehicle-btn p-2 rounded-xl border-2 border-gray-100 bg-gray-50 text-gray-400 font-bold text-[10px] uppercase";
          priceDisplay.textContent = `Total: € ${prijsTesla},-`;
        } else {
          busjeBtn.className = "vehicle-btn active p-2 rounded-xl border-2 border-[#003399] bg-[#003399] text-white font-bold text-[10px] uppercase";
          teslaBtn.className = "vehicle-btn p-2 rounded-xl border-2 border-gray-100 bg-gray-50 text-gray-400 font-bold text-[10px] uppercase";
          priceDisplay.textContent = `Total: € ${prijsBus},-`;
        }
      }

      teslaBtn.onclick = () => setVehicle('Tesla');
      busjeBtn.onclick = () => setVehicle('Van');

      input.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        const q = input.value;
        if (q.length < 3) { suggestionsBox.classList.add('hidden'); return; }

        debounceTimer = setTimeout(async () => {
          try {
            const res = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q)}&format=json&addressdetails=1&limit=5&countrycodes=nl`);
            const data = await res.json();
            suggestionsBox.innerHTML = '';
            if (data.length > 0) {
              suggestionsBox.classList.remove('hidden');
              data.forEach(item => {
                const div = document.createElement('div');
                div.className = 'p-2 hover:bg-blue-50 cursor-pointer border-b text-[11px] text-black bg-white';
                const parts = item.display_name.split(',');
                const label = parts[0] + (parts[1] ? ', ' + parts[1] : '');
                div.textContent = label;
                div.onclick = () => {
                  input.value = label;
                  suggestionsBox.classList.add('hidden');
                  document.getElementById('huisnummer').focus();
                };
                suggestionsBox.appendChild(div);
              });
            }
          } catch (err) { console.error('Address error:', err); }
        }, 300);
      });

      btn.onclick = () => {
        const val = (id) => document.getElementById(id).value;
        const text = `Hi InTaxi, I want to book a trip to ${naam}:%0A%0A` +
                     `🚕 Vehicle: ${selectedVehicle}%0A` +
                     `💰 Price: ${priceDisplay.textContent}%0A` +
                     `🏠 From: ${val('ophaal-adres')} ${val('huisnummer')}%0A` +
                     `📅 Date: ${val('datum')}%0A` +
                     `⏰ Time: ${val('tijd')}%0A` +
                     `👤 Name: ${val('naam')}%0A` +
                     `📞 Phone: ${val('tel')}%0A` +
                     `📝 Note: ${val('notitie')}`;
        
        window.open(`https://wa.me/31642277607?text=${text}`, '_blank');
      };

      document.addEventListener('click', (e) => {
        if (!input.contains(e.target)) suggestionsBox.classList.add('hidden');
      });
    }

    initLocalBooking();
    document.addEventListener('astro:page-load', initLocalBooking);
  </script>
</Layout>
