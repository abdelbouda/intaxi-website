---
import Layout from '~/layouts/PageLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const luchthavens = [
    { slug: 'schiphol-airport', naam: 'Schiphol Airport', code: 'AMS', prijsTesla: '45', prijsBus: '65', reistijd: '20-25 min' },
    { slug: 'rotterdam-the-hague', naam: 'Rotterdam The Hague', code: 'RTM', prijsTesla: '125', prijsBus: '160', reistijd: '50-60 min' },
    { slug: 'eindhoven-airport', naam: 'Eindhoven Airport', code: 'EIN', prijsTesla: '185', prijsBus: '230', reistijd: '75-90 min' },
    { slug: 'antwerp-airport', naam: 'Antwerp Airport', code: 'ANR', prijsTesla: '225', prijsBus: '275', reistijd: '120 min' },
    { slug: 'brussels-zaventem', naam: 'Brussels Zaventem', code: 'BRU', prijsTesla: '325', prijsBus: '395', reistijd: '2.5 hours' },
    { slug: 'charleroi-airport', naam: 'Charleroi Airport', code: 'CRL', prijsTesla: '325', prijsBus: '395', reistijd: '3 hours' },
    { slug: 'duesseldorf-weeze', naam: 'Düsseldorf / Weeze', code: 'DUS', prijsTesla: '345', prijsBus: '415', reistijd: '2 hours' },
  ];

  return luchthavens.map((l) => ({
    params: { luchthaven: l.slug },
    props: { 
      naam: l.naam, 
      code: l.code, 
      prijsTesla: l.prijsTesla,
      prijsBus: l.prijsBus,
      reistijd: l.reistijd 
    },
  }));
}
const { naam, code, prijsTesla, prijsBus, reistijd } = Astro.props;
const today = new Date().toISOString().split('T')[0];

const metadata = {
  title: `Taxi Amsterdam to ${naam} (${code}) | Fixed Price from €${prijsTesla}`,
  description: `Luxury Tesla taxi or van from Amsterdam to ${naam}. Fixed rate from €${prijsTesla}. No hidden costs, available 24/7. Book directly via WhatsApp!`,
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- ... al je bestaande HTML blijft precies hetzelfde ... -->

  <!-- Je gehele form en inhoud komt HIER ... -->

  <!-- Plaats enkel DIT <script is:inline> blok vlak voor de afsluitende </Layout> -->
  <script is:inline>
    // Maak prijs-gegevens beschikbaar (uit Astro.props)
    const prijsTesla = "{prijsTesla}";
    const prijsBus = "{prijsBus}";
    const naam = "{naam}";

    function initLocalBooking() {
      const input = document.getElementById('ophaal-adres');
      const suggestionsBox = document.getElementById('suggestions');
      const btn = document.getElementById('whatsapp-btn');
      const priceDisplay = document.getElementById('current-price');
      const teslaBtn = document.getElementById('btn-tesla');
      const busjeBtn = document.getElementById('btn-busje');

      let selectedVehicle = 'Tesla';
      let debounceTimer;

      function setVehicle(type) {
        selectedVehicle = type;
        if (type === 'Tesla') {
          teslaBtn.className = "vehicle-btn active p-2 rounded-xl border-2 border-[#003399] bg-[#003399] text-white font-bold text-[10px] uppercase";
          busjeBtn.className = "vehicle-btn p-2 rounded-xl border-2 border-gray-100 bg-gray-50 text-gray-400 font-bold text-[10px] uppercase";
          priceDisplay.textContent = `Total: € ${prijsTesla},-`;
        } else {
          busjeBtn.className = "vehicle-btn active p-2 rounded-xl border-2 border-[#003399] bg-[#003399] text-white font-bold text-[10px] uppercase";
          teslaBtn.className = "vehicle-btn p-2 rounded-xl border-2 border-gray-100 bg-gray-50 text-gray-400 font-bold text-[10px] uppercase";
          priceDisplay.textContent = `Total: € ${prijsBus},-`;
        }
      }

      teslaBtn.onclick = () => setVehicle('Tesla');
      busjeBtn.onclick = () => setVehicle('Van');

      input.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        const q = input.value;
        if (q.length < 3) { suggestionsBox.classList.add('hidden'); return; }
        debounceTimer = setTimeout(async () => {
          try {
            const res = await fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(q)}&format=json&addressdetails=1&limit=5&countrycodes=nl`);
            const data = await res.json();
            suggestionsBox.innerHTML = '';
            if (data.length > 0) {
              suggestionsBox.classList.remove('hidden');
              data.forEach(item => {
                const div = document.createElement('div');
                div.className = 'p-2 hover:bg-blue-50 cursor-pointer border-b text-[11px] text-black bg-white';
                const parts = item.display_name.split(',');
                const label = parts[0] + (parts[1] ? ', ' + parts[1] : '');
                div.textContent = label;
                div.onclick = () => {
                  input.value = label;
                  suggestionsBox.classList.add('hidden');
                  document.getElementById('huisnummer').focus();
                };
                suggestionsBox.appendChild(div);
              });
            }
          } catch (err) { console.error('Address error:', err); }
        }, 300);
      });

      btn.onclick = () => {
        const val = (id) => document.getElementById(id).value;
        const text = `Hi InTaxi, I want to book a trip to ${naam}:%0A%0A` +
                     `🚕 Vehicle: ${selectedVehicle}%0A` +
                     `💰 Price: ${priceDisplay.textContent}%0A` +
                     `🏠 From: ${val('ophaal-adres')} ${val('huisnummer')}%0A` +
                     `📅 Date: ${val('datum')}%0A` +
                     `⏰ Time: ${val('tijd')}%0A` +
                     `👤 Name: ${val('naam')}%0A` +
                     `📞 Phone: ${val('tel')}%0A` +
                     `📝 Note: ${val('notitie')}`;
        window.open(`https://wa.me/31642277607?text=${text}`, '_blank');
      };

      document.addEventListener('click', (e) => {
        if (!input.contains(e.target)) suggestionsBox.classList.add('hidden');
      });
    }

    // Astro hydrateert niet altijd DOM direct 
    if (document.readyState !== "loading") {
      initLocalBooking();
    } else {
      document.addEventListener('DOMContentLoaded', initLocalBooking);
    }
    document.addEventListener('astro:page-load', initLocalBooking);
  </script>
</Layout>
