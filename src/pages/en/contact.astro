---
import Layout from '~/layouts/PageLayout.astro';
import ContactUs from '~/components/widgets/Contact.astro';

// Ensure static generation
export const prerender = true;

const metadata = {
  title: 'Contact | InTaxi Amsterdam - Your Premium Tesla Taxi Partner',
  description: 'Get in touch with InTaxi for corporate travel, Tesla taxi services, and luxury airport transfers. Available 24/7 via WhatsApp for rides to Schiphol, Brussels, and more.',
};

// Updated slugs to match the dynamic paths
const airports = [
  { name: 'Schiphol Airport', slug: 'schiphol' },
  { name: 'Rotterdam The Hague', slug: 'rotterdam' },
  { name: 'Eindhoven Airport', slug: 'eindhoven' },
  { name: 'Antwerp Airport', slug: 'antwerpen' },
  { name: 'Brussels Zaventem', slug: 'brussel' },
  { name: 'Charleroi Airport', slug: 'charleroi' },
  { name: 'Düsseldorf Airport', slug: 'duesseldorf' },
];
---

<Layout metadata={metadata}>
  <section class="relative h-[60vh] min-h-[500px] flex items-center justify-center overflow-hidden">
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute z-0 w-auto min-w-full min-h-full max-w-none object-cover"
    >
      <source src="/videos/video_intaxi.webm" type="video/webm" />
      Your browser does not support video streaming.
    </video>
    
    <div class="absolute inset-0 bg-[#003399]/40 z-10"></div>

    <div class="relative z-20 w-full max-w-5xl px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <div class="bg-white/95 backdrop-blur-sm p-6 rounded-xl shadow-2xl text-center border-t-4 border-[#003399]">
          <div class="flex justify-center mb-3">
            <div class="p-3 bg-[#003399]/10 rounded-full text-[#003399]">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
            </div>
          </div>
          <h3 class="text-gray-900 font-bold text-lg mb-1 uppercase tracking-tight">WhatsApp</h3>
          <a href="https://wa.me/31642277607" class="text-[#003399] font-black text-xl hover:underline">+31 6 42277607</a>
        </div>

        <div class="bg-white/95 backdrop-blur-sm p-6 rounded-xl shadow-2xl text-center border-t-4 border-[#003399]">
          <div class="flex justify-center mb-3">
            <div class="p-3 bg-[#003399]/10 rounded-full text-[#003399]">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
          </div>
          <h3 class="text-gray-900 font-bold text-lg mb-1 uppercase tracking-tight">Email</h3>
          <a href="mailto:info@intaxi.nl" class="text-[#003399] font-black text-xl hover:underline">info@intaxi.nl</a>
        </div>

        <div class="bg-white/95 backdrop-blur-sm p-6 rounded-xl shadow-2xl text-center border-t-4 border-[#003399]">
          <div class="flex justify-center mb-3">
            <div class="p-3 bg-[#003399]/10 rounded-full text-[#003399]">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
          </div>
          <h3 class="text-gray-900 font-bold text-lg mb-1 uppercase tracking-tight">Base</h3>
          <p class="text-[#003399] font-black text-xl">Amsterdam</p>
        </div>

      </div>
    </div>
  </section>

  <div class="grid md:grid-cols-2 gap-0 bg-white dark:bg-slate-900 border-t border-gray-100 dark:border-slate-800">
    <div class="p-8 md:p-16 border-r border-gray-100 dark:border-slate-800">
       <ContactUs
        id="form"
        title="Direct Inquiry"
        subtitle="Contact us regarding fleet availability, international long-distance trips, or corporate accounts."
        inputs={[
          { type: 'text', name: 'name', label: 'Name / Company Name' },
          { type: 'email', name: 'email', label: 'Email Address' },
        ]}
        textarea={{ label: 'How can we assist you?' }}
        button="Send Message"
      />
    </div>

    <div class="bg-[#003399] p-8 md:p-16 text-white flex flex-col justify-center">
      <h2 class="text-3xl font-bold mb-8 italic border-b border-white/20 pb-4">Business Partner</h2>
      <ul class="space-y-6">
        <li class="flex items-start gap-4">
          <div class="bg-white/20 p-2 rounded-lg text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M5 12l5 5l10 -10" /></svg>
          </div>
          <div>
            <h4 class="font-bold text-lg">Invoicing on Account</h4>
            <p class="text-sm opacity-80">Ideal for corporate clients. Receive monthly invoices for all your executive travel.</p>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <div class="bg-white/20 p-2 rounded-lg text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M5 12l5 5l10 -10" /></svg>
          </div>
          <div>
            <h4 class="font-bold text-lg">Tesla Executive Fleet</h4>
            <p class="text-sm opacity-80">Travel in silence, style, and comfort with our Tesla Model Y or Model 3 fleet.</p>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <div class="bg-white/20 p-2 rounded-lg text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M5 12l5 5l10 -10" /></svg>
          </div>
          <div>
            <h4 class="font-bold text-lg">International Transfers</h4>
            <p class="text-sm opacity-80">Specialists in long-distance cross-border trips to Paris, Brussels, Berlin, and beyond.</p>
          </div>
        </li>
      </ul>
    </div>
  </div>

  <section class="bg-slate-50 dark:bg-slate-800/50 py-16">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid md:grid-cols-3 gap-12">
        <div class="md:col-span-2">
          <h2 class="text-2xl font-bold text-[#003399] dark:text-blue-400 mb-4 uppercase tracking-tight">Luxury Taxi Amsterdam to Schiphol & Europe</h2>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed mb-4">
            InTaxi is your premier partner for high-end passenger transport from Amsterdam to all major European airports. Whether you require a <strong>Tesla taxi to Schiphol</strong> for a business flight or a comfortable van for a group transfer to Brussels, our professional drivers are available 24/7.
          </p>
          <p class="text-gray-700 dark:text-gray-300 leading-relaxed">
            We distinguish ourselves through fixed pricing, an all-electric sustainable fleet, and a seamless booking experience via WhatsApp. No hidden fees, just premium quality <strong>executive airport transfers</strong> and corporate taxi solutions.
          </p>
        </div>
        
        <div class="bg-white dark:bg-slate-900 p-6 rounded-xl shadow-sm border border-gray-100 dark:border-slate-700">
          <h3 class="font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
            <span class="text-[#003399]">✈️</span> Our Destinations
          </h3>
          <ul class="space-y-2">
            {airports.map((airport) => (
              <li>
                <a 
                  href={`/en/taxi-${airport.slug}`} 
                  class="text-sm text-gray-600 dark:text-gray-400 hover:text-[#003399] dark:hover:text-blue-400 flex justify-between border-b border-gray-50 dark:border-slate-800 pb-1"
                >
                  Taxi to {airport.name}
                  <span class="text-[10px] font-bold">→</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>
