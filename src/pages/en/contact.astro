---
import Layout from '~/layouts/PageLayout.astro';
import ContactUs from '~/components/widgets/Contact.astro';

const metadata = {
  title: 'Contact | InTaxi Amsterdam - Your Premium Taxi Partner',
  description: 'Contact InTaxi for business transport, Tesla taxi services and airport transfers. Available 24/7 via WhatsApp and Email.',
};
---

<Layout metadata={metadata}>
  <!-- Video Hero Section -->
  <section class="relative h-[60vh] min-h-[500px] flex items-center justify-center overflow-hidden">
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute z-0 w-auto min-w-full min-h-full max-w-none object-cover"
    >
      <source src="/videos/video_intaxi.webm" type="video/webm" />
      Your browser does not support video streaming.
    </video>
    
    <div class="absolute inset-0 bg-[#003399]/40 z-10"></div>

    <!-- 3 Compact cards instead of text/CTA -->
    <div class="relative z-20 w-full max-w-5xl px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- Card 1: WhatsApp -->
        <div class="bg-white/95 backdrop-blur-sm p-6 rounded-xl shadow-2xl text-center border-t-4 border-[#003399]">
          <div class="flex justify-center mb-3">
            <div class="p-3 bg-[#003399]/10 rounded-full text-[#003399]">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d=[...]
            </div>
          </div>
          <h3 class="text-gray-900 font-bold text-lg mb-1 uppercase tracking-tight">WhatsApp</h3>
          <a href="https://wa.me/31642277607" class="text-[#003399] font-black text-xl hover:underline">06-42277607</a>
        </div>

        <!-- Card 2: E-mail -->
        <div class="bg-white/95 backdrop-blur-sm p-6 rounded-xl shadow-2xl text-center border-t-4 border-[#003399]">
          <div class="flex justify-center mb-3">
            <div class="p-3 bg-[#003399]/10 rounded-full text-[#003399]">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d=[...]
            </div>
          </div>
          <h3 class="text-gray-900 font-bold text-lg mb-1 uppercase tracking-tight">E-mail</h3>
          <a href="mailto:info@intaxi.nl" class="text-[#003399] font-black text-xl hover:underline">info@intaxi.nl</a>
        </div>

        <!-- Card 3: Location -->
        <div class="bg-white/95 backdrop-blur-sm p-6 rounded-xl shadow-2xl text-center border-t-4 border-[#003399]">
          <div class="flex justify-center mb-3">
            <div class="p-3 bg-[#003399]/10 rounded-full text-[#003399]">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d=[...]
            </div>
          </div>
          <h3 class="text-gray-900 font-bold text-lg mb-1 uppercase tracking-tight">Location</h3>
          <p class="text-[#003399] font-black text-xl">Amsterdam</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Contact Form & Business USPs -->
  <div class="grid md:grid-cols-2 gap-0 bg-white dark:bg-slate-900 border-t border-gray-100 dark:border-slate-800">
    <div class="p-8 md:p-16 border-r border-gray-100 dark:border-slate-800">
       <ContactUs
        id="form"
        title="Direct Inquiry"
        subtitle="Ask us about our fleet, international trips or business accounts."
        inputs={[
          { type: 'text', name: 'name', label: 'Name / Company Name' },
          { type: 'email', name: 'email', label: 'Email Address' },
        ]}
        textarea={{ label: 'How can we help you?' }}
        button="Send Message"
      />
    </div>

    <div class="bg-[#003399] p-8 md:p-16 text-white flex flex-col justify-center">
      <h2 class="text-3xl font-bold mb-8 italic border-b border-white/20 pb-4">Business Partner</h2>
      <ul class="space-y-6">
        <li class="flex items-start gap-4">
          <div class="bg-white/20 p-2 rounded-lg text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M5 12l5 5l10 -10" /></svg>
          </div>
          <div>
            <h4 class="font-bold text-lg">Billing on Account</h4>
            <p class="text-sm opacity-80">Perfect for companies. Receive periodic invoices for all your trips.</p>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <div class="bg-white/20 p-2 rounded-lg text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M5 12l5 5l10 -10" /></svg>
          </div>
          <div>
            <h4 class="font-bold text-lg">Tesla Executive Fleet</h4>
            <p class="text-sm opacity-80">Travel in silence and comfort in our Tesla Model Y or Model 3.</p>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <div class="bg-white/20 p-2 rounded-lg text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M5 12l5 5l10 -10" /></svg>
          </div>
          <div>
            <h4 class="font-bold text-lg">International Trips</h4>
            <p class="text-sm opacity-80">Specialized in long distances to Paris, Brussels and Berlin among others.</p>
          </div>
        </li>
      </ul>
    </div>
  </div>
</Layout>
