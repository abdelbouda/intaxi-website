---
import Layout from '~/layouts/PageLayout.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'Contact | InTaxi Amsterdam - Uw Premium Taxi Partner',
  description: 'Neem direct contact op met InTaxi voor zakelijk vervoer, Tesla taxi services en luchthavenritten. 24/7 bereikbaar via WhatsApp en E-mail.',
};
---

<Layout metadata={metadata}>
  <section class="relative h-[35vh] min-h-[300px] flex items-center justify-center overflow-hidden">
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute z-0 w-full h-full object-cover"
    >
      <source src="/videos/video_intaxi.webm" type="video/webm" />
    </video>
    
    <div class="absolute inset-0 bg-[#003399]/40 z-10"></div>

    <div class="relative z-20 text-center text-white px-4 max-w-4xl">
      <h1 class="text-3xl md:text-5xl font-bold mb-2 font-heading tracking-tighter uppercase drop-shadow-lg">
        Contact
      </h1>
      <p class="text-base md:text-lg font-medium mb-4 leading-relaxed drop-shadow-md">
        Premium vervoer voor zakelijke en particuliere klanten.<br class="hidden md:block" /> 
        24/7 bereikbaar vanuit Amsterdam.
      </p>
      <div class="flex justify-center">
        <a href="https://wa.me/31642277607" class="bg-[#003399] hover:bg-blue-900 text-white px-6 py-2 rounded-full font-bold transition-all shadow-xl flex items-center border border-white/30 text-sm md:text-base">
           <span class="mr-2">WhatsApp Direct: 06-42277607</span>
        </a>
      </div>
    </div>
  </section>

  <div class="relative z-30 max-w-6xl mx-auto px-4 mt-[-5rem]">
    <Features2
      classes={{ 
        container: 'py-0 md:py-0 lg:py-0',
        items: 'gap-4 md:gap-6', // Zorgt dat de kaders dichter bij elkaar staan
      }} 
      items={[
        {
          title: 'WhatsApp & Telefoon',
          description: '<a href="tel:0642277607" class="text-[#003399] font-bold">06-42277607</a>',
          icon: 'tabler:brand-whatsapp',
        },
        {
          title: 'Zakelijk E-mail',
          description: '<a href="mailto:info@intaxi.nl" class="text-[#003399] font-bold">info@intaxi.nl</a>',
          icon: 'tabler:mail',
        },
        {
          title: 'Standplaats',
          description: 'Memeleiland, Amsterdam',
          icon: 'tabler:map-pin',
        },
      ]}
    />
  </div>

  <div class="grid md:grid-cols-2 gap-0 bg-white dark:bg-slate-900 border-t border-gray-100 dark:border-slate-800 mt-4">
    <div class="p-6 md:p-10 border-r border-gray-100 dark:border-slate-800">
       <ContactUs
        id="form"
        title="Directe Aanvraag"
        subtitle="Stel hier uw vraag over onze vloot of zakelijke accounts."
        inputs={[
          { type: 'text', name: 'name', label: 'Naam / Bedrijfsnaam' },
          { type: 'email', name: 'email', label: 'E-mailadres' },
        ]}
        textarea={{ label: 'Hoe kunnen we u van dienst zijn?' }}
        button="Verstuur Bericht"
      />
    </div>

    <div class="bg-[#003399] p-6 md:p-10 text-white flex flex-col justify-center">
      <h2 class="text-xl font-bold mb-4 italic border-b border-white/20 pb-2">Zakelijke Partner</h2>
      <ul class="space-y-3">
        <li class="flex items-start gap-3">
          <div class="bg-white/10 p-1 rounded text-white shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M5 12l5 5l10 -10" /></svg>
          </div>
          <div>
            <h4 class="font-bold text-sm">Facturatie op Rekening</h4>
            <p class="text-xs opacity-70">Periodieke verzamelfacturen voor uw administratie.</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <div class="bg-white/10 p-1 rounded text-white shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M5 12l5 5l10 -10" /></svg>
          </div>
          <div>
            <h4 class="font-bold text-sm">Tesla Executive Vloot</h4>
            <p class="text-xs opacity-70">Representatief vervoer in Tesla Model Y of Model 3.</p>
          </div>
        </li>
        <li class="flex items-start gap-3">
          <div class="bg-white/10 p-1 rounded text-white shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M5 12l5 5l10 -10" /></svg>
          </div>
          <div>
            <h4 class="font-bold text-sm">Internationale Ritten</h4>
            <p class="text-xs opacity-70">Lange afstandsspecialist naar o.a. Brussel en Parijs.</p>
          </div>
        </li>
      </ul>
    </div>
  </div>
</Layout>
