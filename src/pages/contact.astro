---
import Layout from '~/layouts/PageLayout.astro';
import ContactUs from '~/components/widgets/Contact.astro';
// Zorgt ervoor dat deze pagina statisch wordt gegenereerd voor maximale snelheid
export const prerender = true;

const metadata = {
  title: 'Contact | InTaxi Amsterdam - Uw Premium Taxi Partner',
  description: 'Neem direct contact op met InTaxi voor zakelijk vervoer, Tesla taxi services en luchthavenritten. 24/7 bereikbaar via WhatsApp en E-mail.',
};
---

<Layout metadata={metadata}>
  <!-- Video Hero Section -->
  <section class="relative h-[60vh] min-h-[500px] flex items-center justify-center overflow-hidden">
    <video
      autoplay
      muted
      loop
      playsinline
      class="absolute z-0 w-auto min-w-full min-h-full max-w-none object-cover"
    >
      <source src="/videos/video_intaxi.webm" type="video/webm" />
      Uw browser ondersteunt geen video-streaming.
    </video>
    
    <div class="absolute inset-0 bg-[#003399]/40 z-10"></div>

    <!-- 3 Compacte kaders in plaats van tekst/CTA -->
    <div class="relative z-20 w-full max-w-5xl px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <!-- Kader 1: WhatsApp -->
        <div class="bg-white/95 backdrop-blur-sm p-6 rounded-xl shadow-2xl text-center border-t-4 border-[#003399]">
          <div class="flex justify-center mb-3">
            <div class="p-3 bg-[#003399]/10 rounded-full text-[#003399]">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
            </div>
          </div>
          <h3 class="text-gray-900 font-bold text-lg mb-1 uppercase tracking-tight">WhatsApp</h3>
          <a href="https://wa.me/31642277607" class="text-[#003399] font-black text-xl hover:underline">06-42277607</a>
        </div>

        <!-- Kader 2: E-mail -->
        <div class="bg-white/95 backdrop-blur-sm p-6 rounded-xl shadow-2xl text-center border-t-4 border-[#003399]">
          <div class="flex justify-center mb-3">
            <div class="p-3 bg-[#003399]/10 rounded-full text-[#003399]">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            </div>
          </div>
          <h3 class="text-gray-900 font-bold text-lg mb-1 uppercase tracking-tight">E-mail</h3>
          <a href="mailto:info@intaxi.nl" class="text-[#003399] font-black text-xl hover:underline">info@intaxi.nl</a>
        </div>

        <!-- Kader 3: Standplaats -->
        <div class="bg-white/95 backdrop-blur-sm p-6 rounded-xl shadow-2xl text-center border-t-4 border-[#003399]">
          <div class="flex justify-center mb-3">
            <div class="p-3 bg-[#003399]/10 rounded-full text-[#003399]">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
            </div>
          </div>
          <h3 class="text-gray-900 font-bold text-lg mb-1 uppercase tracking-tight">Standplaats</h3>
          <p class="text-[#003399] font-black text-xl">Amsterdam</p>
        </div>

      </div>
    </div>
  </section>

  <!-- Contact Formulier & Zakelijke USP's -->
  <div class="grid md:grid-cols-2 gap-0 bg-white dark:bg-slate-900 border-t border-gray-100 dark:border-slate-800">
    <div class="p-8 md:p-16 border-r border-gray-100 dark:border-slate-800">
       <ContactUs
        id="form"
        title="Directe Aanvraag"
        subtitle="Stel hier uw vraag over onze vloot, internationale ritten of zakelijke accounts."
        inputs={[
          { type: 'text', name: 'name', label: 'Naam / Bedrijfsnaam' },
          { type: 'email', name: 'email', label: 'E-mailadres' },
        ]}
        textarea={{ label: 'Hoe kunnen we u van dienst zijn?' }}
        button="Verstuur Bericht"
      />
    </div>

    <div class="bg-[#003399] p-8 md:p-16 text-white flex flex-col justify-center">
      <h2 class="text-3xl font-bold mb-8 italic border-b border-white/20 pb-4">Zakelijke Partner</h2>
      <ul class="space-y-6">
        <li class="flex items-start gap-4">
          <div class="bg-white/20 p-2 rounded-lg text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M5 12l5 5l10 -10" /></svg>
          </div>
          <div>
            <h4 class="font-bold text-lg">Facturatie op Rekening</h4>
            <p class="text-sm opacity-80">Ideaal voor bedrijven. Ontvang periodieke facturen voor al uw ritten.</p>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <div class="bg-white/20 p-2 rounded-lg text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M5 12l5 5l10 -10" /></svg>
          </div>
          <div>
            <h4 class="font-bold text-lg">Tesla Executive Vloot</h4>
            <p class="text-sm opacity-80">Reis in stilte en comfort in onze Tesla Model Y of Model 3.</p>
          </div>
        </li>
        <li class="flex items-start gap-4">
          <div class="bg-white/20 p-2 rounded-lg text-white">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none"><path d="M5 12l5 5l10 -10" /></svg>
          </div>
          <div>
            <h4 class="font-bold text-lg">Internationale Ritten</h4>
            <p class="text-sm opacity-80">Gespecialiseerd in lange afstanden naar o.a. Parijs, Brussel en Berlijn.</p>
          </div>
        </li>
      </ul>
    </div>
  </div>
</Layout>
