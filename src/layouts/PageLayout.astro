---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';

import { headerData, footerData } from '~/navigation';

import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
}

const { metadata } = Astro.props;

// 1. Detecteer de huidige taal (nl of en)
const lang = (Astro.currentLocale || 'nl') as 'nl' | 'en';

// 2. Haal de juiste data op basis van de taal
const currentHeaderData = headerData(lang);
const currentFooterData = footerData(lang);
---

<Layout metadata={metadata}>
  <slot name="header">
    <Header 
      {...currentHeaderData} 
      isSticky 
      showToggleTheme 
    />
  </slot>
  <main>
    <slot />
  </main>
  <slot name="footer">
    <Footer {...currentFooterData} />
  </slot>

<script is:inline>
    const initChatbase = () => {
      // 1. Volledige reset van oude variabelen
      window.chatbase = undefined;

      // 2. Alleen de noodzakelijke config
      window.chatbaseConfig = {
        chatbotId: "xebg6Uj_yHqd9ef2Sq4F5",
      };

      // 3. Maak het script aan ZONDER eigen ID of extra attributen
      const s = document.createElement("script");
      s.src = "https://www.chatbase.co/embed.min.js";
      s.defer = true;
      
      // 4. Injecteer
      document.body.appendChild(s);
    };

    // Start bij eerste load
    if (document.readyState === 'complete') {
      initChatbase();
    } else {
      window.addEventListener('load', initChatbase);
    }

    // Start na elke Astro-navigatie
    document.addEventListener('astro:after-swap', initChatbase);
  </script>
  </script>
</Layout>
