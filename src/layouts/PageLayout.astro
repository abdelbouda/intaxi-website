---
import Layout from '~/layouts/Layout.astro';
import Header from '~/components/widgets/Header.astro';
import Footer from '~/components/widgets/Footer.astro';

import { headerData, footerData } from '~/navigation';

import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
}

const { metadata } = Astro.props;

// 1. Detecteer de huidige taal (nl of en)
const lang = (Astro.currentLocale || 'nl') as 'nl' | 'en';

// 2. Haal de juiste data op basis van de taal
const currentHeaderData = headerData(lang);
const currentFooterData = footerData(lang);
---

<Layout metadata={metadata}>
  <slot name="header">
    <Header 
      {...currentHeaderData} 
      isSticky 
      showToggleTheme 
    />
  </slot>
  <main>
    <slot />
  </main>
  <slot name="footer">
    <Footer {...currentFooterData} />
  </slot>

  <script is:inline>
    const initChatbase = () => {
      // 1. Verwijder de global om een schone herstart te forceren
      window.chatbase = undefined;

      // 2. Stel de officiële configuratie in
      window.chatbaseConfig = {
        chatbotId: "xebg6Uj_yHqd9ef2Sq4F5",
      };

      // 3. Maak het script aan met de ID die zij verwachten
      const s = document.createElement("script");
      s.src = "https://www.chatbase.co/embed.min.js";
      s.id = "xebg6Uj_yHqd9ef2Sq4F5"; 
      s.domain = "www.chatbase.co";
      s.defer = true;
      
      // 4. Injecteer in de body
      document.body.appendChild(s);
    };

    // Voer uit bij eerste keer laden
    if (document.readyState === 'complete') {
      initChatbase();
    } else {
      window.addEventListener('load', initChatbase);
    }

    // Luister naar Astro paginawissels (ClientRouter ondersteuning)
    // We gebruiken na-swap omdat dan de nieuwe DOM (body) klaar is voor de injectie
    document.addEventListener('astro:after-swap', initChatbase);
  </script>
</Layout>
